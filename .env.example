# White-label tenant config bundle (branding, emails, allergen key, template
# markers, seed rules/properties). Defaults to <repoRoot>/config. Override to run
# a different business's bundle. See docs/onboarding-new-business.md.
TENANT_CONFIG_PATH=

# Email Sending Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_AUTH=login
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_FROM=
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password

# Microsoft 365 IP-based SMTP relay example:
# SMTP_HOST=richardsandoval-com.mail.protection.outlook.com
# SMTP_PORT=25
# SMTP_AUTH=none
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_FROM=no-reply@richardsandoval.com
# SMTP_USER=
# SMTP_PASS=

# Email that receives internal review notifications
INTERNAL_REVIEWER_EMAIL=reviewer@example.com

# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_REVIEW_MODEL=gpt-4o-mini
BASIC_AI_CHECK_AUDIT_ENABLED=true
BASIC_AI_CHECK_AUDIT_MAX_CHARS=120000

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Alias for the modern Supabase dashboard label; either service key name works.
SUPABASE_SERVICE_ROLE_KEY=

# ClickUp Integration
CLICKUP_API_TOKEN=pk_your_token_here
CLICKUP_LIST_ID=your_list_id
CLICKUP_TEAM_ID=your_team_id
CLICKUP_ASSIGNEE_ID=your_assignee_user_id
CLICKUP_MARKETING_WATCHER_GROUP_NAME=Marketing
CLICKUP_MARKETING_WATCHER_GROUP_ID=
CLICKUP_WATCHER_USER_IDS=
CLICKUP_WEBHOOK_URL=https://your-server.com/webhook/clickup
CLICKUP_WEBHOOK_SECRET=your_webhook_secret_from_clickup
CLICKUP_INITIAL_REVIEW_STATUS=pending initial isa review
CLICKUP_CORRECTIONS_STATUS=to do
CLICKUP_CORRECTIONS_STATUSES=
CLICKUP_POST_APPROVAL_STATUS=to do

# File Paths
SOP_DOC_PATH=samples/sop.txt

# Dashboard URL (for email links)
DASHBOARD_URL=http://localhost:3005
# Optional override specifically for public improvement-cycle proposal links.
# Leave blank to use DASHBOARD_URL.
DASHBOARD_PUBLIC_URL=

# Service URLs (override for cloud deployments)
DB_SERVICE_URL=http://localhost:3004
AI_REVIEW_URL=http://localhost:3002
DIFFER_SERVICE_URL=http://localhost:3006
CLICKUP_SERVICE_URL=http://localhost:3007

# Shared token required for service-to-service calls across dashboard/internal APIs
INTERNAL_API_TOKEN=replace-with-a-long-random-secret
# Default timeout in milliseconds for internal service-to-service HTTP calls
# Defaults to 5000 when blank/unset; individual long-running calls may override it
INTERNAL_API_TIMEOUT_MS=
AI_REVIEW_SUBMIT_TIMEOUT_MS=120000
CLICKUP_TASK_CREATE_TIMEOUT_MS=60000

# JSON body limits for rich menu submissions and internal raw-payload saves
# Defaults to 5mb when blank/unset
JSON_BODY_LIMIT=
DASHBOARD_JSON_BODY_LIMIT=
DB_JSON_BODY_LIMIT=

# Persistent document storage root (recommended for cloud deploy: mount a persistent volume)
# For Docker/Lightsail/EC2: set to the container path backed by a named volume (e.g. /app/tmp/documents)
# Local dev: leave blank to use default tmp/documents
DOCUMENT_STORAGE_ROOT=

# Persistent differ learning-data root (recommended for cloud deploy: mount a persistent volume)
# For Docker/Lightsail/EC2: set to the container path backed by a named volume (e.g. /app/tmp/learning)
# Local dev: leave blank to use default tmp/learning
LEARNING_DATA_DIR=

# Weekly prompt rewrite model (for scripts/prompt-rewrite.js)
PROMPT_REWRITE_MODEL=gpt-4o

# Learned reviewer-correction rule controls
LEARNING_MIN_OCCURRENCES=2
LEARNING_MAX_OVERLAY_RULES=25

# Admin alert email (receives system failure notifications)
# Separate from INTERNAL_REVIEWER_EMAIL so alerts go to a dedicated inbox
ALERT_EMAIL=alerts@example.com

# Production public-form failure alerts (defaults to dcowser@richardsandoval.com if unset)
FORM_ATTEMPT_ALERT_EMAIL=dcowser@richardsandoval.com
PUBLIC_FORM_SUPPORT_EMAIL=dcowser@richardsandoval.com

# Microsoft Graph mail/SharePoint app registration
# Copy the client secret Value from Azure, not the Secret ID.
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_CLIENT_SECRET_EXPIRES=
GRAPH_MAILBOX_ADDRESS=
GRAPH_USER_EMAIL=
ALERT_MAIL_GRAPH_DISABLED=false
