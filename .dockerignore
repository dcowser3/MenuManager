# Keep the build context small. Dockerfile.dev only needs package.json files
# (for npm ci layer caching), the docx-redliner requirements.txt, and the
# shared-lib source (for the build step). Service source comes in via
# bind mounts at runtime — no need to ship it into the image.

**/node_modules
**/dist
**/.cache
**/.parcel-cache
**/coverage
**/.next

# Virtualenvs and Python bytecode
**/venv
**/__pycache__
**/*.pyc

# Local state and secrets
.env
.env.*
!.env.example
tmp
logs
*.log

# Editor / OS scratch
.DS_Store
.idea
.vscode
*.swp

# VCS + CI
.git
.gitignore
.github

# Docker meta
docker-compose*.yml
docker/Dockerfile*
.dockerignore

# Worktrees and backups
.claude/worktrees
*.bak
*.orig

# Big sample / test artifacts that aren't needed at build time
**/test-files

# sop-processor: ship qa_prompt.txt and sop_rules.* (read at runtime), but
# leave the source PDF and extraction scratch out of the image.
sop-processor/company_sop.pdf
sop-processor/sop_raw_text.txt
sop-processor/extract_sop.py
sop-processor/requirements.txt
sop-processor/README.md
sop-processor/.DS_Store

# samples: ship the two .docx templates the dashboard reads at runtime
# (food + beverage). Demo files, PDFs, and email/training subdirs stay out.
samples/.DS_Store
samples/~$*
samples/*.pdf
samples/SAMPLE-CONTENT.txt
samples/sop.txt
samples/demo-*.docx
samples/Design Approval Pairs
samples/FW_ Zengo Doha - Menu
samples/example_pairs
