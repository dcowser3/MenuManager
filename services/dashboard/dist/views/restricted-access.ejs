<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --text: #333;
            --muted: #777;
            --border: #e8e4de;
            --bg: #fff;
            --bg-alt: #fafaf8;
            --primary: #2c2c2c;
            --danger: #8b3a3a;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            background: var(--bg-alt);
            color: var(--text);
            font-family: 'Montserrat', sans-serif;
        }
        .card {
            width: min(100%, 420px);
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 2rem;
        }
        h1 {
            margin: 0 0 .5rem;
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            letter-spacing: .04em;
        }
        p {
            margin: 0 0 1.25rem;
            color: var(--muted);
            line-height: 1.6;
            font-size: .92rem;
        }
        label {
            display: block;
            margin-bottom: .4rem;
            font-size: .72rem;
            letter-spacing: .12em;
            text-transform: uppercase;
        }
        input[type="password"] {
            width: 100%;
            padding: .9rem 1rem;
            border: 1px solid var(--border);
            font-size: 1rem;
            letter-spacing: .3em;
            text-align: center;
        }
        .error {
            margin-bottom: 1rem;
            color: var(--danger);
            font-size: .85rem;
        }
        button {
            width: 100%;
            margin-top: 1rem;
            padding: .9rem 1rem;
            border: 1px solid var(--primary);
            background: var(--primary);
            color: #fff;
            cursor: pointer;
            font-size: .72rem;
            letter-spacing: .14em;
            text-transform: uppercase;
        }
    </style>
</head>
<body>
    <form class="card" method="post" action="/restricted-access">
        <h1>Restricted Access</h1>
        <p>Learning and training tools are temporarily limited to approved team members. Enter the 4-digit PIN to continue.</p>
        <% if (errorMessage) { %>
            <div class="error"><%= errorMessage %></div>
        <% } %>
        <input type="hidden" name="next" value="<%= nextPath %>">
        <label for="pin">4-Digit PIN</label>
        <input id="pin" name="pin" type="password" inputmode="numeric" pattern="[0-9]{4}" maxlength="4" autocomplete="one-time-code" required>
        <button type="submit">Continue</button>
    </form>
</body>
</html>
