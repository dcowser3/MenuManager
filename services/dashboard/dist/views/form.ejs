        function formatDateForInput(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function getTurnaroundDaysValue() {
            const raw = parseInt((document.getElementById('turnaroundDays').value || '').trim(), 10);
            const minDays = getMinimumTurnaroundDays();
            if (!Number.isFinite(raw) || raw < minDays) {
                return getDefaultTurnaroundDays();
            }
            return raw;
        }

        function setDateNeededMinimumFromTurnaround(forceDateToMinimum = false) {
            const dateInput = document.getElementById('dateNeeded');
            const days = getTurnaroundDaysValue();
            const minDate = window.formHelpers.addBusinessDays(new Date(), days);
            const minDateStr = formatDateForInput(minDate);
            dateInput.min = minDateStr;
            dateInput.value = minDateStr;
        }

        function onTurnaroundDaysChange(event) {
            const turnaroundInput = document.getElementById('turnaroundDays');
            const minDays = getMinimumTurnaroundDays();
            if (event && event.isTrusted) {
                const rawValue = (turnaroundInput.value || '').trim();
                turnaroundUserState[submissionMode].isUserSet = !!rawValue;
                turnaroundUserState[submissionMode].value = rawValue;
            }
            turnaroundInput.min = String(minDays);
            const current = parseInt((turnaroundInput.value || '').trim(), 10);
            if (Number.isFinite(current) && current < minDays) {
                turnaroundInput.setCustomValidity(getTurnaroundMinimumMessage());
                setTurnaroundFieldError(getTurnaroundMinimumMessage());
            } else {
                turnaroundInput.setCustomValidity('');
                setTurnaroundFieldError('');
            }
            setDateNeededMinimumFromTurnaround(true);
        }

        function onDateNeededBlur() {
            const dateInput = document.getElementById('dateNeeded');
            if (dateInput.value && dateInput.min && dateInput.value < dateInput.min) {
                showAlert(`Date needed cannot be earlier than ${dateInput.min} based on turnaround days.`, 'error');
                dateInput.value = dateInput.min;
            }
        }

        function applyTurnaroundDefaults(forceDateToMinimum = false, forceValue = false) {
            const turnaroundInput = document.getElementById('turnaroundDays');
            const defaultDays = getDefaultTurnaroundDays();
            const modeState = turnaroundUserState[submissionMode];
            const storedValue = (modeState.value || '').trim();
            const hasUserValue = modeState.isUserSet && storedValue;
            const desiredValue = hasUserValue ? storedValue : String(defaultDays);
            turnaroundInput.min = String(getMinimumTurnaroundDays());
            if (forceValue || !hasUserValue || (turnaroundInput.value || '').trim() !== desiredValue) {
                turnaroundInput.value = desiredValue;
            }
            if (!hasUserValue) {
                modeState.value = String(defaultDays);
            }
            turnaroundInput.setCustomValidity('');
            setTurnaroundFieldError('');
            setDateNeededMinimumFromTurnaround(forceDateToMinimum);
        }

