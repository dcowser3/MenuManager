        // ---- Progressive-disclosure reveal wiring ----------------------------
        // Snapshot of the form passed to the pure stage logic in form-stage.js.
        function gatherFormStateForStage() {
            function val(id) {
                const el = document.getElementById(id);
                return el ? (el.value || '') : '';
            }
            return {
                menuUploaded: menuUploaded,
                submitterName: val('submitterName'),
                submitterEmail: val('submitterEmail'),
                submitterJobTitle: val('submitterJobTitle'),
                projectName: val('projectName'),
                property: val('property'),
                menuType: val('menuType'),
                servicePeriod: val('servicePeriod'),
                templateType: val('templateType'),
                turnaroundDays: val('turnaroundDays'),
                dateNeeded: val('dateNeeded'),
                assetType: val('assetType'),
                orientation: val('orientation'),
                widthPrint: val('widthPrint'),
                heightPrint: val('heightPrint'),
                printRegion: val('printRegion'),
                printSize: val('printSize'),
                folded: val('folded'),
                cropMarks: val('cropMarks'),
                bleedMarks: val('bleedMarks'),
                fileSizeLimit: val('fileSizeLimit'),
                fileSizeLimitMb: val('fileSizeLimitMb'),
                widthDigital: val('widthDigital'),
                heightDigital: val('heightDigital'),
                approval1: val('approval1'),
                approver1Name: val('approver1Name'),
                approver1Position: val('approver1Position'),
                approver1Email: val('approver1Email'),
                aiCheckHasRun: aiCheckHasRun
            };
        }

        // Reveal (fade + slide) or collapse a .reveal-wrapped section by id.
        function setSectionRevealed(id, shouldReveal) {
            const el = document.getElementById(id);
            if (!el) return;
            const isRevealed = el.classList.contains('revealed');
            if (shouldReveal && !isRevealed) {
                el.classList.add('revealed');
                requestAnimationFrame(function () {
                    requestAnimationFrame(function () { el.classList.add('show'); });
                });
            } else if (!shouldReveal && isRevealed) {
                el.classList.remove('revealed', 'show');
            }
        }

        // Recompute which progressively-disclosed sections should be visible and
        // apply it. Safe to call before the new markup exists (missing ids no-op).
        function applyStageReveals() {
            if (!formStage) return;
            const reveal = formStage.computeRevealState(gatherFormStateForStage());
            setSectionRevealed('menuSplitBlock', reveal.menu && !menuFloatedDown);
            setSectionRevealed('detailsStage', reveal.details);
            setSectionRevealed('approvalStage', reveal.approval);
            setSectionRevealed('submitterStage', reveal.submitter);
            if (typeof updateAiSubmitStageVisibility === 'function') {
                updateAiSubmitStageVisibility(reveal);
            }
            refreshNeedsInputHighlights();
        }

        // Highlight the required fields the chef STILL needs to fill (empty +
        // currently visible), clearing each as it's completed. Replaces the old
        // "highlight what was auto-filled" behavior, which was less intuitive.
        function refreshNeedsInputHighlights() {
            function val(id) { const el = document.getElementById(id); return el ? (el.value || '') : ''; }
            const assetType = val('assetType');
            const isPrint = assetType === 'PRINT' || assetType === 'BOTH';
            const isDigital = assetType === 'DIGITAL' || assetType === 'BOTH';
            const required = [
                'projectName', 'property', 'menuType', 'servicePeriod', 'templateType',
                'turnaroundDays', 'dateNeeded', 'assetType', 'orientation',
                'approval1', 'approver1Name', 'approver1Position', 'approver1Email',
                'submitterName', 'submitterEmail', 'submitterJobTitle'
            ];
            if (isPrint) {
                required.push('folded', 'printRegion', 'cropMarks', 'bleedMarks', 'fileSizeLimit');
                if (val('printRegion') === 'NON_US') required.push('printSize');
                else required.push('widthPrint', 'heightPrint');
                if (val('fileSizeLimit') === 'yes') required.push('fileSizeLimitMb');
            }
            if (isDigital) required.push('widthDigital', 'heightDigital');

            required.forEach(function (id) {
                const el = document.getElementById(id);
                if (!el) return;
                const visible = !!(el.offsetParent || el.getClientRects().length);
                const empty = !String(el.value || '').trim();
                if (visible && empty) el.classList.add('needs-input');
                else el.classList.remove('needs-input');
            });
        }

        // ---- Copy project details from a previous submission ----------------
        // Reuses the approved-submission search + applyProjectPrefill, but fills
        // ONLY the project-detail fields — the uploaded menu is never touched.
        let projectPrefillResults = [];
        let projectPrefillDebounce = null;

        function toggleProjectPrefill() {
            const panel = document.getElementById('projectPrefillPanel');
            if (!panel) return;
            panel.classList.toggle('hidden');
            if (!panel.classList.contains('hidden')) {
                const input = document.getElementById('projectPrefillSearch');
                if (input) input.focus();
            }
        }

        function onProjectPrefillSearch(value) {
            clearTimeout(projectPrefillDebounce);
            const query = (value || '').trim();
            const resultsEl = document.getElementById('projectPrefillResults');
            if (query.length < 2) {
                if (resultsEl) resultsEl.innerHTML = '';
                projectPrefillResults = [];
                return;
            }
            projectPrefillDebounce = setTimeout(function () { searchProjectPrefill(query); }, 250);
        }

        async function searchProjectPrefill(query) {
            const resultsEl = document.getElementById('projectPrefillResults');
            try {
                const { property, servicePeriod } = getCurrentPropertyService();
                const params = new URLSearchParams({ q: query, limit: '20' });
                if (property) params.set('property', property);
                if (servicePeriod) params.set('servicePeriod', servicePeriod);
                const response = await fetch(`/api/submissions/search?${params.toString()}`);
                const results = await response.json();
                if (!response.ok) throw new Error(results.error || 'Search failed');
                projectPrefillResults = results || [];
                if (!resultsEl) return;
                if (!projectPrefillResults.length) {
                    resultsEl.innerHTML = '<div class="search-result-item">No previous submissions found.</div>';
                    return;
                }
                resultsEl.innerHTML = projectPrefillResults.map(function (r, idx) {
                    return `
                    <div class="search-result-item" onclick="selectProjectPrefill(${idx})">
                        <strong>${escapeHtml(r.projectName || '(Untitled)')}</strong> - ${escapeHtml(r.property || 'Unknown Property')}<br>
                        <span style="color: var(--color-text-muted);">Service: ${escapeHtml(r.servicePeriod || 'N/A')} | ${escapeHtml(formatApprovedDate(r.reviewedAt || r.updatedAt))}</span>
                    </div>`;
                }).join('');
            } catch (error) {
                console.error('Project prefill search failed:', error);
                if (resultsEl) resultsEl.innerHTML = '<div class="search-result-item">Search failed.</div>';
            }
        }

        function selectProjectPrefill(index) {
            const selected = projectPrefillResults[index];
            if (!selected) return;
            applyProjectPrefill(selected);
            refreshNeedsInputHighlights();
            applyStageReveals();
            const panel = document.getElementById('projectPrefillPanel');
            if (panel) panel.classList.add('hidden');
            const search = document.getElementById('projectPrefillSearch');
            if (search) search.value = '';
            const resultsEl = document.getElementById('projectPrefillResults');
            if (resultsEl) resultsEl.innerHTML = '';
            showAlert(`Copied project details from "${selected.projectName || 'previous submission'}". Review and adjust as needed.`, 'success');
        }

        // FLIP: smoothly animate `node` from its current on-screen position to
        // wherever it lands after `mutate()` moves it in the DOM. No-ops (but
        // still performs the move) under prefers-reduced-motion.
        function flipMove(node, mutate, onSettled) {
            const settle = function () {
                if (typeof onSettled === 'function') onSettled();
            };
            if (!node) {
                if (typeof mutate === 'function') mutate();
                settle();
                return;
            }
            const reduceMotion = window.matchMedia
                && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            const first = node.getBoundingClientRect();
            if (typeof mutate === 'function') mutate();
            const last = node.getBoundingClientRect();
            const dx = first.left - last.left;
            const dy = first.top - last.top;
            if (reduceMotion || (!dx && !dy)) {
                requestAnimationFrame(settle);
                return;
            }
            node.classList.remove('flip-animating');
            node.style.transform = 'translate(' + dx + 'px, ' + dy + 'px)';
            requestAnimationFrame(function () {
                node.classList.add('flip-animating');
                node.style.transform = '';
                let settled = false;
                const cleanup = function (event) {
                    if (event && event.target !== node) return;
                    if (settled) return;
                    settled = true;
                    node.classList.remove('flip-animating');
                    node.removeEventListener('transitionend', cleanup);
                    settle();
                };
                node.addEventListener('transitionend', cleanup);
                setTimeout(cleanup, 600);
            });
        }

        function getOrCreateFormAttemptId() {
            const storageKey = 'menumanager_form_attempt_id';
            try {
                const existing = window.sessionStorage && window.sessionStorage.getItem(storageKey);
                if (existing) return existing;
                const generated = generateFormAttemptId();
                if (window.sessionStorage) window.sessionStorage.setItem(storageKey, generated);
                return generated;
            } catch (error) {
                return generateFormAttemptId();
            }
        }

        function generateFormAttemptId() {
            return (window.crypto && window.crypto.randomUUID)
                ? window.crypto.randomUUID()
                : `attempt-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        }

        function resetFormAttemptId() {
            const generated = generateFormAttemptId();
            formAttemptId = generated;
            try {
                if (window.sessionStorage) {
                    window.sessionStorage.setItem('menumanager_form_attempt_id', generated);
                }
            } catch (error) {
                // Non-critical telemetry only.
            }
        }

        function byteLength(value) {
            const text = typeof value === 'string' ? value : JSON.stringify(value || '');
            if (window.TextEncoder) return new TextEncoder().encode(text).length;
            return unescape(encodeURIComponent(text)).length;
        }

        // HTTP header values must be ISO-8859-1 (Latin-1). Smart punctuation (curly
        // apostrophes, em dashes, etc.) from menu names like "d'Leña" is outside that
        // range and makes fetch() throw before the request is sent. These headers are
        // diagnostic-only, so normalize common smart punctuation to ASCII and drop any
        // remaining out-of-range code points.
        function headerSafe(value) {
            return String(value == null ? '' : value)
                .replace(/[‘’‚‛]/g, "'")
                .replace(/[“”„‟]/g, '"')
                .replace(/[–—―]/g, '-')
                .replace(/[…]/g, '...')
                .replace(/[^\x00-\xFF]/g, '');
        }

        function getAttemptHeaders(extra) {
            const headers = {
                'x-menumanager-attempt-id': formAttemptId,
                'x-menumanager-submit-mode': submissionMode || '',
                'x-menumanager-revision-source': revisionSource || '',
                'x-menumanager-submitter-email': document.getElementById('submitterEmail')?.value?.trim() || '',
                'x-menumanager-project': document.getElementById('projectName')?.value?.trim() || '',
                'x-menumanager-property': document.getElementById('property')?.value?.trim() || '',
                ...(extra || {})
            };
            for (const key of Object.keys(headers)) {
                headers[key] = headerSafe(headers[key]);
            }
            return headers;
        }

        function getAttemptMetadata(extra) {
            return {
                attemptId: formAttemptId,
                submitterEmail: document.getElementById('submitterEmail')?.value?.trim() || '',
                submitterName: document.getElementById('submitterName')?.value?.trim() || '',
                projectName: document.getElementById('projectName')?.value?.trim() || '',
                property: document.getElementById('property')?.value?.trim() || '',
                servicePeriod: document.getElementById('servicePeriod')?.value || '',
                templateType: document.getElementById('templateType')?.value || '',
                submissionMode,
                revisionSource: submissionMode === 'modification' ? revisionSource : '',
                revisionBaselineFileName: submissionMode === 'modification' ? revisionBaselineFileName : '',
                draftSessionId: draftSessionId || '',
                baseMenuTextLength: (baseApprovedMenuContent || '').length,
                ...(extra || {})
            };
        }

        async function logFormAttempt(eventType, extra) {
            const payload = getAttemptMetadata({ eventType, ...(extra || {}) });
            const body = JSON.stringify(payload);
            try {
                if (navigator.sendBeacon) {
                    const blob = new Blob([body], { type: 'application/json' });
                    if (navigator.sendBeacon('/api/form/attempt-log', blob)) return;
                }
                await fetch('/api/form/attempt-log', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', ...getAttemptHeaders() },
                    body,
                    keepalive: true
                });
            } catch (error) {
                console.warn('Failed to log form attempt event:', error);
            }
        }

        const BASIC_CHECK_CLIENT_TIMEOUT_MS = 150000;
        const BASIC_CHECK_DEBUG_ENABLED = new URLSearchParams(window.location.search).has('debugBasicCheck');

        function getBasicCheckDebugHeaders() {
            return BASIC_CHECK_DEBUG_ENABLED ? { 'x-menumanager-debug-basic-check': '1' } : {};
        }

