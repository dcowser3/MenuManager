        function truncateReportText(value, maxChars) {
            const text = `${value || ''}`;
            if (text.length <= maxChars) return text;
            return `${text.slice(0, maxChars)}... [truncated ${text.length - maxChars} chars]`;
        }

        function compactReportValue(value, options, depth) {
            const opts = options || {};
            const currentDepth = depth || 0;
            const maxDepth = opts.maxDepth || 4;
            const stringLimit = opts.stringLimit || 10000;
            const maxArrayItems = opts.maxArrayItems || 50;
            const maxKeys = opts.maxKeys || 80;
            if (value === null || value === undefined) return value ?? null;
            if (currentDepth >= maxDepth) return '[max depth reached]';
            if (typeof value === 'string') return truncateReportText(value, stringLimit);
            if (typeof value === 'number' || typeof value === 'boolean') return value;
            if (Array.isArray(value)) {
                const items = value.slice(0, maxArrayItems).map((item) => compactReportValue(item, opts, currentDepth + 1));
                if (value.length > maxArrayItems) items.push(`[+${value.length - maxArrayItems} more items truncated]`);
                return items;
            }
            if (typeof value === 'object') {
                const entries = Object.entries(value).slice(0, maxKeys).map(([key, entryValue]) => [
                    key.slice(0, 120),
                    compactReportValue(entryValue, opts, currentDepth + 1)
                ]);
                if (Object.keys(value).length > maxKeys) {
                    entries.push(['_truncatedKeys', `[+${Object.keys(value).length - maxKeys} more keys truncated]`]);
                }
                return Object.fromEntries(entries);
            }
            return `${value}`;
        }

        function summarizeFieldLengths(fields) {
            return Object.fromEntries(Object.entries(fields || {}).map(([key, value]) => {
                const length = Array.isArray(value)
                    ? value.join(', ').length
                    : `${value ?? ''}`.length;
                return [key.slice(0, 120), { length }];
            }));
        }

        function buildCompactProblemReportState(state) {
            const menuEditor = state.menuEditor || {};
            return {
                droppedReason: 'full state snapshot too large; sending compact state',
                capturedAt: state.capturedAt,
                page: state.page,
                fields: compactReportValue(state.fields || {}, { stringLimit: 5000, maxArrayItems: 50, maxKeys: 80, maxDepth: 3 }),
                menuEditor: {
                    menuTextLength: menuEditor.menuTextLength || 0,
                    menuHtmlLength: menuEditor.menuHtmlLength || 0,
                    menuText: truncateReportText(menuEditor.menuText || '', 80000),
                    menuHtml: truncateReportText(menuEditor.menuHtml || '', 80000)
                },
                appState: compactReportValue(state.appState || {}, { stringLimit: 5000, maxArrayItems: 50, maxKeys: 80, maxDepth: 3 }),
                aiCheck: {
                    hasRun: !!state.aiCheck?.hasRun,
                    hasCriticalErrors: !!state.aiCheck?.hasCriticalErrors,
                    suggestions: compactReportValue((state.aiCheck?.suggestions || []).slice(0, 25), { stringLimit: 5000, maxArrayItems: 25, maxKeys: 80, maxDepth: 4 }),
                    lastDiagnostics: compactReportValue(state.aiCheck?.lastDiagnostics || null, { stringLimit: 5000, maxArrayItems: 50, maxKeys: 80, maxDepth: 3 })
                },
                recentAlerts: state.recentAlerts || []
            };
        }

        function buildMinimalProblemReportState(state) {
            const menuEditor = state.menuEditor || {};
            return {
                droppedReason: 'state snapshot minimized to stay under report payload limit',
                capturedAt: state.capturedAt,
                page: state.page,
                fieldLengths: summarizeFieldLengths(state.fields || {}),
                menuEditor: {
                    menuTextLength: menuEditor.menuTextLength || 0,
                    menuHtmlLength: menuEditor.menuHtmlLength || 0
                },
                appState: {
                    submissionMode: state.appState?.submissionMode || '',
                    revisionSource: state.appState?.revisionSource || '',
                    revisionBaselineFileName: state.appState?.revisionBaselineFileName || '',
                    revisionBaseSubmissionId: state.appState?.revisionBaseSubmissionId || '',
                    unapprovedMode: !!state.appState?.unapprovedMode,
                    aiCheckHasRun: !!state.appState?.aiCheckHasRun,
                    aiCheckCompletedCount: state.appState?.aiCheckCompletedCount || 0,
                    requiresAiRerun: !!state.appState?.requiresAiRerun,
                    isEditMode: !!state.appState?.isEditMode,
                    baseMenuTextLength: state.appState?.baseMenuTextLength || 0,
                    persistentDiffHtmlLength: state.appState?.persistentDiffHtmlLength || 0,
                    persistentDiffSummary: state.appState?.persistentDiffSummary || null
                },
                aiCheck: {
                    hasRun: !!state.aiCheck?.hasRun,
                    hasCriticalErrors: !!state.aiCheck?.hasCriticalErrors,
                    suggestionCount: (state.aiCheck?.suggestions || []).length
                },
                recentAlerts: state.recentAlerts || []
            };
        }

        function serializeProblemReportPayload(payload, state) {
            let body = JSON.stringify(payload);
            if (byteLength(body) <= REPORT_MAX_BODY_BYTES) return body;

            const screenshotDataUrl = payload.screenshotDataUrl || null;
            const screenshotError = payload.screenshotError || '';
            payload.state = buildCompactProblemReportState(state);
            body = JSON.stringify(payload);
            if (byteLength(body) <= REPORT_MAX_BODY_BYTES) return body;

            payload.state = buildMinimalProblemReportState(state);
            body = JSON.stringify(payload);
            if (byteLength(body) <= REPORT_MAX_BODY_BYTES) return body;

            if (screenshotDataUrl) {
                payload.screenshotDataUrl = null;
                payload.screenshotError = screenshotError
                    ? `${screenshotError}; screenshot dropped: report payload too large`
                    : 'screenshot dropped: report payload too large';
                payload.state = buildCompactProblemReportState(state);
                body = JSON.stringify(payload);
                if (byteLength(body) <= REPORT_MAX_BODY_BYTES) return body;

                payload.state = buildMinimalProblemReportState(state);
                body = JSON.stringify(payload);
                if (byteLength(body) <= REPORT_MAX_BODY_BYTES) return body;
            }

            payload.recentAlerts = [];
            payload.context = truncateReportText(payload.context || '', 500);
            payload.state = {
                droppedReason: 'state snapshot omitted to stay under report payload limit',
                page: state.page,
                menuEditor: {
                    menuTextLength: state.menuEditor?.menuTextLength || 0,
                    menuHtmlLength: state.menuEditor?.menuHtmlLength || 0
                }
            };
            return JSON.stringify(payload);
        }

        async function sendProblemReport(options) {
            const opts = options || {};
            if (problemReportInFlight) return;
            problemReportInFlight = true;
            const btn = opts.sourceButton || null;
            const originalLabel = btn ? btn.textContent : '';
            if (btn) {
                btn.disabled = true;
                btn.textContent = 'Capturing page…';
            }

            try {
                // Capture before any UI changes so the screenshot shows exactly
                // what the user is looking at, including the open error alert.
                let screenshotDataUrl = null;
                let screenshotError = '';
                try {
                    screenshotDataUrl = await capturePageScreenshot();
                } catch (error) {
                    screenshotError = (error && error.message) ? error.message : 'screenshot capture failed';
                }

                if (btn) btn.textContent = 'Sending report…';

                const state = collectClientStateSnapshot();
                const payload = {
                    attemptId: formAttemptId,
                    trigger: opts.trigger || 'unknown',
                    context: opts.context || '',
                    pageUrl: window.location.href,
                    userAgent: navigator.userAgent,
                    viewport: state.page.viewport,
                    submitterName: document.getElementById('submitterName')?.value?.trim() || '',
                    submitterEmail: document.getElementById('submitterEmail')?.value?.trim() || '',
                    projectName: document.getElementById('projectName')?.value?.trim() || '',
                    property: document.getElementById('property')?.value?.trim() || '',
                    submissionMode,
                    recentAlerts: recentClientAlerts.slice(),
                    screenshotError,
                    screenshotDataUrl,
                    state
                };

                const body = serializeProblemReportPayload(payload, state);

                const response = await fetch('/api/form/error-report', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', ...getAttemptHeaders() },
                    body
                });
                const data = await response.json().catch(() => ({}));
                if (!response.ok) throw new Error(data.error || `Failed to send the report (status ${response.status})`);

                if (btn) {
                    btn.textContent = 'Report sent ✓';
                    setTimeout(() => {
                        btn.disabled = false;
                        btn.textContent = originalLabel;
                    }, 8000);
                }
                const incidentNote = data.incidentId ? ` Incident ID: ${data.incidentId}.` : '';
                showAlert(`Problem report sent.${incidentNote} It includes the details you filled in, so the team can investigate without needing anything else from you.`, 'success');
            } catch (error) {
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = originalLabel;
                }
                logFormAttempt('error_report_client_failed', {
                    errorMessage: (error && error.message) ? error.message : 'unknown error',
                    details: { trigger: opts.trigger || 'unknown' }
                });
                showAlert('Could not send the problem report automatically (' + ((error && error.message) || 'unknown error') + ').', 'error', { noReportAction: true });
            } finally {
                problemReportInFlight = false;
            }
        }

        function showAlert(message, type = 'info', options = {}) {
            const DEFAULT_ALERT_DURATIONS = {
                success: 6000,
                info: 6000,
                warning: 9000,
                error: 0
            };
            recordClientAlert(type, message);
            const container = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} show`;
            alert.setAttribute('role', type === 'error' ? 'alert' : 'status');

            const msgSpan = document.createElement('span');
            msgSpan.className = 'alert-message';
            msgSpan.textContent = message;
            alert.appendChild(msgSpan);

            if (type === 'error') {
                const support = document.createElement('span');
                support.className = 'alert-support';
                const supportLink = document.createElement('a');
                supportLink.href = 'mailto:<%= supportEmail %>';
                supportLink.textContent = '<%= supportEmail %>';
                if (options.noReportAction) {
                    support.appendChild(document.createTextNode(' If this keeps happening or blocks your submission, email '));
                    support.appendChild(supportLink);
                    support.appendChild(document.createTextNode(' and include screenshots with your email.'));
                } else {
                    support.appendChild(document.createTextNode(' If this keeps happening or blocks your submission, '));
                    const reportBtn = document.createElement('button');
                    reportBtn.type = 'button';
                    reportBtn.className = 'report-problem-btn';
                    reportBtn.textContent = 'Report this problem';
                    reportBtn.title = 'Emails our support team a screenshot of this page plus the details you have filled in';
                    // The alert intentionally stays open so the screenshot captures it.
                    reportBtn.onclick = () => sendProblemReport({ trigger: 'error_alert', context: message, sourceButton: reportBtn });
                    support.appendChild(reportBtn);
                    support.appendChild(document.createTextNode(' (sends us a screenshot of this page and your form details) or email '));
                    support.appendChild(supportLink);
                    support.appendChild(document.createTextNode('.'));
                }
                alert.appendChild(support);
            }

            let dismissTimer = null;
            const dismissAlert = () => {
                if (dismissTimer) clearTimeout(dismissTimer);
                if (!alert.isConnected || alert.classList.contains('closing')) return;
                alert.classList.add('closing');
                setTimeout(() => alert.remove(), 180);
            };

            const dismiss = document.createElement('button');
            dismiss.type = 'button';
            dismiss.className = 'alert-dismiss';
            dismiss.setAttribute('aria-label', 'Dismiss notification');
            dismiss.textContent = '×';
            dismiss.onclick = dismissAlert;
            alert.appendChild(dismiss);

            // Retry button
            if (options.onRetry) {
                const retryBtn = document.createElement('button');
                retryBtn.type = 'button';
                retryBtn.className = 'alert-action';
                retryBtn.textContent = 'Retry';
                retryBtn.onclick = () => { dismissAlert(); options.onRetry(); };
                alert.appendChild(retryBtn);
            }

            if (Array.isArray(options.actions)) {
                options.actions.forEach((action) => {
                    if (!action || !action.label) return;
                    if (typeof action.onClick === 'function') {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'alert-action';
                        button.textContent = action.label;
                        button.onclick = () => {
                            dismissAlert();
                            action.onClick();
                        };
                        alert.appendChild(button);
                        return;
                    }
                    if (!action.href) return;
                    const link = document.createElement('a');
                    link.className = 'alert-action';
                    link.href = action.href;
                    link.textContent = action.label;
                    link.target = action.target || '_self';
                    link.rel = 'noopener';
                    alert.appendChild(link);
                });
            }

            const hasExplicitAutoDismiss = Object.prototype.hasOwnProperty.call(options, 'autoDismissMs');
            const autoDismissMs = options.persistent
                ? 0
                : (hasExplicitAutoDismiss
                    ? Number(options.autoDismissMs || 0)
                    : (DEFAULT_ALERT_DURATIONS[type] || 0));

            if (autoDismissMs > 0) {
                const progress = document.createElement('div');
                progress.className = 'toast-progress';
                progress.style.setProperty('--toast-duration', `${autoDismissMs}ms`);
                alert.appendChild(progress);
            }

            container.appendChild(alert);

            if (autoDismissMs > 0 && !options.persistent) {
                dismissTimer = setTimeout(dismissAlert, autoDismissMs);
            }
        }

        function triggerLocalSubmissionDownload(downloadUrl) {
            if (!downloadUrl) return;
            const anchor = document.createElement('a');
            anchor.href = downloadUrl;
            anchor.download = '';
            anchor.style.display = 'none';
            document.body.appendChild(anchor);
            anchor.click();
            setTimeout(() => anchor.remove(), 1000);
        }

        function validateStep1(options = {}) {
            clearErrorAlerts();
            clearApprovalsCardError();
            const allowDraftPrecheckConfirmLater = !!options.allowDraftPrecheckConfirmLater;
            const submitterName = document.getElementById('submitterName').value.trim();
            const submitterEmail = document.getElementById('submitterEmail').value.trim();
            const submitterJobTitle = document.getElementById('submitterJobTitle').value.trim();
            const projectName = document.getElementById('projectName').value.trim();
            const property = document.getElementById('property').value.trim();
            const orientation = document.getElementById('orientation').value;
            const menuType = document.getElementById('menuType').value;
            const servicePeriod = document.getElementById('servicePeriod').value;
            const templateType = document.getElementById('templateType').value;
            const turnaroundDays = document.getElementById('turnaroundDays').value.trim();
            const dateNeeded = document.getElementById('dateNeeded').value;
            const assetType = document.getElementById('assetType').value;
            const menuContent = quill.getText().trim();
            const needsPrint = assetType === 'PRINT' || assetType === 'BOTH';
            const needsDigital = assetType === 'DIGITAL' || assetType === 'BOTH';
            const printRegion = document.getElementById('printRegion').value;
            const printWidth = document.getElementById('widthPrint').value.trim();
            const printHeight = document.getElementById('heightPrint').value.trim();
            const printSize = document.getElementById('printSize').value;
            const digitalWidth = document.getElementById('widthDigital').value.trim();
            const digitalHeight = document.getElementById('heightDigital').value.trim();

            if (allowDraftPrecheckConfirmLater) {
                setSubmitterFieldError('submitterName', '');
                setSubmitterFieldError('submitterEmail', '');
                setSubmitterFieldError('submitterJobTitle', '');
            } else {
                setSubmitterFieldError('submitterName', submitterName ? '' : 'Please enter your name');
                setSubmitterFieldError('submitterEmail', submitterEmail ? '' : 'Please enter your email');
                setSubmitterFieldError('submitterJobTitle', submitterJobTitle ? '' : 'Please enter your job title');
            }
            const submitterMissing = !allowDraftPrecheckConfirmLater && (!submitterName || !submitterEmail || !submitterJobTitle);

            const projectFieldsMissing = applyProjectFieldValidationErrors({ skipDateNeeded: allowDraftPrecheckConfirmLater });
            const approvalValid = allowDraftPrecheckConfirmLater ? true : applyApprovalFieldValidationErrors();

            if (submitterMissing || projectFieldsMissing || !approvalValid || !menuContent) {
                showAlert('Please fill in all required fields. Missing fields are highlighted below.', 'error');
                if (submitterMissing) {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                } else if (projectFieldsMissing || !menuContent) {
                    document.getElementById('projectDetailsCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
                } else {
                    document.getElementById('approvalsCard').scrollIntoView({ behavior: 'smooth' });
                }
                return false;
            }

            if (!allowDraftPrecheckConfirmLater && !submitterEmail.includes('@')) {
                setSubmitterFieldError('submitterEmail', 'Please enter a valid email address');
                showAlert('Please enter a valid email address', 'error');
                window.scrollTo({ top: 0, behavior: 'smooth' });
                return false;
            }
            if (!isPropertyFromCatalog(property)) {
                setPropertyFieldError('Please select a property from the list.');
                setCardError('projectDetailsCard', true);
                showAlert('Please select a property from the configured list', 'error');
                document.getElementById('projectDetailsCard').scrollIntoView({ behavior: 'smooth', block: 'start' });
                return false;
            } else {
                setPropertyFieldError('');
                syncProjectDetailsCardErrorState();
            }

            const turnaroundDaysNum = parseInt(turnaroundDays, 10);
            const minTurnaroundDays = getMinimumTurnaroundDays();
            if (!Number.isFinite(turnaroundDaysNum) || turnaroundDaysNum < minTurnaroundDays) {
                setTurnaroundFieldError(getTurnaroundMinimumMessage());
                setCardError('projectDetailsCard', true);
                showAlert(getTurnaroundMinimumMessage(), 'error');
                return false;
            }
            setTurnaroundFieldError('');
            syncProjectDetailsCardErrorState();

            if (!allowDraftPrecheckConfirmLater && dateNeeded < document.getElementById('dateNeeded').min) {
                showAlert(`Date needed cannot be earlier than ${document.getElementById('dateNeeded').min}`, 'error');
                return false;
            }

            if (needsDigital && (!digitalWidth || !digitalHeight)) {
                showAlert('Please provide digital width and height', 'error');
                return false;
            }

            if (needsPrint) {
                const folded = document.getElementById('folded').value;
                const cropMarks = document.getElementById('cropMarks').value;
                const bleedMarks = document.getElementById('bleedMarks').value;
                const fileSizeLimit = document.getElementById('fileSizeLimit').value;

                if (!folded || !printRegion || !cropMarks || !bleedMarks || !fileSizeLimit) {
                    showAlert('Please complete all required print fields', 'error');
                    return false;
                }

                if (printRegion === 'US' && (!printWidth || !printHeight)) {
                    showAlert('Please provide print width and height for US print assets', 'error');
                    return false;
                }

                if (printRegion === 'NON_US' && !printSize) {
                    showAlert('Please select an A-size for Non-US print assets', 'error');
                    return false;
                }

                if (fileSizeLimit === 'yes' && !document.getElementById('fileSizeLimitMb').value.trim()) {
                    showAlert('Please provide the max file size in MB', 'error');
                    return false;
                }
            }

            return true;
        }

        // Apply/clear the "Running AI Check" loading state on every AI-trigger
        // button — crucially including the visible #reviewWithAiBtn — so the chef
        // gets instant feedback and the check can't be double-fired.
        function setAiCheckButtonsLoading(loading) {
            ['reviewWithAiBtn', 'runCheckBtn', 'runCheckBtnBottom'].forEach(function (id) {
                const button = document.getElementById(id);
                if (!button) return;
                if (loading) {
                    if (button.dataset.idleLabel === undefined) button.dataset.idleLabel = button.innerHTML;
                    button.disabled = true;
                    button.innerHTML = '<span class="spinner"></span>Running AI Check…';
                } else {
                    button.disabled = false;
                    if (button.dataset.idleLabel !== undefined) {
                        button.innerHTML = button.dataset.idleLabel;
                        delete button.dataset.idleLabel;
                    }
                }
            });
        }

        async function runBasicCheck() {
            // Re-entrancy guard: a slow AI call must not be fired multiple times
            // by repeated clicks while it's in flight.
            if (basicCheckInProgress) return;
            if (!validateStep1({ allowDraftPrecheckConfirmLater: !!draftSessionToken })) return;
            if (submissionMode === 'modification' && !revisionBaseSubmissionId && !revisionBaselineDocPath) {
                showAlert('Choose a modification source and load a baseline DOCX first.', 'error');
                return;
            }

            // Immediate feedback on the actual visible button BEFORE any async work
            // (the baseline-freshness check and AI request both take a moment).
            basicCheckInProgress = true;
            setAiCheckButtonsLoading(true);
            try {

            if (!(await ensureBaselineFreshnessBeforeContinue())) {
                setAiCheckButtonsLoading(false);
                return;
            }

            if (!requiresAiReview()) {
                showAlert('AI review is skipped for non-beverage templates. Submitting directly.', 'success');
                await submitMenu(true);
                return;
            }

            let menuContent = '';
            if (isEditMode && document.getElementById('step2').classList.contains('hidden') === false) {
                const reviewedArea = document.getElementById('reviewedContentArea');
                menuContent = extractAiReviewTextFromReviewedArea(reviewedArea);
            } else {
                const delta = quill.getContents();
                delta.ops.forEach((op) => {
                    if (typeof op.insert === 'string') {
                        menuContent += op.insert;
                    }
                });
                menuContent = menuContent.trim();
            }
            const allergens = getAllergenInputValue();
            const menuType = document.getElementById('menuType').value;
            const reviewMode = submissionMode === 'modification' && !unapprovedMode ? 'changed_only' : 'full';
            const baselineForAiReview = submissionMode === 'modification' && !unapprovedMode ? baseApprovedMenuContent : '';
            const richHtmlForMetrics = isEditMode && document.getElementById('step2').classList.contains('hidden') === false
                ? (document.getElementById('reviewedContentArea')?.innerHTML || '')
                : (quill.root.innerHTML || '');
            const persistentDiffHtmlForMetrics = document.getElementById('persistentPreviewBody')?.innerHTML || '';
            const basicCheckPayload = attachBasicCheckDebugFlag({
                menuContent,
                allergens,
                menuType,
                baselineMenuContent: baselineForAiReview,
                reviewMode,
                ...getAttemptMetadata({
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length
                })
            });

            try {
                await logFormAttempt('basic_check_started', {
                    route: '/api/form/basic-check',
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length,
                    requestBodyLength: byteLength(JSON.stringify(basicCheckPayload)),
                    details: { reviewMode }
                });
                const data = await requestBasicCheckWithFallback(basicCheckPayload, {
                    menuContent,
                    reviewMode,
                    changedLineCount: 0
                });

                aiCheckHasRun = true;
                aiCheckCompletedCount += 1;
                setAiSuggestionsVisibility(true);
                aiCheckResults = data;
                await logFormAttempt('basic_check_client_received', {
                    route: '/api/form/basic-check',
                    statusCode: data.gatewayFallbackStatus || data.basicCheckStatus || 200,
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length,
                    correctedMenuTextLength: (data.correctedMenu || '').length,
                    requestBodyLength: byteLength(JSON.stringify(basicCheckPayload)),
                    suggestionsCount: (data.suggestions || []).length,
                    criticalSuggestionsCount: (data.suggestions || []).filter((s) => s.severity === 'critical').length,
                    criticalSuggestions: (data.suggestions || []).filter((s) => s.severity === 'critical'),
                    details: {
                        reviewMode: data.reviewMode || reviewMode,
                        changedLineCount: data.changedLineCount || 0,
                        hasChanges: !!data.hasChanges,
                        aiCheckCompletedCount,
                        aiUnavailable: !!data.aiUnavailable,
                        aiFailureReason: (data.aiFailure && data.aiFailure.reason) || null,
                        gatewayFallbackStatus: data.gatewayFallbackStatus || 0
                    }
                });
                showStep2(data);
                scheduleDraftAutosave(0);
                floatMenuToBottom(scrollAiReviewResultsIntoView);
                applyStageReveals();
                if (data.aiUnavailable) {
                    showAlert(data.reviewSkippedReason || 'AI check is temporarily unavailable. You can still submit this menu for manual review.', 'warning', {
                        persistent: true
                    });
                } else if (data.reviewMode === 'changed_only') {
                    showAlert(`AI reviewed changed content only (${data.changedLineCount || 0} changed lines).`, 'success');
                } else {
                    showAlert('AI check complete! Review the suggestions below.', 'success');
                }

            } catch (error) {
                console.error('Error:', error);
                await logFormAttempt('basic_check_client_failed', {
                    route: '/api/form/basic-check',
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length,
                    requestBodyLength: byteLength(JSON.stringify(basicCheckPayload)),
                    errorMessage: error.message
                });
                showAlert('Error running AI check: ' + error.message, 'error');
                setAiCheckButtonsLoading(false);
            }
            } finally {
                basicCheckInProgress = false;
            }
        }

