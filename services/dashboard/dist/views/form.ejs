                if (!statusEl) return;
                statusEl.textContent = msg;
                statusEl.className = 'upload-status' + (cls ? ' ' + cls : '');
            };

            if (dropzone) dropzone.classList.add('uploading');
            setStatus('Reading "' + file.name + '"…', '');

