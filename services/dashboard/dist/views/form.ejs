        function renderUploadedBaselineLineageSuggestion() {
            const container = document.getElementById('lineageSuggestion');
            const suggestion = uploadedBaselineLineageSuggestion;
            container.innerHTML = '';
            if (!suggestion?.id) {
                container.style.display = 'none';
                return;
            }
            const line = document.createElement('span');
            const approved = suggestion.approvedAt ? new Date(suggestion.approvedAt).toLocaleDateString() : 'an unknown date';
            line.textContent = `This looks like an update to ${suggestion.projectName || 'an approved menu'}, approved ${approved}. `;
            const yes = document.createElement('button');
            yes.type = 'button'; yes.className = 'btn btn-secondary'; yes.textContent = 'Yes, this replaces it';
            const no = document.createElement('button');
            no.type = 'button'; no.className = 'btn btn-secondary'; no.style.marginLeft = '0.5rem'; no.textContent = 'No, this is a separate menu';
            const state = document.createElement('span'); state.style.marginLeft = '0.5rem';
            yes.onclick = () => { revisionBaseSubmissionId = suggestion.id; uploadedBaselineLineageConfirmed = true; state.textContent = 'Will link this revision.'; };
            no.onclick = () => { revisionBaseSubmissionId = null; uploadedBaselineLineageConfirmed = false; state.textContent = 'Will not link this revision.'; };
            container.append(line, yes, no, state);
            container.style.display = '';
        }

