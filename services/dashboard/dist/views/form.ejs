        function suspendViewportScrollAnchoring() {
            const root = document.documentElement;
            if (!root || !root.style) return function () {};
            const previous = root.style.overflowAnchor;
            root.style.overflowAnchor = 'none';
            let restored = false;
            return function restoreScrollAnchoring() {
                if (restored) return;
                restored = true;
                root.style.overflowAnchor = previous;
            };
        }

        // After the AI check, FLIP-float the menu side-by-side down to the bottom
        // slot (just above submit) so the AI's changes sit where the chef is looking.
        function floatMenuToBottom(onSettled) {
            const restoreScrollAnchoring = suspendViewportScrollAnchoring();
            const settle = function () {
                if (typeof onSettled === 'function') onSettled();
                setTimeout(restoreScrollAnchoring, 250);
            };
            if (menuFloatedDown) {
                requestAnimationFrame(settle);
                return;
            }
            const menu = document.querySelector('.step2-container');
            const slot = document.getElementById('menuBottomSlot');
            if (!menu || !slot) {
                settle();
                return;
            }
            flipMove(menu, function () { slot.appendChild(menu); }, settle);
            menuFloatedDown = true;
            const block = document.getElementById('menuSplitBlock');
            if (block) block.classList.remove('revealed', 'show');
        }

        function scrollAiReviewResultsIntoView() {
            const reviewPanel = document.querySelector('.step2-container');
            if (!reviewPanel) return;
            const scroll = function () {
                reviewPanel.scrollIntoView({ behavior: 'auto', block: 'start' });
            };
            if (typeof window.requestAnimationFrame === 'function') {
                window.requestAnimationFrame(function () {
                    window.requestAnimationFrame(scroll);
                });
            } else {
                setTimeout(scroll, 0);
            }
        }

        // One-time layout setup: relocate the menu side-by-side under the upload,
        // make the (reveal-gated) bottom region present, and start reveal tracking.
        function initUploadFirstLayout() {
            const menu = document.querySelector('.step2-container');
            const block = document.getElementById('menuSplitBlock');
            if (menu && block && menu.parentElement !== block) {
                block.appendChild(menu);
            }
            // Submitter Information is revealed last — relocate its card into #submitterStage.
            const submitterCard = document.getElementById('submitterInfoCard');
            const submitterStage = document.getElementById('submitterStage');
            if (submitterCard && submitterStage && submitterCard.parentElement !== submitterStage) {
                submitterStage.appendChild(submitterCard);
            }
            const step2 = document.getElementById('step2');
            if (step2) step2.classList.remove('hidden');
            applyStageReveals();
            document.addEventListener('input', applyStageReveals);
            document.addEventListener('change', applyStageReveals);
        }

        function enterRevisionTrackingMode() {
            if (submissionMode !== 'modification') return;

            const baselineText = baseApprovedMenuContent || quill.getText().trim();
            const synthetic = {
                success: true,
                originalMenu: baselineText,
                correctedMenu: baselineText,
                suggestions: [],
                hasChanges: false,
                hasCriticalErrors: false
            };

            aiCheckHasRun = false;
            aiCheckCompletedCount = 0;
            lastAiCheckedMenuText = '';
            requiresAiRerun = false;
            aiCheckResults = synthetic;
            showStep2(synthetic);
            setAiSuggestionsVisibility(false);

            // Keep Step 1 visible so chefs can still edit metadata fields before AI check.
            document.getElementById('step1').classList.remove('hidden');
            document.getElementById('step2FormFields').classList.add('hidden');

            const step2Container = document.querySelector('.step2-container');
            if (step2Container) {
                step2Container.classList.add('revision-split');
            }

            // If we have extracted HTML (bold/italic/etc), render the accepted/current side
            // in the editor and use the synthetic original for the dynamic preview.
            if (unapprovedMode && unapprovedBaseHtml && unapprovedBaseHtml.trim()) {
                if (!unapprovedEditorHtml || !unapprovedDiffBaseline) {
                    const revisionComparison = redlinePreview.buildRevisionComparisonFromAnnotatedHtml(unapprovedBaseHtml);
                    unapprovedDiffBaseline = revisionComparison.originalText || '';
                    unapprovedOriginalHtml = revisionComparison.originalHtml || '';
                    unapprovedEditorHtml = revisionComparison.editorHtml || '';
                    baseApprovedMenuContent = revisionComparison.currentText || baseApprovedMenuContent;
                }
                unapprovedAnnotationMap = {};
                displayReviewedContent(unapprovedEditorHtml || '<p><br></p>');
                renderPersistentPreview(unapprovedDiffBaseline, baseApprovedMenuContent);
            } else if (baseApprovedMenuContentHtml && baseApprovedMenuContentHtml.trim()) {
                displayReviewedContent(baseApprovedMenuContentHtml);
                renderPersistentPreview(baseApprovedMenuContent, baseApprovedMenuContent);
            }

            if (!isEditMode) {
                toggleEditMode();
            }
            updateRevisionPreCheckLayout();
        }

        function setAiSuggestionsVisibility(visible) {
            const section = document.getElementById('aiSuggestionsSection');
            if (!section) return;
            if (visible) {
                section.classList.remove('hidden');
            } else {
                section.classList.add('hidden');
            }
            syncStep2EditorWorkboxAlignment();
        }

        function isStep2WorkboxVisible(element) {
            return !!(
                element &&
                !element.classList.contains('hidden') &&
                (element.offsetParent || element.getClientRects().length)
            );
        }

        function alignStep2EditorWorkbox() {
            const editorBox = document.querySelector('[data-step2-editor-box]');
            const rightWorkboxes = Array.from(document.querySelectorAll('[data-step2-right-workbox]'));

            rightWorkboxes.forEach((workbox) => {
                workbox.style.marginTop = '';
            });

            if (!isStep2WorkboxVisible(editorBox)) return;

            const firstVisibleRightWorkbox = rightWorkboxes.find(isStep2WorkboxVisible);
            if (!firstVisibleRightWorkbox) return;

            const editorTop = editorBox.getBoundingClientRect().top;
            const rightAlignBox = firstVisibleRightWorkbox.querySelector('[data-step2-right-align-box]') || firstVisibleRightWorkbox;
            const rightTop = rightAlignBox.getBoundingClientRect().top;
            const offset = Math.max(0, editorTop - rightTop);
            if (offset < 1) return;

            const currentMargin = parseFloat(window.getComputedStyle(firstVisibleRightWorkbox).marginTop) || 0;
            firstVisibleRightWorkbox.style.marginTop = `${Math.round(currentMargin + offset)}px`;
        }

        function syncStep2EditorWorkboxAlignment() {
            if (typeof window === 'undefined') return;
            const runAlignment = () => alignStep2EditorWorkbox();
            if (typeof window.requestAnimationFrame === 'function') {
                window.requestAnimationFrame(runAlignment);
            } else {
                setTimeout(runAlignment, 0);
            }
        }

        window.addEventListener('resize', syncStep2EditorWorkboxAlignment);

        // === Submitter Autocomplete ===
        let submitterDebounceTimer = null;
        let submitterResults = [];
        let submitterHighlightIndex = -1;

        function onSubmitterNameInput(value) {
            clearTimeout(submitterDebounceTimer);
            submitterDebounceTimer = setTimeout(() => {
                if (value.trim().length < 2) {
                    document.getElementById('submitterDropdown').classList.remove('show');
                    submitterResults = [];
                    return;
                }
                searchSubmitters(value.trim());
            }, 250);
        }

        async function searchSubmitters(query) {
            try {
                const response = await fetch(`/api/submitter-profiles/search?q=${encodeURIComponent(query)}`);
                const profiles = await response.json();
                submitterResults = profiles;
                submitterHighlightIndex = -1;
                showSubmitterDropdown(profiles, query);
            } catch (err) {
                console.error('Submitter search error:', err);
            }
        }

        function showSubmitterDropdown(profiles, query) {
            const dropdown = document.getElementById('submitterDropdown');
            if (!profiles || profiles.length === 0) {
                dropdown.classList.remove('show');
                return;
            }

            dropdown.innerHTML = profiles.map((p, i) => {
                const nameHtml = highlightMatch(p.name, query);
                const detail = [p.email, p.jobTitle].filter(Boolean).join(' · ');
                return `<div class="autocomplete-item" data-index="${i}" onmousedown="selectSubmitter(${i})">
                    <div class="ac-name">${nameHtml}</div>
                    ${detail ? `<div class="ac-detail">${escapeHtml(detail)}</div>` : ''}
                </div>`;
            }).join('');

            dropdown.classList.add('show');
        }

        function highlightMatch(text, query) {
            const raw = `${text || ''}`;
            const helper = window.formHelpers && window.formHelpers.findSearchMatchRange;
            const range = typeof helper === 'function' ? helper(raw, query) : null;
            if (!range) return escapeHtml(raw);
            return `${escapeHtml(raw.slice(0, range.start))}<span class="ac-match">${escapeHtml(raw.slice(range.start, range.end))}</span>${escapeHtml(raw.slice(range.end))}`;
        }

        function selectSubmitter(index) {
            const profile = submitterResults[index];
            if (!profile) return;

            document.getElementById('submitterName').value = profile.name;
            document.getElementById('submitterEmail').value = profile.email || '';
            document.getElementById('submitterJobTitle').value = profile.jobTitle || '';
            document.getElementById('submitterDropdown').classList.remove('show');
            submitterResults = [];
            submitterHighlightIndex = -1;
        }

        function handleSubmitterKeydown(e) {
            const dropdown = document.getElementById('submitterDropdown');
            if (!dropdown.classList.contains('show') || submitterResults.length === 0) return;

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                submitterHighlightIndex = Math.min(submitterHighlightIndex + 1, submitterResults.length - 1);
                updateSubmitterHighlight();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                submitterHighlightIndex = Math.max(submitterHighlightIndex - 1, 0);
                updateSubmitterHighlight();
            } else if (e.key === 'Enter' && submitterHighlightIndex >= 0) {
                e.preventDefault();
                selectSubmitter(submitterHighlightIndex);
            } else if (e.key === 'Escape') {
                dropdown.classList.remove('show');
                submitterHighlightIndex = -1;
            }
        }

        function updateSubmitterHighlight() {
            const items = document.querySelectorAll('#submitterDropdown .autocomplete-item');
            items.forEach((item, i) => {
                item.classList.toggle('highlighted', i === submitterHighlightIndex);
            });
            // Scroll highlighted item into view
            if (items[submitterHighlightIndex]) {
                items[submitterHighlightIndex].scrollIntoView({ block: 'nearest' });
            }
        }

        // === Recent Project Loader ===
        <% const safePropertyOptions = typeof propertyOptions === 'undefined' ? [] : propertyOptions; %>
        <% const safePropertyCatalog = typeof propertyCatalog === 'undefined' ? [] : propertyCatalog; %>
        const initialPropertyOptions = <%- JSON.stringify(safePropertyOptions) %>;
        const initialPropertyCatalog = <%- JSON.stringify(safePropertyCatalog) %>;
        const DEFAULT_SERVICE_PERIOD_OPTIONS = [
            { value: 'breakfast', label: 'Breakfast' },
            { value: 'brunch', label: 'Brunch' },
            { value: 'lunch', label: 'Lunch' },
            { value: 'dinner', label: 'Dinner' },
            { value: 'happy_hour', label: 'Happy Hour' },
            { value: 'holiday', label: 'Holiday' },
            { value: 'other', label: 'Other' }
        ];
        let recentProjectsData = [];
        let propertyCatalogData = Array.isArray(initialPropertyOptions) ? initialPropertyOptions.slice() : [];
        let propertyCatalogMeta = [];
        let propertyCatalogLookup = {};
        let suppressMenuSizeDefaults = false;
        let projectSuggestResults = [];
        let projectSuggestHighlightIndex = -1;
        let propertySuggestResults = [];
        let propertySuggestHighlightIndex = -1;

        function normalizeServiceFolderKey(value) {
            return String(value || '')
                .trim()
                .toLowerCase()
                .replace(/[_-]+/g, ' ')
                .replace(/\s*&\s*/g, ' and ')
                .replace(/\s+/g, ' ');
        }

        function rebuildPropertyCatalogState(catalog) {
            propertyCatalogMeta = Array.isArray(catalog)
                ? catalog
                    .map((item) => ({
                        name: `${item?.name || ''}`.trim(),
                        hotel: `${item?.hotel || ''}`.trim(),
                        cityCountry: `${item?.city_country || ''}`.trim(),
                        menuSizeDefaults: Array.isArray(item?.menu_size_defaults) ? item.menu_size_defaults : [],
                        sharepointServiceFolders: Array.isArray(item?.sharepoint_service_folders)
                            ? item.sharepoint_service_folders.map((folder) => `${folder || ''}`.trim()).filter(Boolean)
                            : []
                    }))
                    .filter((item) => item.name)
                : [];

            propertyCatalogData = propertyCatalogMeta.map((item) => item.name);
            propertyCatalogLookup = propertyCatalogMeta.reduce((acc, item) => {
                acc[item.name.toLowerCase()] = item;
                return acc;
            }, {});
        }

        function getPropertyCatalogEntry(propertyName) {
            const key = `${propertyName || ''}`.trim().toLowerCase();
            return key ? propertyCatalogLookup[key] || null : null;
        }

        function getServicePeriodOptionsForProperty(propertyName) {
            const config = getPropertyCatalogEntry(propertyName);
            if (config && Array.isArray(config.sharepointServiceFolders) && config.sharepointServiceFolders.length > 0) {
                const propertySpecific = config.sharepointServiceFolders.map((folder) => ({
                    value: folder,
                    label: folder
                }));
                propertySpecific.push({ value: 'other', label: 'Other' });
                return propertySpecific;
            }
            return DEFAULT_SERVICE_PERIOD_OPTIONS.slice();
        }

        function updateServicePeriodOptions(propertyName, preferredValue) {
            const servicePeriodSelect = document.getElementById('servicePeriod');
            if (!servicePeriodSelect) return;

            const options = getServicePeriodOptionsForProperty(propertyName);
            const currentValue = preferredValue !== undefined ? preferredValue : servicePeriodSelect.value;

            servicePeriodSelect.innerHTML = `
                <option value="">Select service period</option>
                ${options.map((option) => `<option value="${escapeHtml(option.value)}">${escapeHtml(option.label)}</option>`).join('')}
            `;

            if (!currentValue) {
                servicePeriodSelect.value = '';
                return;
            }

            const exactMatch = options.find((option) => option.value === currentValue);
            if (exactMatch) {
                servicePeriodSelect.value = exactMatch.value;
                return;
            }

            const caseInsensitiveMatch = options.find((option) => option.value.toLowerCase() === currentValue.toLowerCase());
            if (caseInsensitiveMatch) {
                servicePeriodSelect.value = caseInsensitiveMatch.value;
                return;
            }

            const normalizedValue = normalizeServiceFolderKey(currentValue);
            const normalizedMatch = options.find((option) => normalizeServiceFolderKey(option.value) === normalizedValue);
            servicePeriodSelect.value = normalizedMatch ? normalizedMatch.value : '';
        }

        async function loadPropertyCatalog() {
            if (!propertyCatalogMeta.length && Array.isArray(initialPropertyCatalog) && initialPropertyCatalog.length) {
                rebuildPropertyCatalogState(initialPropertyCatalog);
            } else if (!propertyCatalogData.length && Array.isArray(initialPropertyOptions)) {
                propertyCatalogData = initialPropertyOptions.slice();
            }
            try {
                const response = await fetch('/api/properties');
                const data = await response.json();
                const catalog = Array.isArray(data?.catalog) ? data.catalog : [];
                if (catalog.length) {
                    rebuildPropertyCatalogState(catalog);
                }
            } catch (err) {
                console.error('Failed to load property catalog:', err);
                if (!propertyCatalogMeta.length && !propertyCatalogData.length) {
                    propertyCatalogData = [];
                }
            }

            updateServicePeriodOptions(document.getElementById('property')?.value || '', document.getElementById('servicePeriod')?.value || '');
            applyCurrentMenuSizeDefaults();
        }

        async function loadRecentProjects() {
            try {
                const response = await fetch('/api/recent-projects?limit=20');
                const projects = await response.json();
                recentProjectsData = projects;

                if (projects.length === 0) return;

                const select = document.getElementById('recentProjectSelect');
                projects.forEach((p, i) => {
                    const opt = document.createElement('option');
                    opt.value = i;
                    opt.textContent = `${p.projectName} — ${p.property}`;
                    select.appendChild(opt);
                });

                if (submissionMode !== 'modification') {
                    document.getElementById('recentProjectLoader').style.display = 'flex';
                }
            } catch (err) {
                console.error('Failed to load recent projects:', err);
            }
        }

        function loadRecentProject(index) {
            if (index < 0 || !recentProjectsData[index]) return;
            const p = recentProjectsData[index];
            applyProjectPrefill(p);
        }

        function applyProjectPrefill(p) {
            if (!p) return;
            const toYesNo = (value, fallback = 'no') => {
                if (value === true || value === 'true' || value === 1 || value === '1' || value === 'yes') return 'yes';
                if (value === false || value === 'false' || value === 0 || value === '0' || value === 'no') return 'no';
                return fallback;
            };

            document.getElementById('projectName').value = p.projectName || '';
            document.getElementById('property').value = p.property || '';

            setSelectValue('orientation', p.orientation);
            setSelectValue('menuType', p.menuType);
            updateServicePeriodOptions(p.property || '', p.servicePeriod || '');
            baselineFreshnessOverrideKey = '';
            scheduleBaselineFreshnessCheck();
            setSelectValue('templateType', p.templateType);
            setSelectValue('assetType', p.assetType);
            if (p.turnaroundDays) {
                document.getElementById('turnaroundDays').value = p.turnaroundDays;
                setDateNeededMinimumFromTurnaround(true);
            }

            // Show the right conditional fields
            toggleAssetFields();

            // Populate dimension fields based on asset type
            if (p.assetType === 'PRINT') {
                document.getElementById('widthPrint').value = p.width || '';
                document.getElementById('heightPrint').value = p.height || '';
                setSelectValue('cropMarks', toYesNo(p.cropMarks));
                setSelectValue('bleedMarks', toYesNo(p.bleedMarks));
                setSelectValue('fileSizeLimit', toYesNo(p.fileSizeLimit));
                toggleFileSizeLimit();
                document.getElementById('fileSizeLimitMb').value = p.fileSizeLimitMb || '';
                document.getElementById('fileDeliveryNotes').value = p.fileDeliveryNotes || '';
                setSelectValue('folded', toYesNo(p.folded));
                setSelectValue('printRegion', p.printRegion || 'US');
                setSelectValue('printSize', p.printSize || '');
                togglePrintRegionFields();
            } else if (p.assetType === 'DIGITAL') {
                document.getElementById('widthDigital').value = p.width || '';
                document.getElementById('heightDigital').value = p.height || '';
            } else if (p.assetType === 'BOTH') {
                document.getElementById('widthDigital').value = p.digitalWidth || '';
                document.getElementById('heightDigital').value = p.digitalHeight || '';
                document.getElementById('widthPrint').value = p.printWidth || p.width || '';
                document.getElementById('heightPrint').value = p.printHeight || p.height || '';
                setSelectValue('cropMarks', toYesNo(p.cropMarks));
                setSelectValue('bleedMarks', toYesNo(p.bleedMarks));
                setSelectValue('fileSizeLimit', toYesNo(p.fileSizeLimit));
                document.getElementById('fileSizeLimitMb').value = p.fileSizeLimitMb || '';
                document.getElementById('fileDeliveryNotes').value = p.fileDeliveryNotes || '';
                setSelectValue('folded', toYesNo(p.folded));
                setSelectValue('printRegion', p.printRegion || 'US');
                setSelectValue('printSize', p.printSize || '');
                togglePrintRegionFields();
                toggleFileSizeLimit();
            }

            // Dispatch change event on templateType to update approval hints
            suppressMenuSizeDefaults = true;
            document.getElementById('templateType').dispatchEvent(new Event('change'));
            suppressMenuSizeDefaults = false;
        }

        function getSelectedOptionText(fieldId) {
            const select = document.getElementById(fieldId);
            if (!select || select.selectedIndex < 0) return '';
            return select.options[select.selectedIndex]?.textContent || '';
        }

        function applyCurrentMenuSizeDefaults() {
            if (suppressMenuSizeDefaults) return;
            const propertyName = document.getElementById('property')?.value || '';
            const propertyConfig = getPropertyCatalogEntry(propertyName);
            if (!propertyConfig || !Array.isArray(propertyConfig.menuSizeDefaults) || !propertyConfig.menuSizeDefaults.length) return;

            const match = window.formHelpers.findMenuSizeDefault(propertyConfig.menuSizeDefaults, {
                servicePeriod: document.getElementById('servicePeriod')?.value || '',
                serviceLabel: getSelectedOptionText('servicePeriod'),
                templateType: document.getElementById('templateType')?.value || '',
                templateLabel: getSelectedOptionText('templateType'),
            });
            if (!match) return;

            setSelectValue('assetType', 'PRINT');
            toggleAssetFields();
            document.getElementById('widthPrint').value = match.width;
            document.getElementById('heightPrint').value = match.height;
            setSelectValue('folded', match.folded);
            setSelectValue('cropMarks', match.cropMarks);
            setSelectValue('bleedMarks', match.bleedMarks);
            setSelectValue('printRegion', 'US');
            document.getElementById('printSize').value = '';
            const width = Number.parseFloat(match.width);
            const height = Number.parseFloat(match.height);
            if (Number.isFinite(width) && Number.isFinite(height)) {
                setSelectValue('orientation', width > height ? 'Landscape' : 'Portrait');
            }
            togglePrintRegionFields();
            syncProjectDetailsCardErrorState();
        }

        function onProjectNameInput(value) {
            const query = (value || '').trim();
            const normalizedQuery = window.formHelpers.normalizeSearchText(query).trim();
            const dropdown = document.getElementById('projectDropdown');
            if (normalizedQuery.length < 2) {
                dropdown.classList.remove('show');
                projectSuggestResults = [];
                projectSuggestHighlightIndex = -1;
                return;
            }

            const seen = new Set();
            projectSuggestResults = recentProjectsData
                .filter(p => window.formHelpers.searchTextIncludes(p.projectName || '', query))
                .filter(p => {
                    const key = `${window.formHelpers.normalizeSearchText(p.projectName || '')}|${window.formHelpers.normalizeSearchText(p.property || '')}`;
                    if (seen.has(key)) return false;
                    seen.add(key);
                    return true;
                })
                .slice(0, 8);
            projectSuggestHighlightIndex = -1;
            showProjectDropdown(query);
        }

        function showProjectDropdown(query) {
            const dropdown = document.getElementById('projectDropdown');
            if (!projectSuggestResults.length) {
                dropdown.classList.remove('show');
                return;
            }
            dropdown.innerHTML = projectSuggestResults.map((p, i) => `
                <div class="autocomplete-item" data-index="${i}" onmousedown="selectProjectSuggestion(${i})">
                    <div class="ac-name">${highlightMatch(p.projectName || '', query)}</div>
                    <div class="ac-detail">${escapeHtml(p.property || '')}</div>
