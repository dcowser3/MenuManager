        function focusFirstMissingSubmissionField(missingFields) {
            for (const label of missingFields) {
                const config = submissionFieldErrorMap[label];
                const target = config ? document.getElementById(config.fieldId) : null;
                if (!target) continue;
                const section = document.getElementById(config.sectionId) || target;
                section.scrollIntoView({ behavior: 'smooth', block: 'start' });
                if (typeof target.focus === 'function' && !target.readOnly && !target.disabled) {
                    setTimeout(() => target.focus({ preventScroll: true }), 250);
                }
                return;
            }
        }

        function recoverFromMissingSubmissionFields(missingFields) {
            if (!Array.isArray(missingFields) || !missingFields.length) return false;
            revealEditableFieldsForSubmitCorrection();

            missingFields.forEach((label) => {
                const config = submissionFieldErrorMap[label];
                if (!config) return;
                if (['submitterName', 'submitterEmail', 'submitterJobTitle'].includes(config.fieldId)) {
                    setSubmitterFieldError(config.fieldId, config.message);
                } else if (config.fieldId === 'property') {
                    setPropertyFieldError(config.message);
                } else {
                    setGenericFieldError(config.fieldId, config.message);
                }
                if (config.sectionId === 'projectDetailsCard' || config.sectionId === 'submitterInfoCard') {
                    setCardError(config.sectionId, true);
                }
            });
            if (typeof refreshNeedsInputHighlights === 'function') {
                refreshNeedsInputHighlights();
            }
            focusFirstMissingSubmissionField(missingFields);
            return true;
        }

