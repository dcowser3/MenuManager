        function isPropertyFromCatalog(value) {
            const normalized = (value || '').trim().toLowerCase();
            return !!normalized && propertyCatalogData.some((item) => item.toLowerCase() === normalized);
        }

        function handlePropertyKeydown(e) {
            const dropdown = document.getElementById('propertyDropdown');
            if (!dropdown.classList.contains('show') || propertySuggestResults.length === 0) return;
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                propertySuggestHighlightIndex = Math.min(propertySuggestHighlightIndex + 1, propertySuggestResults.length - 1);
                updateAutocompleteHighlight('#propertyDropdown', propertySuggestHighlightIndex);
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                propertySuggestHighlightIndex = Math.max(propertySuggestHighlightIndex - 1, 0);
                updateAutocompleteHighlight('#propertyDropdown', propertySuggestHighlightIndex);
            } else if (e.key === 'Enter' && propertySuggestHighlightIndex >= 0) {
                e.preventDefault();
                selectPropertySuggestion(propertySuggestHighlightIndex);
