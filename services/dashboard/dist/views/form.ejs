                    method: 'POST',
                    headers: getAttemptHeaders({ 'x-menumanager-revision-source': 'uploaded_unapproved' }),
                    body: form,
                });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to extract menu document');
                }

                applyUnapprovedUploadData(data, file);
                menuUploaded = true;
                enterRevisionTrackingMode();
                applyStageReveals();

                await logFormAttempt('unapproved_upload_completed', {
                    route: '/api/modification/unapproved-upload',
                    statusCode: response.status,
                    revisionSource: 'uploaded_unapproved',
                    revisionBaselineFileName,
                    menuTextLength: baseApprovedMenuContent.length,
                    menuHtmlLength: unapprovedBaseHtml.length,
                    details: { fileName: file.name, fileSize: file.size, annotationCount: unapprovedAnnotations.length }
                });
                setStatus('Loaded "' + revisionBaselineFileName + '". Existing redlines preserved — review your menu and fill in the details below.', 'success');
            } catch (error) {
                console.error(error);
                await logFormAttempt('unapproved_upload_failed', {
                    route: '/api/modification/unapproved-upload',
                    revisionSource: 'uploaded_unapproved',
                    revisionBaselineFileName: file.name,
                    errorMessage: error.message,
                    details: { fileName: file.name, fileSize: file.size }
                });
                setStatus('Could not read that file: ' + error.message, 'error');
            } finally {
                if (dropzone) dropzone.classList.remove('uploading');
            }
        }

