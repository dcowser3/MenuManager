        function isValidEmailAddress(value) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(value || '').trim());
        }

        function applyApprovalFieldValidationErrors() {
            const approval1 = document.getElementById('approval1').value;
            const approver1Name = document.getElementById('approver1Name').value.trim();
            const approver1Position = document.getElementById('approver1Position').value.trim();
            const approver1Email = document.getElementById('approver1Email').value.trim();

            setGenericFieldError('approval1', approval1 ? '' : 'Please confirm approval');
            setGenericFieldError('approver1Name', approver1Name ? '' : 'Please enter the approver name');
            setGenericFieldError('approver1Position', approver1Position ? '' : 'Please enter the approver position');
            setGenericFieldError('approver1Email', approver1Email ? '' : 'Please enter the approver email');

            if (!approval1 || !approver1Name || !approver1Position || !approver1Email) {
                setApprovalsCardError('Please complete the required approval fields');
                return false;
            }

            if (!isValidEmailAddress(approver1Email)) {
                setGenericFieldError('approver1Email', 'Please enter a valid email address');
                setApprovalsCardError('Please enter a valid approver email address');
                return false;
            }

            const approver2Email = document.getElementById('approver2Email').value.trim();
            if (approver2Email && !isValidEmailAddress(approver2Email)) {
                setGenericFieldError('approver2Email', 'Please enter a valid email address');
                setApprovalsCardError('Please enter a valid email for the additional approver');
                return false;
            }

            if (approval1 !== 'yes') {
                setGenericFieldError('approval1', 'Approval must be set to Yes before submission');
                setApprovalsCardError('Approval is required before submission');
                return false;
            }

            clearApprovalsCardError();
            return true;
        }

