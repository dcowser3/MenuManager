        });

        // ===== User problem reports ("Report this problem") =====
        // Captures a screenshot of the page plus a JSON snapshot of everything
        // filled in, and emails both to support via /api/form/error-report.
        const recentClientAlerts = [];
        const MAX_RECENT_CLIENT_ALERTS = 20;
        const SCREENSHOT_MAX_DATA_URL_CHARS = 3500000;
        // Keep report POSTs just under the route-specific server limit after
        // UTF-8 encoding and JSON escaping.
        const REPORT_MAX_BODY_BYTES = <%= errorReportMaxBodyBytes %>;
        let problemReportInFlight = false;
        let html2canvasLoaderPromise = null;

        function recordClientAlert(type, message) {
            try {
                recentClientAlerts.push({
                    time: new Date().toISOString(),
                    type: `${type || 'info'}`,
                    message: `${message || ''}`.slice(0, 1000)
                });
                if (recentClientAlerts.length > MAX_RECENT_CLIENT_ALERTS) recentClientAlerts.shift();
            } catch (error) {
                // Alert telemetry must never break the alert itself.
            }
        }

        function loadHtml2Canvas() {
            if (window.html2canvas) return Promise.resolve(window.html2canvas);
            if (!html2canvasLoaderPromise) {
                html2canvasLoaderPromise = new Promise((resolve, reject) => {
                    const script = document.createElement('script');
                    script.src = '/js/html2canvas.min.js';
                    script.onload = () => resolve(window.html2canvas);
                    script.onerror = () => {
                        html2canvasLoaderPromise = null;
                        reject(new Error('screenshot library failed to load'));
                    };
                    document.head.appendChild(script);
                });
            }
            return html2canvasLoaderPromise;
        }

        function parseScreenshotColorComponent(value) {
            const text = `${value || ''}`.trim();
            if (!text) return 0;
            if (text.endsWith('%')) return Math.round(Math.max(0, Math.min(100, parseFloat(text))) * 2.55);
            return Math.round(Math.max(0, Math.min(1, parseFloat(text))) * 255);
        }

        function parseScreenshotAlphaComponent(value) {
            const text = `${value || ''}`.trim();
            if (!text) return 1;
            if (text.endsWith('%')) return Math.max(0, Math.min(100, parseFloat(text))) / 100;
            return Math.max(0, Math.min(1, parseFloat(text)));
        }

        function fallbackCssColorForScreenshot(value) {
            const text = `${value || ''}`.trim();
            if (!/\b(color|lab|lch|oklab|oklch|color-mix)\(/i.test(text)) return null;
            const colorMatch = text.match(/^color\(\s*(?:srgb|display-p3)\s+([^\s/]+)\s+([^\s/]+)\s+([^\s/]+)(?:\s*\/\s*([^)]+))?\s*\)$/i);
            if (!colorMatch) return null;
            const red = parseScreenshotColorComponent(colorMatch[1]);
            const green = parseScreenshotColorComponent(colorMatch[2]);
            const blue = parseScreenshotColorComponent(colorMatch[3]);
            const alpha = parseScreenshotAlphaComponent(colorMatch[4]);
            return alpha < 1
                ? `rgba(${red}, ${green}, ${blue}, ${Number(alpha.toFixed(3))})`
                : `rgb(${red}, ${green}, ${blue})`;
        }

        function normalizeScreenshotCloneForHtml2Canvas(clonedDocument) {
            const colorProperties = [
                'color',
                'backgroundColor',
                'borderTopColor',
                'borderRightColor',
                'borderBottomColor',
                'borderLeftColor',
                'outlineColor',
                'textDecorationColor',
                'columnRuleColor',
                'fill',
                'stroke'
            ];
            try {
                clonedDocument.querySelectorAll('*').forEach((element) => {
                    const computed = clonedDocument.defaultView.getComputedStyle(element);
                    colorProperties.forEach((property) => {
                        const fallback = fallbackCssColorForScreenshot(computed[property]);
                        if (fallback) element.style[property] = fallback;
                    });
                });
            } catch (error) {
                // Screenshot capture should fall back gracefully if clone cleanup fails.
            }
        }

        async function capturePageScreenshot() {
            const html2canvasFn = await loadHtml2Canvas();
            const pageWidth = Math.max(document.documentElement.clientWidth || 0, document.body.scrollWidth || 0, 1);
            // Stay under mobile-Safari canvas area limits on very long pages.
            const heightCap = Math.min(document.body.scrollHeight || 4000, Math.floor(14000000 / pageWidth));
            const capture = html2canvasFn(document.body, {
                useCORS: true,
                logging: false,
                scale: 1,
                height: heightCap,
                windowWidth: document.documentElement.clientWidth,
                onclone: normalizeScreenshotCloneForHtml2Canvas
            });
            const timeout = new Promise((_, reject) =>
                setTimeout(() => reject(new Error('screenshot capture timed out')), 15000));
            const canvas = await Promise.race([capture, timeout]);
            let dataUrl = canvas.toDataURL('image/jpeg', 0.85);
            if (dataUrl.length > SCREENSHOT_MAX_DATA_URL_CHARS) dataUrl = canvas.toDataURL('image/jpeg', 0.55);
            if (dataUrl.length > SCREENSHOT_MAX_DATA_URL_CHARS) throw new Error('screenshot too large to send');
            return dataUrl;
        }

        function collectFormFieldValues() {
            const fields = {};
            document.querySelectorAll('input, select, textarea').forEach((el) => {
                if (el.type === 'password') return;
                if (el.type === 'radio') {
                    if (el.checked) fields[el.name || el.id] = el.value;
                    return;
                }
                const key = el.id || el.name;
                if (!key) return;
                if (el.type === 'file') {
                    fields[key] = Array.from(el.files || []).map((file) => `${file.name} (${file.size} bytes)`);
                } else if (el.type === 'checkbox') {
                    fields[key] = el.checked;
                } else {
                    fields[key] = el.value;
                }
            });
            return fields;
        }

