        function handleProjectKeydown(e) {
            const dropdown = document.getElementById('projectDropdown');
            if (!dropdown.classList.contains('show') || projectSuggestResults.length === 0) return;
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                projectSuggestHighlightIndex = Math.min(projectSuggestHighlightIndex + 1, projectSuggestResults.length - 1);
                updateAutocompleteHighlight('#projectDropdown', projectSuggestHighlightIndex);
