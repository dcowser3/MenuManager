<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --text: #333;
            --muted: #777;
            --border: #e8e4de;
            --bg: #fff;
            --bg-alt: #fafaf8;
            --primary: #2c2c2c;
            --success: #4a7c59;
            --danger: #8b3a3a;
            --warn: #b8860b;
            --diff-add-bg: #e6ffed;
            --diff-add-text: #22863a;
            --diff-del-bg: #ffeef0;
            --diff-del-text: #cb2431;
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Montserrat', sans-serif; color: var(--text); background: var(--bg); line-height: 1.55; }
        .header { border-bottom: 1px solid var(--border); padding: 1.75rem 4vw; }
        .header h1 { margin: 0; font-family: 'Cormorant Garamond', serif; font-size: 2rem; letter-spacing: .04em; }
        .links { margin-top: .35rem; }
        .links a { color: var(--primary); text-decoration: none; margin-right: 1rem; font-size: .75rem; text-transform: uppercase; letter-spacing: .12em; }
        .container { max-width: 1400px; margin: 0 auto; padding: 1.5rem 4vw 2.5rem; }
        .card { border: 1px solid var(--border); background: #fff; padding: 1.25rem; margin-bottom: 1rem; }
        .section-title {
            font-size: .8rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            margin: 1.5rem 0 .6rem;
        }
        .badge {
            display: inline-block;
            border: 1px solid var(--border);
            padding: .2rem .5rem;
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            background: #fff;
        }
        .badge.pending { color: var(--warn); border-color: rgba(184,134,11,.35); }
        .badge.superseded { color: var(--muted); border-color: rgba(100,116,139,.35); text-decoration: line-through; }
        .badge.approved, .badge.approved_modified { color: var(--success); border-color: rgba(74,124,89,.35); }
        .badge.rejected { color: var(--danger); border-color: rgba(139,58,58,.35); }
        .badge.no_effect { color: #b45309; border-color: rgba(180,83,9,.35); background: #fffbeb; } /* distinct amber for no_effect per Fix 4 / B1 */
        .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: .75rem; margin-bottom: 1rem; }
        .meta-item { border: 1px solid var(--border); background: var(--bg-alt); padding: .5rem .6rem; }
        .meta-label { font-size: .6rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: .15rem; }
        .meta-value { font-size: .82rem; font-weight: 500; }
        .prompt-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 1rem;
        }
        @media (max-width: 980px) { .prompt-grid { grid-template-columns: 1fr; } }
        .prompt-block { border: 1px solid var(--border); background: #fff; padding: .75rem; }
        .prompt-block h3 { margin: 0 0 .5rem; font-size: .75rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); }
        .prompt-text {
            width: 100%;
            min-height: 350px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
            font-size: .72rem;
            line-height: 1.4;
            border: 1px solid var(--border);
            padding: .6rem;
            white-space: pre-wrap;
            overflow: auto;
            background: #fcfcfb;
        }
        .diff-view {
            font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
            font-size: .72rem;
            line-height: 1.5;
            border: 1px solid var(--border);
            padding: .6rem;
            overflow: auto;
            background: #fcfcfb;
            max-height: 500px;
        }
        .diff-line { white-space: pre-wrap; }
        .diff-add { background: var(--diff-add-bg); color: var(--diff-add-text); }
        .diff-del { background: var(--diff-del-bg); color: var(--diff-del-text); }
        .diff-eq { color: var(--muted); }
        .diff-fold { color: var(--muted); text-align: center; font-size: .66rem; padding: .2rem 0; background: #f6f6f4; letter-spacing: .04em; }
        .diff-summary { margin-bottom: .5rem; }
        .diff-summary.unchanged { padding: .6rem .75rem; border: 1px solid var(--border); background: var(--bg-alt); color: var(--text); }
        .diff-add-text { color: var(--diff-add-text); font-weight: 600; }
        .diff-del-text { color: var(--diff-del-text); font-weight: 600; }
        .analysis-box {
            border: 1px solid var(--border);
            background: var(--bg-alt);
            padding: 1rem;
            font-size: .85rem;
            line-height: 1.6;
            white-space: pre-wrap;
        }
        .notes-list { margin: 0; padding-left: 1.1rem; white-space: normal; }
        .notes-list li { margin-bottom: .35rem; }
        .notes-list li:last-child { margin-bottom: 0; }
        .btn {
            border: 1px solid var(--primary);
            background: var(--primary);
            color: #fff;
            font-size: .7rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            padding: .55rem .8rem;
            cursor: pointer;
        }
        .btn.success { background: var(--success); border-color: var(--success); }
        .btn.danger { background: var(--danger); border-color: var(--danger); }
        .btn.secondary { background: #fff; color: var(--primary); }
        .btn-group { display: flex; gap: .5rem; margin-top: 1rem; }
        .review-form { margin-top: 1rem; }
        .review-form label { display: block; font-size: .65rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: .25rem; margin-top: .75rem; }
        .review-form input, .review-form textarea { width: 100%; border: 1px solid var(--border); padding: .5rem; font-family: inherit; font-size: .84rem; }
        .review-form textarea { min-height: 80px; resize: vertical; }
        .status-msg { margin-top: .75rem; font-size: .85rem; font-weight: 500; }
        .status-msg.ok { color: var(--success); }
        .status-msg.err { color: var(--danger); }
        table { width: 100%; border-collapse: collapse; border: 1px solid var(--border); background: #fff; }
        th, td { border-bottom: 1px solid var(--border); padding: .5rem .6rem; font-size: .82rem; vertical-align: top; }
        th { background: var(--bg-alt); text-align: left; font-size: .68rem; text-transform: uppercase; letter-spacing: .1em; }
        .empty { border: 1px solid var(--border); padding: 1.5rem; text-align: center; color: var(--muted); }
        .small { font-size: .72rem; color: var(--muted); }
    </style>
</head>
<body>
    <div class="header">
        <h1>Prompt Proposal Review</h1>
        <div class="links">
            <button id="runCycleBtn" class="btn secondary" onclick="runCycleNow()">Run cycle now</button>
            <a href="/learning">Learning Dashboard</a>
            <a href="/">Dashboard</a>
        </div>
    </div>
    <div id="runCycleStatus" class="status-msg" style="margin: 0 0 1rem;"></div>

    <div class="container">
        <% if (!proposal) { %>
            <div class="empty">
                No prompt proposals yet. The daily improvement cycle (<code>npm run improve:cycle</code>) generates one automatically
                when new annotated corrections exist; <code>npm run prompt:rewrite</code> remains the manual fallback.
            </div>
        <% } else { %>
            <div class="card">
                <div class="meta-grid">
                    <div class="meta-item">
                        <div class="meta-label">Cycle</div>
                        <div class="meta-value"><%= proposal.cycle_id %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Status</div>
                        <div class="meta-value"><span class="badge <%= proposal.status %>"><%= proposal.status %></span></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Source Corrections</div>
                        <div class="meta-value">
                            <% if (proposal.supersede_carried_correction_count != null && proposal.supersede_new_correction_count != null) { %>
                                <%= proposal.correction_rule_count || 0 %>
                                <span class="small" style="color:var(--muted);">(<%= proposal.supersede_carried_correction_count %> carried + <%= proposal.supersede_new_correction_count %> new)</span>
                            <% } else { %>
                                <%= proposal.correction_rule_count || 0 %>
                            <% } %>
                        </div>
                    </div>
                    <% if (proposal.superseded_from_cycle_id) { %>
                        <div class="meta-item">
                            <div class="meta-label">Supersedes</div>
                            <div class="meta-value">cycle <strong><%= proposal.superseded_from_cycle_id %></strong></div>
                        </div>
                    <% } %>
                    <div class="meta-item">
                        <div class="meta-label">Submissions</div>
                        <div class="meta-value"><%= proposal.submission_count || 0 %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Date Range</div>
                        <div class="meta-value"><%= proposal.date_range_start || '' %> to <%= proposal.date_range_end || '' %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Model</div>
                        <div class="meta-value"><%= proposal.llm_model || 'N/A' %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Source</div>
                        <div class="meta-value"><%= proposal.source === 'improvement_cycle' ? 'Improvement cycle' : (proposal.source === 'consolidation' ? 'Consolidation' : 'Prompt rewrite') %></div>
                    </div>
                    <% if (proposal.eval_status) { %>
                        <div class="meta-item">
                            <div class="meta-label">Eval</div>
                            <%
                                const evalBadgeClass = proposal.eval_status === 'passed' ? 'approved'
                                    : (proposal.eval_status === 'regressed' ? 'rejected'
                                    : (proposal.eval_status === 'no_effect' ? 'no_effect' : 'pending'));
                            %>
                            <div class="meta-value"><span class="badge <%= evalBadgeClass %>"><%= proposal.eval_status %></span></div>
                        </div>
                    <% } %>
                    <div class="meta-item">
                        <div class="meta-label">Generated</div>
                        <div class="meta-value"><%= proposal.created_at ? new Date(proposal.created_at).toLocaleString() : 'N/A' %></div>
                    </div>
                    <% if (proposal.reviewed_at) { %>
                        <div class="meta-item">
                            <div class="meta-label">Reviewed</div>
                            <div class="meta-value"><%= new Date(proposal.reviewed_at).toLocaleString() %> by <%= proposal.reviewer_name || 'Unknown' %></div>
                        </div>
                    <% } %>
                </div>
            </div>

            <%
                // C2: plain-language headline for the code-computed disposition (what the
                // proposal actually concluded). Kept in sync with describeDisposition() in core.
                const dispo = proposal.disposition || null;
                const ruleN = Array.isArray(proposal.proposed_rules) ? proposal.proposed_rules.length : 0;
                const recN = Array.isArray(proposal.code_recommendations) ? proposal.code_recommendations.length : 0;
                const dispoText = {
                    prompt_change: `Prompt change proposed${recN ? ` + ${recN} code recommendation(s)` : ''}.`,
                    rules_and_prompt: `${ruleN} replacement rule(s) + a prompt change.`,
                    rules_only: `${ruleN} replacement rule(s), no prompt change.`,
                    code_recs_only: `${recN} code recommendation(s), no prompt or rule change.`,
                    no_change_model_declined: 'No change proposed — the model concluded nothing needed to change.',
                    no_change_guard_discarded: "No change proposed — the model's rewrite was discarded by a formatting guard.",
                }[dispo] || null;
                const guardDiscarded = dispo === 'no_change_guard_discarded';
            %>
            <% if (dispoText) { %>
                <div class="card" style="<%= guardDiscarded ? 'border-color:var(--danger); background:#fff5f5;' : 'border-color:var(--border);' %>">
                    <div class="small" style="color:var(--muted); text-transform:uppercase; letter-spacing:.04em;">Disposition</div>
                    <div style="font-size:1.05rem; font-weight:600; margin-top:.15rem;"><%= dispoText %></div>
                </div>
            <% } %>

            <%
                // C3: per-correction routing table — the conclusion, first thing the reviewer sees.
                const routing = Array.isArray(proposal.correction_routing) ? proposal.correction_routing : [];
            %>
            <% if (routing.length) { %>
                <h3 class="section-title">What happened to each correction</h3>
                <div class="card">
                    <table>
                        <thead>
                            <tr><th>Correction</th><th>Replay</th><th>Lane</th><th>Target</th><th>Note</th></tr>
                        </thead>
                        <tbody>
                        <% routing.forEach((r) => { %>
                            <%
                                const laneClass = (r.lane === 'unrouted' || r.lane === 'dismissed') ? 'rejected'
                                    : (r.lane === 'already_correct' ? 'no_effect' : 'approved');
                                const stillMissedConflict = r.replay_status === 'still_missed' && (r.lane === 'dismissed' || r.lane === 'already_correct' || r.lane === 'unrouted');
                            %>
                            <tr<%= stillMissedConflict ? ' style="background:#fff5f5;"' : '' %>>
                                <td class="small">
                                    <% if (r.original_text || r.corrected_text) { %>
                                        <code><%= (r.original_text || '∅') %></code> → <code><%= (r.corrected_text || '∅') %></code>
                                    <% } else if (r.guidance) { %>
                                        <span><%= r.guidance.length > 160 ? r.guidance.slice(0, 160) + '…' : r.guidance %></span>
                                    <% } else { %>
                                        <span style="color:var(--muted);">freeform · <%= r.correction_id %></span>
                                    <% } %>
                                    <% const verifiable = r.replay_status === 'still_missed' || r.replay_status === 'now_correct'; %>
                                    <% if (r.replay_status === 'not_verifiable') { %>
                                        <span class="badge no_effect" style="margin-left:.3rem;" title="Freeform guidance with no example — cannot be replay-verified.">guidance only</span>
                                    <% } else if (verifiable) { %>
                                        <span class="badge approved" style="margin-left:.3rem;" title="Replay-verifiable against a concrete instance.">verifiable</span>
                                    <% } %>
                                </td>
                                <td class="small"><%= r.replay_status || '—' %></td>
                                <td><span class="badge <%= laneClass %>"><%= r.lane %></span></td>
                                <td class="small"><%= r.target || '' %></td>
                                <td class="small"><%= r.note || '' %></td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                    <div class="small" style="margin-top:.4rem; color:var(--muted);">One row per source correction. A still_missed correction routed dismissed/already_correct is highlighted — replay evidence outranks that routing.</div>
                </div>
            <% } %>

            <% if (proposal.llm_analysis) { %>
                <% if (guardDiscarded) { %>
                    <h3 class="section-title">LLM Analysis (describes a DISCARDED rewrite)</h3>
                    <div class="card" style="border-color:var(--danger); background:#fff5f5;">
                        <strong style="color:var(--danger)">This analysis describes a rewrite that was DISCARDED by a formatting guard and is NOT part of this proposal.</strong>
                        <details style="margin-top:.5rem">
                            <summary class="small" style="cursor:pointer;">Show the discarded analysis</summary>
                            <div class="analysis-box" style="margin-top:.4rem"><%= proposal.llm_analysis %></div>
                        </details>
                    </div>
                <% } else { %>
                    <h3 class="section-title">LLM Analysis</h3>
                    <div class="analysis-box"><%= proposal.llm_analysis %></div>
                <% } %>
            <% } %>

            <%
                // C2: computed prompt length before -> after (never model-claimed numbers).
                const lenBefore = (proposal.current_prompt || '').length;
                const lenAfter = (proposal.final_prompt || proposal.proposed_prompt || '').length;
            %>
            <% if (lenBefore || lenAfter) { %>
                <div class="small" style="margin:-.3rem 0 .6rem; color:var(--muted);">
                    Prompt length (computed): <strong><%= lenBefore.toLocaleString() %></strong> → <strong><%= lenAfter.toLocaleString() %></strong> chars
                    <% if (lenBefore && lenAfter && lenAfter !== lenBefore) { %>
                        (<%= lenAfter > lenBefore ? '+' : '' %><%= (lenAfter - lenBefore).toLocaleString() %>)
                    <% } else if (lenBefore && lenAfter === lenBefore) { %>
                        (unchanged)
                    <% } %>
                </div>
            <% } %>

            <% const covClaims = Array.isArray(proposal.coverage_claims) ? proposal.coverage_claims : []; %>
            <% if (covClaims.length) { %>
                <h3 class="section-title">Coverage Claims (validated)</h3>
                <div class="analysis-box">
                    <ul class="notes-list">
                    <% covClaims.forEach((c) => { %>
                        <li>
                            <strong>correction <%= c.correction_id %></strong>:
                            <span style="font-family: monospace; background:#fff; padding:1px 3px; border:1px solid var(--border);"><%= (c.prompt_quote || '').slice(0, 160) %><%= (c.prompt_quote || '').length > 160 ? '…' : '' %></span>
                            <% if (c.explanation) { %><div class="small" style="margin-top:.2rem; color:var(--muted);"><%= c.explanation %></div><% } %>
                        </li>
                    <% }) %>
                    </ul>
                    <div class="small" style="margin-top:.3rem; color:#854d0e;">Note: a citation alone does not resolve a still_missed correction (replay evidence takes precedence).</div>
                </div>
            <% } %>

            <% const llmWarnings = Array.isArray(proposal.llm_warnings) ? proposal.llm_warnings : []; %>
            <% if (llmWarnings.length) { %>
                <h3 class="section-title">Validation Notes</h3>
                <div class="analysis-box">
                    <ul class="notes-list">
                    <% llmWarnings.forEach((warning) => { %>
                        <li><%= warning %></li>
                    <% }) %>
                    </ul>
                </div>
            <% } %>

            <% if (proposal.unresolved_still_missed) { %>
                <div class="card" style="border-color: var(--danger); background:#fff5f5;">
                    <strong style="color:var(--danger)">Unresolved still_missed corrections</strong>
                    <div class="small" style="margin-top:.25rem">Pre-analysis replay showed that the current pipeline still reproduces one or more of the motivating mistakes, but this proposal left the prompt unchanged and did not provide a replacement rule or code recommendation that addresses them. A reviewer must either approve a covering change or explicitly note why the evidence can be deferred.</div>
                </div>
            <% } %>

            <% const evalSummary = proposal.eval_summary || null; %>
            <% if (evalSummary) { %>
                <h3 class="section-title">Eval Results (baseline vs candidate over historical menus)</h3>
                <div class="card">
                    <% if (evalSummary.error) { %>
                        <div class="status-msg err">Eval failed: <%= evalSummary.error %></div>
                    <% } else { %>
                        <div class="meta-grid">
                            <div class="meta-item">
                                <div class="meta-label">Cases Compared</div>
                                <div class="meta-value"><%= evalSummary.comparedCases || 0 %></div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Baseline Composite</div>
                                <div class="meta-value"><%= evalSummary.baseline ? (evalSummary.baseline.avgComposite * 100).toFixed(2) + '%' : 'n/a' %></div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Candidate Composite</div>
                                <div class="meta-value"><%= evalSummary.candidate ? (evalSummary.candidate.avgComposite * 100).toFixed(2) + '%' : 'n/a' %></div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Avg Delta</div>
                                <div class="meta-value"><%= ((evalSummary.avgDelta || 0) * 100).toFixed(3) %> pp</div>
                            </div>
                            <div class="meta-item">
                                <div class="meta-label">Improved / Same / Regressed</div>
                                <div class="meta-value"><%= evalSummary.improved || 0 %> / <%= evalSummary.same || 0 %> / <%= evalSummary.regressed || 0 %></div>
                            </div>
                            <% if (evalSummary.flaggedRegressed && evalSummary.flaggedRegressed > (evalSummary.regressed || 0)) { %>
                            <div class="meta-item">
                                <div class="meta-label">Regression confirmation</div>
                                <div class="meta-value"><%= evalSummary.flaggedRegressed %> flagged → <%= evalSummary.regressed || 0 %> confirmed (<%= evalSummary.noiseRegressed || 0 %> noise)</div>
                            </div>
                            <% } %>
                            <div class="meta-item">
                                <div class="meta-label">Correction F1 (candidate)</div>
                                <div class="meta-value"><%= evalSummary.candidate ? (evalSummary.candidate.correctionF1 * 100).toFixed(1) + '%' : 'n/a' %></div>
                            </div>
                        </div>
                        <% const trigs = Array.isArray(evalSummary.triggers) ? evalSummary.triggers : []; %>
                        <% const trigScorable = trigs.filter((t) => t.status && t.status !== 'unavailable'); %>
                        <% if (trigs.length && trigScorable.length === 0) { %>
                            <div class="small" style="margin:.5rem 0; color:var(--muted);">
                                Trigger progression not measurable — none of the <%= trigs.length %> motivating correction(s) had a replayable source menu to score against (freeform reviewer rules have no menu, so there is nothing to compare). The proposed rules are still safety-checked against historical menus below.
                            </div>
                        <% } else if (trigs.length) { %>
                            <div class="small" style="margin: .4rem 0 .2rem">Trigger cases (submissions whose corrections motivated this proposal — a "passed" verdict requires at least one improved). Rows that couldn't be scored are hidden:</div>
                            <table>
                                <thead><tr><th>Case / Submission</th><th>Baseline</th><th>Candidate</th><th>Delta</th><th>Status</th></tr></thead>
                                <tbody>
                                <% trigScorable.forEach((t) => { %>
                                    <tr>
                                        <td><code><%= t.case_id || t.submission_id %></code></td>
                                        <td><%= t.baseline_composite != null ? (t.baseline_composite * 100).toFixed(2) + '%' : 'n/a' %></td>
                                        <td><%= t.candidate_composite != null ? (t.candidate_composite * 100).toFixed(2) + '%' : 'n/a' %></td>
                                        <td><%= t.delta != null ? (t.delta * 100).toFixed(3) + ' pp' : '' %></td>
                                        <td><%= t.status %></td>
                                    </tr>
                                <% }) %>
                                </tbody>
                            </table>
                            <div class="small" style="margin-top:.2rem">Triggers: improved <%= evalSummary.triggers_improved || 0 %>, unchanged <%= evalSummary.triggers_unchanged || 0 %>, regressed <%= evalSummary.triggers_regressed || 0 %>, unavailable <%= evalSummary.triggers_unavailable || 0 %></div>
                        <% } %>
                        <% if ((evalSummary.regressions || []).length) { %>
                            <div class="small" style="margin-bottom:.4rem">Confirmed regressions (reproduced on a fresh-seed re-run, not nondeterminism noise):</div>
                            <table>
                                <thead><tr><th>Case</th><th>Composite Delta</th></tr></thead>
                                <tbody>
                                <% evalSummary.regressions.forEach((r) => { %>
                                    <tr><td><%= r.label %></td><td><%= (r.delta * 100).toFixed(3) %> pp</td></tr>
                                <% }) %>
                                </tbody>
                            </table>
                        <% } %>
                    <% } %>
                </div>
            <% } %>

            <% const proposedRules = Array.isArray(proposal.proposed_rules) ? proposal.proposed_rules : []; %>
            <% if (proposedRules.length) { %>
                <h3 class="section-title">Proposed Deterministic Replacement Rules</h3>
                <div class="card">
                    <div class="small" style="margin-bottom:.5rem">
                        Checked rules are saved as accepted correction rules on approval and start applying in the pre-AI deterministic pass immediately. Uncheck any you do not want.
                    </div>
                    <table>
                        <thead>
                            <tr>
                                <% if (proposal.status === 'pending') { %><th style="width:36px">Use</th><% } %>
                                <th>From</th><th>To</th><th>Type</th><th>Scope</th><th>Why</th>
                            </tr>
                        </thead>
                        <tbody>
                        <% proposedRules.forEach((rule, index) => { %>
                            <tr>
                                <% if (proposal.status === 'pending') { %>
                                    <%
                                        const isThin = (rule.evidence_submission_count || 0) <= 1;
                                        const shouldCheck = !(typeof thinRuleUncheckedDefault !== 'undefined' && thinRuleUncheckedDefault && isThin);
                                    %>
                                    <td><input type="checkbox" class="proposed-rule-checkbox" data-rule-index="<%= index %>" <%= shouldCheck ? 'checked' : '' %>></td>
                                <% } %>
                                <td><code><%= rule.original_text %></code></td>
                                <td><code><%= rule.corrected_text %></code></td>
                                <td><%= rule.change_type %></td>
                                <td><%= rule.is_location_specific ? (rule.location || 'location-specific') : 'Global' %> · <%= rule.applies_to_menu_type || 'all' %></td>
                                <td class="small"><%= rule.rule %>
                                    <% if ((rule.evidence_submission_count || 0) <= 1) { %>
                                        <span class="badge no_effect" title="Recomputed from corrections; consider whether this generalizes beyond the single menu." style="margin-left:.4rem;">single-submission evidence</span>
                                    <% } %>
                                    <% if (rule.inferred_from_guidance) { %>
                                        <span class="badge rejected" title="The model synthesized this exact swap from freeform guidance — verify the strings before trusting them." style="margin-left:.4rem;">inferred from guidance</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>

            <% const codeRecommendations = Array.isArray(proposal.code_recommendations) ? proposal.code_recommendations : []; %>
            <% if (codeRecommendations.length) { %>
                <h3 class="section-title">Code Recommendations (for an engineer — not auto-applied)</h3>
                <% codeRecommendations.forEach((rec) => { %>
                    <div class="card">
                        <strong><%= rec.title %></strong>
                        <div style="margin-top:.4rem; white-space:pre-wrap;"><%= rec.description %></div>
                        <% if (rec.target_file_hint || (rec.manifest_rule_ids || []).length) { %>
                            <div class="small" style="margin-top:.4rem">
                                <%= rec.target_file_hint ? `Likely file: ${rec.target_file_hint}` : '' %>
                                <%= (rec.manifest_rule_ids || []).length ? ` · Related manifest rules: ${rec.manifest_rule_ids.join(', ')}` : '' %>
                            </div>
                        <% } %>
                    </div>
                <% }) %>
            <% } %>

            <% const _currentFull = proposal.current_prompt || ''; %>
            <% const _proposedFull = proposal.final_prompt || proposal.proposed_prompt || ''; %>
            <% const promptChanged = _currentFull.trim() !== _proposedFull.trim(); %>
            <% if (promptChanged) { %>
                <h3 class="section-title">Prompt Changes</h3>
                <div id="promptDiffSummary" class="diff-summary small">Computing changes…</div>
                <div class="diff-view" id="diffView"></div>

                <h3 class="section-title">Full Text (current vs proposed)</h3>
                <div class="small" style="margin-bottom:.5rem">The proposed side is editable — changes here update the diff above live and are used for "Approve With Edits".</div>
                <div class="prompt-grid">
                    <div class="prompt-block">
                        <h3>Current Prompt</h3>
                        <textarea class="prompt-text" id="currentPrompt" readonly><%= _currentFull %></textarea>
                    </div>
                    <div class="prompt-block">
                        <h3>Proposed Prompt</h3>
                        <textarea class="prompt-text" id="proposedPrompt"><%= _proposedFull %></textarea>
                    </div>
                </div>
            <% } else { %>
                <h3 class="section-title">Prompt</h3>
                <div class="small" style="margin-bottom:.5rem; color:var(--muted);">
                    No prompt change in this proposal — the fixes are deterministic replacement rules (above). The QA prompt is unchanged, so there is nothing to diff.
                </div>
                <details>
                    <summary class="small" style="cursor:pointer;">View / edit the full prompt (unchanged)</summary>
                    <div class="prompt-block" style="margin-top:.5rem">
                        <textarea class="prompt-text" id="proposedPrompt"><%= _proposedFull %></textarea>
                    </div>
                </details>
            <% } %>

            <% if (proposal.status === 'pending') { %>
                <div class="card">
                    <h3 class="section-title" style="margin-top:0">Review</h3>
                    <div class="small">
                        You can edit the proposed prompt above before approving. "Approve as-is" uses the proposed prompt unchanged.
                        "Approve with edits" uses your modified version.
                    </div>
                    <div class="review-form">
                        <label for="reviewerName">Reviewer Name</label>
                        <input id="reviewerName" placeholder="Your name">
                        <label for="reviewerNotes">Notes (strongly encouraged for rejections; fed to the next cycle)</label>
                        <textarea id="reviewerNotes" placeholder="Any notes about this prompt change..."></textarea>
                    </div>
                    <div class="btn-group">
                        <button class="btn success" onclick="submitReview('approved')">Approve As-Is</button>
                        <button class="btn" onclick="submitReview('approved_modified')">Approve With Edits</button>
                        <button class="btn danger" onclick="submitReview('rejected')">Reject</button>
                    </div>
                    <div class="status-msg" id="reviewStatus"></div>
                </div>
            <% } else if (proposal.reviewer_notes) { %>
                <div class="card">
                    <h3 class="section-title" style="margin-top:0">Reviewer Notes</h3>
                    <div><%= proposal.reviewer_notes %></div>
                </div>
            <% } %>
        <% } %>

        <!-- Proposal History -->
        <h3 class="section-title">Proposal History</h3>
        <% if (!history || history.length === 0) { %>
            <div class="empty">No proposals generated yet.</div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Cycle</th>
                        <th>Status</th>
                        <th>Eval</th>
                        <th>Corrections</th>
                        <th>Submissions</th>
                        <th>Date Range</th>
                        <th>Model</th>
                        <th>Reviewed</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                <% history.forEach((p) => { %>
                    <tr>
                        <td><strong><%= p.cycle_id %></strong></td>
                        <td><span class="badge <%= p.status === 'superseded' ? 'superseded' : p.status %>"><%= p.status %></span><%
                            if (p.status === 'superseded' && p.superseded_by_cycle_id) { %>
                                <span class="small" style="color:var(--muted);"> → <%= p.superseded_by_cycle_id %></span><%
                            }
                        %></td>
                        <td><%
                            if (p.eval_status) {
                                const ec = p.eval_status === 'passed' ? 'approved' : (p.eval_status === 'regressed' ? 'rejected' : (p.eval_status === 'no_effect' ? 'no_effect' : 'pending'));
                                %><span class="badge <%= ec %>"><%= p.eval_status %></span><%
                            } else { %>—<% }
                        %></td>
                        <td><%= p.correction_rule_count || 0 %></td>
                        <td><%= p.submission_count || 0 %></td>
                        <td><%= p.date_range_start || '' %> - <%= p.date_range_end || '' %></td>
                        <td><%= p.llm_model || '' %></td>
                        <td><%= p.reviewed_at ? new Date(p.reviewed_at).toLocaleString() : '' %></td>
                        <td><%= p.created_at ? new Date(p.created_at).toLocaleString() : '' %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>

    <% if (proposal) { %>
    <script>
        // Client-side line diff of current vs proposed prompt, with context
        // folding and an explicit no-change banner. Computed from the textareas
        // so it works for every proposal regardless of any stored diff.
        (function () {
            var currentEl = document.getElementById('currentPrompt');
            var proposedEl = document.getElementById('proposedPrompt');
            var viewEl = document.getElementById('diffView');
            var summaryEl = document.getElementById('promptDiffSummary');
            if (!currentEl || !proposedEl || !viewEl || !summaryEl) return;

            function escapeHtml(s) {
                return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            }

            function lineDiff(aText, bText) {
                var a = aText.split('\n'), b = bText.split('\n');
                var n = a.length, m = b.length;
                var dp = [];
                for (var i = 0; i <= n; i++) dp.push(new Int32Array(m + 1));
                for (var i = n - 1; i >= 0; i--) {
                    for (var j = m - 1; j >= 0; j--) {
                        dp[i][j] = a[i] === b[j] ? dp[i + 1][j + 1] + 1 : Math.max(dp[i + 1][j], dp[i][j + 1]);
                    }
                }
                var out = [], i = 0, j = 0;
                while (i < n && j < m) {
                    if (a[i] === b[j]) { out.push({ t: 'eq', text: a[i] }); i++; j++; }
                    else if (dp[i + 1][j] >= dp[i][j + 1]) { out.push({ t: 'del', text: a[i] }); i++; }
                    else { out.push({ t: 'add', text: b[j] }); j++; }
                }
                while (i < n) out.push({ t: 'del', text: a[i++] });
                while (j < m) out.push({ t: 'add', text: b[j++] });
                return out;
            }

            function render() {
                var diff = lineDiff(currentEl.value, proposedEl.value);
                var adds = 0, dels = 0;
                for (var k = 0; k < diff.length; k++) {
                    if (diff[k].t === 'add') adds++;
                    else if (diff[k].t === 'del') dels++;
                }

                if (adds === 0 && dels === 0) {
                    summaryEl.className = 'diff-summary small unchanged';
                    summaryEl.innerHTML = '<strong>No changes to the base prompt.</strong> This proposal\'s improvements are in the correction rules above — the prompt text itself is identical to what is live now.';
                    viewEl.style.display = 'none';
                    return;
                }

                summaryEl.className = 'diff-summary small';
                summaryEl.innerHTML = '<span class="diff-add-text">+' + adds + ' added</span> &nbsp;·&nbsp; <span class="diff-del-text">−' + dels + ' removed</span> &nbsp;(lines; green = new wording, red = removed)';
                viewEl.style.display = '';

                var CONTEXT = 3;
                var keep = new Array(diff.length);
                for (var k = 0; k < diff.length; k++) {
                    if (diff[k].t !== 'eq') {
                        for (var c = Math.max(0, k - CONTEXT); c <= Math.min(diff.length - 1, k + CONTEXT); c++) keep[c] = true;
                    }
                }

                var rows = [], fold = 0;
                function flush() {
                    if (fold > 0) {
                        rows.push('<div class="diff-fold">⋯ ' + fold + ' unchanged line' + (fold === 1 ? '' : 's') + ' ⋯</div>');
                        fold = 0;
                    }
                }
                for (var k = 0; k < diff.length; k++) {
                    if (!keep[k]) { fold++; continue; }
                    flush();
                    var d = diff[k];
                    var cls = d.t === 'add' ? 'diff-add' : (d.t === 'del' ? 'diff-del' : 'diff-eq');
                    var prefix = d.t === 'add' ? '+ ' : (d.t === 'del' ? '- ' : '  ');
                    rows.push('<div class="diff-line ' + cls + '">' + escapeHtml(prefix + d.text) + '</div>');
                }
                flush();
                viewEl.innerHTML = rows.join('');
            }

            render();
            proposedEl.addEventListener('input', render);
        })();
    </script>
    <% } %>

    <% if (proposal && proposal.status === 'pending') { %>
    <script>
        async function submitReview(status) {
            const statusEl = document.getElementById('reviewStatus');
            const reviewerName = (document.getElementById('reviewerName').value || '').trim();
            const reviewerNotes = (document.getElementById('reviewerNotes').value || '').trim();
            const proposedText = document.getElementById('proposedPrompt').value;

            if (!reviewerName) {
                statusEl.textContent = 'Reviewer name is required.';
                statusEl.className = 'status-msg err';
                return;
            }
            if (status === 'rejected' && !reviewerNotes) {
                const ok = confirm('Notes are fed to the next cycle — rejecting without notes wastes the signal. Continue without notes?');
                if (!ok) return;
            }

            const body = {
                status,
                reviewer_name: reviewerName,
                reviewer_notes: reviewerNotes || null,
            };

            // Both approve modes send the prompt text from the textarea
            // (unchanged for "as-is", potentially edited for "with edits")
            if (status === 'approved' || status === 'approved_modified') {
                body.final_prompt = proposedText;
                body.accepted_rule_indexes = Array.from(
                    document.querySelectorAll('.proposed-rule-checkbox:checked')
                ).map((checkbox) => Number.parseInt(checkbox.dataset.ruleIndex, 10));
            }

            statusEl.textContent = 'Submitting...';
            statusEl.className = 'status-msg';

            try {
                const response = await fetch('/api/learning/prompt-proposal/<%= proposal.id %>/review', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                const result = await response.json();
                if (!response.ok) {
                    throw new Error(result.error || 'Failed to submit review');
                }
                statusEl.textContent = status.includes('approved')
                    ? 'Approved! Base prompt has been updated.'
                    : 'Rejected. No changes made to the prompt.';
                statusEl.className = 'status-msg ok';
                setTimeout(() => window.location.reload(), 1200);
            } catch (error) {
                statusEl.textContent = error.message || 'Review failed.';
                statusEl.className = 'status-msg err';
            }
        }
    </script>
    <% } %>
    <script>
        // Always available (even with no current proposal) so a reviewer can
        // generate one on demand after saving corrections, instead of waiting
        // for the overnight cron.
        async function runCycleNow() {
            const btn = document.getElementById('runCycleBtn');
            const statusEl = document.getElementById('runCycleStatus');
            if (btn) { btn.disabled = true; btn.textContent = 'Starting…'; }
            if (statusEl) { statusEl.textContent = 'Starting the improvement cycle…'; statusEl.className = 'status-msg'; }
            try {
                const response = await fetch('/api/learning/run-improvement-cycle', { method: 'POST' });
                const data = await response.json();
                if (!response.ok) throw new Error(data.error || 'Failed to start the cycle.');
                if (statusEl) { statusEl.textContent = data.message || 'Improvement cycle started.'; statusEl.className = 'status-msg ok'; }
            } catch (error) {
                if (statusEl) { statusEl.textContent = error.message || 'Failed to start the cycle.'; statusEl.className = 'status-msg err'; }
            } finally {
                if (btn) { btn.disabled = false; btn.textContent = 'Run cycle now'; }
            }
        }
    </script>
</body>
</html>
