<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --text: #333;
            --muted: #777;
            --border: #e8e4de;
            --bg: #fff;
            --bg-alt: #fafaf8;
            --primary: #2c2c2c;
            --success: #4a7c59;
            --error: #8b3a3a;
        }
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Montserrat', sans-serif; color: var(--text); background: var(--bg); }
        .header { border-bottom: 1px solid var(--border); padding: 1.75rem 4vw; }
        .header h1 { margin: 0; font-family: 'Cormorant Garamond', serif; font-size: 2rem; letter-spacing: .04em; }
        .links { margin-top: .35rem; }
        .links a { color: var(--primary); text-decoration: none; margin-right: 1rem; font-size: .75rem; text-transform: uppercase; letter-spacing: .12em; }
        .container { max-width: 1400px; margin: 0 auto; padding: 1.5rem 4vw 2.5rem; }
        .card { border: 1px solid var(--border); background: #fff; padding: 1rem; margin-bottom: 1rem; }
        .meta-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: .75rem; }
        .meta-item { border: 1px solid var(--border); background: var(--bg-alt); padding: .6rem .7rem; }
        .meta-label { font-size: .65rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: .2rem; }
        .meta-value { font-size: .85rem; font-weight: 500; }

        .dish-card { border: 1px solid var(--border); margin-bottom: 1.25rem; }
        .dish-head { background: var(--bg-alt); border-bottom: 1px solid var(--border); padding: .7rem .8rem; display: flex; align-items: center; gap: .6rem; }
        .dish-head-title { font-size: .75rem; text-transform: uppercase; letter-spacing: .1em; font-weight: 600; }
        .badge { display: inline-block; font-size: .6rem; text-transform: uppercase; letter-spacing: .08em; padding: .2rem .45rem; border-radius: 2px; font-weight: 600; }
        .badge-modified { background: #fff3e0; color: #e65100; }
        .badge-removed { background: #ffebee; color: #c62828; }
        .badge-added { background: #e8f5e9; color: #2e7d32; }
        .dish-body { padding: 1rem; }

        .diff-display { border: 1px solid var(--border); background: #fcfcfb; padding: .65rem .75rem; font-size: .88rem; line-height: 1.55; white-space: pre-wrap; margin-bottom: .85rem; font-family: 'Montserrat', sans-serif; }

        .plain-toggle { font-size: .7rem; color: var(--muted); cursor: pointer; text-decoration: underline; margin-bottom: .5rem; display: inline-block; }
        .plain-lines { display: none; margin-bottom: .85rem; }
        .plain-lines.open { display: block; }
        .plain-label { font-size: .63rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: .15rem; }
        .plain-text { border: 1px solid var(--border); background: var(--bg-alt); padding: .45rem .55rem; font-size: .8rem; line-height: 1.35; white-space: pre-wrap; margin-bottom: .4rem; }

        .annotation-section { border-top: 1px solid var(--border); padding-top: .85rem; margin-top: .85rem; }
        .annotation-group {
            border: 1px solid var(--border);
            padding: 1rem;
            margin-bottom: .75rem;
            background: var(--bg-alt);
        }
        .annotation-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: .75rem;
        }
        .annotation-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1rem;
            font-weight: 500;
            color: var(--primary);
        }
        .annotation-hint {
            font-size: .7rem;
            color: var(--muted);
            font-style: italic;
        }
        .annotation-fields {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .75rem;
            align-items: end;
        }
        .annotation-fields.three-col {
            grid-template-columns: 1fr 1fr 1fr;
        }
        .annotation-field {
            display: flex;
            flex-direction: column;
        }
        .annotation-field.full-width {
            grid-column: 1 / -1;
        }
        label { display: block; font-size: .63rem; text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: .25rem; }
        input, textarea, select { width: 100%; border: 1px solid var(--border); padding: .55rem .6rem; font-family: inherit; font-size: .84rem; }
        input:focus, textarea:focus, select:focus { outline: none; border-color: #8b7355; }
        textarea { min-height: 80px; resize: vertical; }
        select[multiple] { min-height: 100px; }

        .location-check { display: flex; align-items: center; gap: .45rem; margin-bottom: .5rem; }
        .location-check input[type="checkbox"] { width: auto; }
        .location-check label { margin: 0; font-size: .8rem; text-transform: none; letter-spacing: 0; color: var(--text); cursor: pointer; }
        .location-fields { display: none; }
        .location-fields.open { display: block; }

        @media (max-width: 640px) {
            .annotation-fields, .annotation-fields.three-col { grid-template-columns: 1fr; }
            .annotation-header { flex-direction: column; align-items: flex-start; }
        }

        .btn { border: 1px solid var(--primary); background: var(--primary); color: #fff; text-transform: uppercase; letter-spacing: .1em; font-size: .68rem; padding: .5rem .7rem; cursor: pointer; }
        .save-status { margin-left: .6rem; font-size: .78rem; color: var(--muted); }
        .save-status.ok { color: var(--success); }
        .save-status.err { color: var(--error); }

        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid var(--border); padding: .5rem .55rem; vertical-align: top; font-size: .8rem; }
        th { background: var(--bg-alt); text-align: left; font-size: .68rem; text-transform: uppercase; letter-spacing: .1em; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Submission Correction Review</h1>
        <div class="links">
            <a href="/learning">Back to Learning</a>
            <a href="/">Dashboard</a>
        </div>
    </div>

    <div class="container">
        <div class="card">
            <div class="meta-grid">
                <div class="meta-item">
                    <div class="meta-label">Submission ID</div>
                    <div class="meta-value"><code><%= submissionId %></code></div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Timestamp</div>
                    <div class="meta-value"><%= learningDetail.timestamp ? new Date(learningDetail.timestamp).toLocaleString() : 'N/A' %></div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Restaurant / Project</div>
                    <div class="meta-value"><%= submissionMeta.project_name || 'N/A' %></div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Property</div>
                    <div class="meta-value"><%= submissionMeta.property || submissionMeta.city_country || 'N/A' %></div>
                </div>
                <div class="meta-item">
                    <div class="meta-label">Dish Corrections</div>
                    <div class="meta-value"><%= learningDetail.dish_correction_count || 0 %></div>
                </div>
            </div>
        </div>

        <% const dishes = learningDetail.dish_corrections || []; %>
        <% if (dishes.length === 0) { %>
            <div class="card">No dish-level corrections were detected for this submission.</div>
        <% } else { %>
            <% dishes.forEach((dish, idx) => { %>
                <div class="dish-card">
                    <div class="dish-head">
                        <span class="dish-head-title">Dish <%= idx + 1 %></span>
                        <% if (dish.change_type === 'modified') { %>
                            <span class="badge badge-modified">Modified</span>
                        <% } else if (dish.change_type === 'removed') { %>
                            <span class="badge badge-removed">Removed</span>
                        <% } else if (dish.change_type === 'added') { %>
                            <span class="badge badge-added">Added</span>
                        <% } %>
                    </div>
                    <div class="dish-body">
                        <div class="diff-display"><%- dish.diff_html %></div>

                        <span class="plain-toggle" onclick="togglePlain(<%= idx %>)">Show original / corrected text</span>
                        <div class="plain-lines" id="plain-<%= idx %>">
                            <% if (dish.before_line) { %>
                                <div class="plain-label">Original</div>
                                <div class="plain-text"><%= dish.before_line %></div>
                            <% } %>
                            <% if (dish.after_line) { %>
                                <div class="plain-label">Corrected</div>
                                <div class="plain-text"><%= dish.after_line %></div>
                            <% } %>
                        </div>

                        <div class="annotation-section">
                            <!-- Correction Details -->
                            <div class="annotation-group">
                                <div class="annotation-header">
                                    <span class="annotation-title">Correction Details</span>
                                    <span class="annotation-hint">Write the actionable rule this correction represents</span>
                                </div>
                                <div class="annotation-fields">
                                    <div class="annotation-field full-width">
                                        <label for="rule-<%= idx %>">Rule *</label>
                                        <textarea id="rule-<%= idx %>" placeholder="e.g., Jalape&#241;o always needs the &#241; per RSH brand guide"></textarea>
                                    </div>
                                    <div class="annotation-field">
                                        <label for="change-type-<%= idx %>">Change Type</label>
                                        <select id="change-type-<%= idx %>">
                                            <option value="">Auto-detect</option>
                                            <option value="diacritic">Diacritic</option>
                                            <option value="spelling">Spelling</option>
                                            <option value="punctuation">Punctuation</option>
                                            <option value="capitalization">Capitalization</option>
                                            <option value="content">Content</option>
                                            <option value="formatting">Formatting</option>
                                        </select>
                                    </div>
                                    <div class="annotation-field">
                                        <label for="reviewer-<%= idx %>">Reviewer Name</label>
                                        <input id="reviewer-<%= idx %>" placeholder="Optional">
                                    </div>
                                </div>
                            </div>

                            <!-- Property Scope -->
                            <div class="annotation-group">
                                <div class="annotation-header">
                                    <span class="annotation-title">Property Scope</span>
                                    <span class="annotation-hint">Does this rule apply to specific properties?</span>
                                </div>
                                <div class="annotation-fields">
                                    <div class="annotation-field full-width">
                                        <div class="location-check">
                                            <input type="checkbox" id="loc-specific-<%= idx %>" onchange="toggleLocFields(<%= idx %>)">
                                            <label for="loc-specific-<%= idx %>">Location-specific rule?</label>
                                        </div>
                                    </div>
                                </div>
                                <div class="location-fields" id="loc-fields-<%= idx %>">
                                    <div class="annotation-fields">
                                        <div class="annotation-field">
                                            <label for="location-<%= idx %>">Primary Property</label>
                                            <select id="location-<%= idx %>">
                                                <option value="">Select property</option>
                                                <% (locationOptions || []).forEach((loc) => { %>
                                                    <option value="<%= loc %>" <%= loc === (submissionMeta.property || submissionMeta.city_country || '') ? 'selected' : '' %>><%= loc %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                        <div class="annotation-field">
                                            <label for="shared-<%= idx %>">Other Applicable Locations</label>
                                            <select multiple id="shared-<%= idx %>">
                                                <% (locationOptions || []).forEach((loc) => { %>
                                                    <option value="<%= loc %>"
                                                        <%= (loc === (submissionMeta.property || submissionMeta.city_country || '')) ? 'disabled' : '' %>
                                                    ><%= loc %></option>
                                                <% }) %>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div style="margin-top: .5rem;">
                                <button class="btn" onclick='saveDishRule(<%- JSON.stringify(dish) %>, <%= idx %>)'>Save Rule</button>
                                <span class="save-status" id="save-status-<%= idx %>"></span>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } %>

        <div class="card">
            <h3 style="margin-top:0; font-size:.9rem; text-transform:uppercase; letter-spacing:.1em; color:var(--muted);">Saved Rules For This Submission</h3>
            <% if (!savedCorrectionRules || savedCorrectionRules.length === 0) { %>
                <div>No saved rules yet.</div>
            <% } else { %>
                <table>
                    <thead>
                        <tr>
                            <th>Created</th>
                            <th>Original</th>
                            <th>Corrected</th>
                            <th>Rule</th>
                            <th>Restaurant</th>
                            <th>Location</th>
                            <th>Other Locations</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% savedCorrectionRules.forEach((item) => { %>
                            <tr>
                                <td><%= item.created_at ? new Date(item.created_at).toLocaleString() : 'N/A' %></td>
                                <td><%= item.original_text || '' %></td>
                                <td><%= item.corrected_text || '' %></td>
                                <td><%= item.rule || '' %></td>
                                <td><%= item.restaurant_name || '' %></td>
                                <td><%= item.location || '' %><%= item.is_location_specific ? '' : ' (global)' %></td>
                                <td><%= (item.other_applicable_locations || []).join(', ') %></td>
                                <td><%= item.change_type || '' %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>

    <script>
        function togglePlain(idx) {
            document.getElementById(`plain-${idx}`).classList.toggle('open');
        }

        function toggleLocFields(idx) {
            const checked = document.getElementById(`loc-specific-${idx}`).checked;
            document.getElementById(`loc-fields-${idx}`).classList.toggle('open', checked);
        }

        async function saveDishRule(dish, idx) {
            const statusEl = document.getElementById(`save-status-${idx}`);
            const rule = (document.getElementById(`rule-${idx}`).value || '').trim();
            const changeType = (document.getElementById(`change-type-${idx}`).value || '').trim();
            const reviewerName = (document.getElementById(`reviewer-${idx}`).value || '').trim();
            const isLocationSpecific = document.getElementById(`loc-specific-${idx}`).checked;

            let location = '';
            let otherLocations = [];
            if (isLocationSpecific) {
                location = (document.getElementById(`location-${idx}`).value || '').trim();
                const sharedSelect = document.getElementById(`shared-${idx}`);
                otherLocations = Array.from(sharedSelect.selectedOptions).map((o) => o.value);
            }

            if (!rule) {
                statusEl.textContent = 'Rule is required.';
                statusEl.className = 'save-status err';
                return;
            }

            statusEl.textContent = 'Saving...';
            statusEl.className = 'save-status';

            try {
                const response = await fetch('/api/learning/correction-rules', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        submission_id: '<%= submissionId %>',
                        correction_id: dish.correction_id,
                        original_text: dish.before_line,
                        corrected_text: dish.after_line,
                        change_type: changeType || null,
                        rule,
                        is_location_specific: isLocationSpecific,
                        project_name: '<%= (submissionMeta.project_name || "").replace(/'/g, "\\'") %>',
                        restaurant_name: '<%= (submissionMeta.project_name || submissionMeta.property || "").replace(/'/g, "\\'") %>',
                        location: location || 'All properties (global rule)',
                        other_applicable_locations: otherLocations,
                        reviewer_name: reviewerName,
                    })
                });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to save rule');
                }
                statusEl.textContent = 'Saved.';
                statusEl.className = 'save-status ok';
                setTimeout(() => window.location.reload(), 600);
            } catch (error) {
                statusEl.textContent = error.message || 'Save failed.';
                statusEl.className = 'save-status err';
            }
        }
    </script>
</body>
</html>
