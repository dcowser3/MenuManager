<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Montserrat:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --text: #333;
            --muted: #777;
            --border: #e8e4de;
            --bg: #fff;
            --bg-alt: #fafaf8;
            --primary: #2c2c2c;
            --warn: #b8860b;
            --danger: #8b3a3a;
            --success: #4a7c59;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: 'Montserrat', sans-serif;
            color: var(--text);
            background: var(--bg);
            line-height: 1.55;
        }
        .header {
            border-bottom: 1px solid var(--border);
            padding: 2rem 4vw;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .header h1 {
            margin: 0;
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            letter-spacing: .04em;
        }
        .links a {
            color: var(--primary);
            text-decoration: none;
            margin-left: 1.25rem;
            font-size: .75rem;
            letter-spacing: .14em;
            text-transform: uppercase;
            font-weight: 500;
        }
        .container {
            padding: 2rem 4vw 3rem;
            max-width: 1400px;
            margin: 0 auto;
        }
        .panel {
            border: 1px solid var(--border);
            background: var(--bg-alt);
            padding: 1rem 1.25rem;
            margin-bottom: 1rem;
        }
        .panel strong { color: var(--primary); }
        .panel.warn {
            background: #fff8f8;
            border-color: #f2cccc;
            color: #7a1f1f;
        }
        .stats {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }
        .stat {
            border: 1px solid var(--border);
            padding: .75rem 1rem;
            min-width: 170px;
            background: #fff;
        }
        .stat .label {
            font-size: .7rem;
            text-transform: uppercase;
            letter-spacing: .12em;
            color: var(--muted);
            margin-bottom: .25rem;
        }
        .stat .value {
            font-size: 1.15rem;
            font-weight: 600;
        }
        .section-title {
            font-size: .8rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            margin: 1.5rem 0 .6rem;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            border: 1px solid var(--border);
            background: #fff;
        }
        th, td {
            border-bottom: 1px solid var(--border);
            padding: .65rem .7rem;
            vertical-align: top;
            font-size: .85rem;
        }
        th {
            text-align: left;
            background: var(--bg-alt);
            font-size: .7rem;
            letter-spacing: .1em;
            text-transform: uppercase;
        }
        .badge {
            display: inline-block;
            border: 1px solid var(--border);
            padding: .2rem .5rem;
            font-size: .65rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            background: #fff;
        }
        .badge.pending { color: var(--warn); border-color: rgba(184,134,11,.35); }
        .badge.accepted { color: var(--success); border-color: rgba(74,124,89,.35); }
        .badge.rejected { color: var(--danger); border-color: rgba(139,58,58,.35); }
        .badge.active { color: var(--success); border-color: rgba(74,124,89,.35); }
        .badge.candidate { color: var(--success); border-color: rgba(74,124,89,.35); }
        .badge.weak { color: var(--warn); border-color: rgba(184,134,11,.35); }
        .badge.conflicted { color: var(--danger); border-color: rgba(139,58,58,.35); }
        .badge.system { color: #555; border-color: #ccc; }
        .badge.human { color: var(--primary); border-color: var(--border); }
        .btn {
            border: 1px solid var(--primary);
            background: var(--primary);
            color: #fff;
            font-size: .68rem;
            letter-spacing: .11em;
            text-transform: uppercase;
            padding: .45rem .65rem;
            cursor: pointer;
        }
        .btn.secondary {
            background: #fff;
            color: var(--primary);
        }
        .btn.success {
            background: var(--success);
            border-color: var(--success);
        }
        .btn.danger {
            background: var(--danger);
            border-color: var(--danger);
        }
        .btn:disabled {
            opacity: .55;
            cursor: not-allowed;
        }
        .btn-group { display: flex; gap: .35rem; }
        .small {
            font-size: .72rem;
            color: var(--muted);
        }
        .examples-row td {
            background: #fcfcfb;
            padding: 0;
        }
        .examples-panel {
            padding: .85rem 1rem 1rem;
            border-top: 1px solid var(--border);
        }
        .examples-note {
            margin-bottom: .75rem;
            color: var(--muted);
            font-size: .76rem;
        }
        .example-item {
            border: 1px solid var(--border);
            background: #fff;
            padding: .75rem;
            margin-top: .65rem;
        }
        .example-meta {
            display: flex;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
            margin-bottom: .6rem;
            font-size: .72rem;
            color: var(--muted);
        }
        .example-lines {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .65rem;
        }
        .example-label {
            font-size: .62rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            margin-bottom: .2rem;
        }
        .example-line {
            border: 1px solid var(--border);
            background: var(--bg-alt);
            padding: .55rem .6rem;
            white-space: pre-wrap;
            overflow-wrap: anywhere;
            font-size: .8rem;
        }
        @media (max-width: 760px) {
            .example-lines {
                grid-template-columns: 1fr;
            }
        }
        .submission-cell {
            min-width: 210px;
        }
        .submission-name {
            font-weight: 600;
            color: var(--primary);
            overflow-wrap: anywhere;
        }
        .submission-detail {
            margin-top: .2rem;
            overflow-wrap: anywhere;
        }
        .prompt-block {
            border: 1px solid var(--border);
            background: #fff;
            padding: .75rem;
            margin-bottom: 1rem;
        }
        .prompt-block h3 {
            margin: 0 0 .5rem;
            font-size: .8rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
        }
        .prompt-text {
            width: 100%;
            min-height: 220px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
            font-size: .73rem;
            line-height: 1.45;
            border: 1px solid var(--border);
            padding: .6rem;
            white-space: pre;
            overflow: auto;
            background: #fcfcfb;
        }
        .empty {
            border: 1px solid var(--border);
            padding: 1.5rem;
            text-align: center;
            color: var(--muted);
        }
        .filter-row {
            display: flex;
            gap: .75rem;
            align-items: center;
            margin-bottom: .75rem;
        }
        .filter-row select {
            border: 1px solid var(--border);
            background: #fff;
            padding: .5rem .6rem;
            font-size: .8rem;
            min-width: 260px;
        }
        .compact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: .65rem;
            margin-bottom: 1rem;
        }
        .rule-card {
            border: 1px solid var(--border);
            background: #fff;
            padding: .75rem .85rem;
        }
        .rule-card-title {
            font-weight: 600;
            margin-bottom: .25rem;
        }
        .rule-card-meta {
            display: flex;
            gap: .35rem;
            flex-wrap: wrap;
            margin-top: .55rem;
        }
        details.compact-details {
            border: 1px solid var(--border);
            background: #fff;
            margin-bottom: 1rem;
        }
        details.compact-details summary {
            cursor: pointer;
            padding: .75rem .9rem;
            font-size: .78rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: var(--primary);
            background: var(--bg-alt);
            border-bottom: 1px solid transparent;
        }
        details.compact-details[open] summary {
            border-bottom-color: var(--border);
        }
        .details-body {
            padding: .75rem;
        }
        .compact-table th,
        .compact-table td {
            font-size: .78rem;
            padding: .5rem .55rem;
        }
        .manual-rule-panel {
            border: 1px solid var(--border);
            background: #fff;
            padding: 1rem 1.1rem;
            margin-bottom: 1rem;
        }
        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: .75rem;
            align-items: end;
        }
        .form-grid.three {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
        .form-field {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }
        .form-field.full-width {
            grid-column: 1 / -1;
        }
        label {
            display: block;
            font-size: .63rem;
            text-transform: uppercase;
            letter-spacing: .1em;
            color: var(--muted);
            margin-bottom: .25rem;
        }
        input, textarea, select {
            width: 100%;
            border: 1px solid var(--border);
            padding: .55rem .6rem;
            font-family: inherit;
            font-size: .84rem;
            background: #fff;
            color: var(--text);
        }
        input:focus, textarea:focus, select:focus {
            outline: none;
            border-color: #8b7355;
        }
        textarea {
            min-height: 84px;
            resize: vertical;
        }
        select[multiple] {
            min-height: 96px;
        }
        .check-row {
            display: flex;
            align-items: center;
            gap: .45rem;
            min-height: 2.45rem;
        }
        .check-row input[type="checkbox"] {
            width: auto;
        }
        .check-row label {
            margin: 0;
            font-size: .8rem;
            text-transform: none;
            letter-spacing: 0;
            color: var(--text);
            cursor: pointer;
        }
        .manual-location-fields {
            display: none;
            margin-top: .75rem;
        }
        .manual-location-fields.open {
            display: block;
        }
        .form-actions {
            display: flex;
            gap: .75rem;
            align-items: center;
            margin-top: .85rem;
            flex-wrap: wrap;
        }
        .save-status {
            font-size: .78rem;
            color: var(--muted);
        }
        .save-status.ok { color: var(--success); }
        .save-status.err { color: var(--danger); }
        @media (max-width: 760px) {
            .form-grid,
            .form-grid.three {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Learning Rules</h1>
        <div class="links">
            <a href="/">Dashboard</a>
            <a href="/learning/prompt-proposal">Prompt Proposals</a>
            <a href="/training">Training</a>
            <a href="/form">Submission Form</a>
        </div>
    </div>

    <div class="container">
        <%
            const dashboardTimeZone = learningDashboardTimeZone || 'America/New_York';
            const formatDashboardTime = (value) => {
                if (!value) return 'N/A';
                try {
                    return new Intl.DateTimeFormat('en-US', {
                        timeZone: dashboardTimeZone,
                        year: 'numeric',
                        month: 'numeric',
                        day: 'numeric',
                        hour: 'numeric',
                        minute: '2-digit',
                        second: '2-digit',
                        timeZoneName: 'short',
                    }).format(new Date(value));
                } catch {
                    return new Date(value).toISOString();
                }
            };
        %>
        <% if (differStatus && (!differStatus.rulesOk || !differStatus.trainingOk)) { %>
            <div class="panel warn">
                <strong>Differ Connectivity Warning:</strong>
                Learning page could not fully reach differ service on port 3006.
                <% if (differStatus.rulesError) { %>
                    <div>Rules endpoint error: <code><%= differStatus.rulesError %></code></div>
                <% } %>
                <% if (differStatus.trainingError) { %>
                    <div>Training endpoint error: <code><%= differStatus.trainingError %></code></div>
                <% } %>
            </div>
        <% } %>

        <div class="stats">
            <div class="stat"><div class="label">Last Scan</div><div class="value"><%= formatDashboardTime(generatedAt) %></div></div>
            <div class="stat"><div class="label">Submissions Analyzed</div><div class="value"><%= totalEntries %></div></div>
            <div class="stat"><div class="label">Detected Patterns</div><div class="value"><%= totalRules %></div></div>
            <div class="stat"><div class="label">Pending Review</div><div class="value"><%= pendingRules.length %></div></div>
            <div class="stat"><div class="label">Accepted Rules</div><div class="value"><%= acceptedRules.length %></div></div>
        </div>

        <%
            const jsonForScript = (value) => JSON.stringify(value)
                .replace(/</g, '\\u003c')
                .replace(/>/g, '\\u003e')
                .replace(/&/g, '\\u0026')
                .replace(/'/g, '\\u0027')
                .replace(/\u2028/g, '\\u2028')
                .replace(/\u2029/g, '\\u2029');
            const pendingRuleExamplePayload = (pendingRules || []).map((rule) => ({
                id: rule.id,
                source: rule.source || '',
                original_text: rule.original_text || '',
                corrected_text: rule.corrected_text || '',
                submission_ids: Array.isArray(rule.submission_ids) ? rule.submission_ids : [],
            }));
            const menuScopeLabel = (value) => {
                if (value === 'food') return 'Food menus';
                if (value === 'beverage') return 'Beverage menus';
                return 'All menus';
            };
            const isManualSubmissionId = (value) => /^manual-submission-/.test(`${value || ''}`);
            const createdFromLabel = (rule) => {
                const submissionId = `${rule.submission_id || ''}`;
                const menuName = rule.project_name || rule.restaurant_name || '';
                if (submissionId.startsWith('proposal-')) {
                    return { origin: 'Prompt proposal approval', menuName: '' };
                }
                if (rule.source === 'system') {
                    return { origin: 'Detected pattern scan', menuName };
                }
                if (!submissionId || isManualSubmissionId(submissionId)) {
                    return { origin: 'General add-rule area', menuName: '' };
                }
                return { origin: 'Menu correction page', menuName: menuName || submissionId };
            };
        %>

        <!-- Manual Rule Capture -->
        <h3 class="section-title">Add Rule</h3>
        <form class="manual-rule-panel" id="manualRuleForm">
            <div class="form-grid">
                <div class="form-field full-width">
                    <label for="manual-rule-text">Rule *</label>
                    <textarea id="manual-rule-text" placeholder="e.g., Use the beverage-specific tequila spelling from the approved brand glossary"></textarea>
                </div>
                <div class="form-field">
                    <label for="manual-rule-menu-type">Menu Scope</label>
                    <select id="manual-rule-menu-type">
                        <option value="all">All menus</option>
                        <option value="food">Food menus only</option>
                        <option value="beverage">Beverage menus only</option>
                    </select>
                </div>
                <div class="form-field">
                    <label for="manual-rule-change-type">Change Type</label>
                    <select id="manual-rule-change-type">
                        <option value="content">Content</option>
                        <option value="terminology">Terminology</option>
                        <option value="diacritic">Diacritic</option>
                        <option value="spelling">Spelling</option>
                        <option value="punctuation">Punctuation</option>
                        <option value="capitalization">Capitalization</option>
                        <option value="formatting">Formatting</option>
                    </select>
                </div>
            </div>
            <div class="form-grid three" style="margin-top:.75rem;">
                <div class="form-field">
                    <label for="manual-rule-original">Original Phrase</label>
                    <input id="manual-rule-original" placeholder="Optional exact text">
                </div>
                <div class="form-field">
                    <label for="manual-rule-corrected">Corrected Phrase</label>
                    <input id="manual-rule-corrected" placeholder="Optional replacement">
                </div>
                <div class="form-field">
                    <label for="manual-rule-reviewer">Reviewer Name *</label>
                    <input id="manual-rule-reviewer" placeholder="Your name" required>
                </div>
            </div>
            <div class="form-grid two" style="margin-top:.75rem;">
                <div class="form-field">
                    <label for="manual-rule-example-original">Example — text as it appeared</label>
                    <input id="manual-rule-example-original" placeholder="Optional, for freeform rules">
                </div>
                <div class="form-field">
                    <label for="manual-rule-example-corrected">Example — corrected text</label>
                    <input id="manual-rule-example-corrected" placeholder="Optional, for freeform rules">
                </div>
            </div>
            <div class="small" style="color:var(--muted); margin-top:.25rem;">An example lets the system verify this rule actually gets applied. Skip it if you filled in the exact Original/Corrected phrases above.</div>
            <div class="check-row" style="margin-top:.75rem;">
                <input type="checkbox" id="manual-rule-location-specific">
                <label for="manual-rule-location-specific">Location-specific rule?</label>
            </div>
            <div class="manual-location-fields" id="manual-rule-location-fields">
                <div class="form-grid">
                    <div class="form-field">
                        <label for="manual-rule-location">Primary Property</label>
                        <select id="manual-rule-location">
                            <option value="">Select property</option>
                            <% (propertyOptions || []).forEach((property) => { %>
                                <option value="<%= property %>"><%= property %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-field">
                        <label for="manual-rule-shared-locations">Other Applicable Locations</label>
                        <select multiple id="manual-rule-shared-locations">
                            <% (propertyOptions || []).forEach((property) => { %>
                                <option value="<%= property %>"><%= property %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn success">Save Rule</button>
                <span class="save-status" id="manual-rule-status"></span>
            </div>
        </form>

        <!-- Pending Rules (need human review) -->
        <% if (pendingRules.length > 0) { %>
            <h3 class="section-title">Pending Rules (Awaiting Review)</h3>
            <table>
                <thead>
                    <tr>
                        <th>Original</th>
                        <th>Corrected</th>
                        <th>Rule</th>
                        <th>Menu Scope</th>
                        <th>Source</th>
                        <th>Reviewer</th>
                        <th>Project / Location</th>
                        <th>Created / From</th>
                        <th>Signals</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                <% pendingRules.forEach((rule) => { %>
                    <tr id="rule-row-<%= rule.id %>">
                        <td>
                            <strong><%= rule.original_text %></strong>
                            <% const isVerifiable = !!((rule.original_text && rule.corrected_text) || (rule.example_original && rule.example_corrected)); %>
                            <% if (!rule.original_text && !rule.corrected_text) { %>
                                <div class="small"><span class="badge <%= isVerifiable ? 'accepted' : 'pending' %>" title="<%= isVerifiable ? 'Has an example the system can replay-verify.' : 'Freeform guidance with no example — cannot be replay-verified.' %>"><%= isVerifiable ? 'verifiable' : 'guidance only' %></span></div>
                            <% } %>
                        </td>
                        <td><strong><%= rule.corrected_text %></strong></td>
                        <td><%= rule.rule || '' %></td>
                        <td><%= menuScopeLabel(rule.applies_to_menu_type) %></td>
                        <td><span class="badge <%= rule.source %>"><%= rule.source %></span></td>
                        <td><%= rule.reviewer_name || '—' %></td>
                        <td>
                            <div><%= rule.restaurant_name || '' %></div>
                            <div class="small"><%= rule.location || '' %><%= rule.is_location_specific ? '' : ' (global)' %></div>
                        </td>
                        <% const origin = createdFromLabel(rule); %>
                        <td>
                            <div><%= formatDashboardTime(rule.created_at) %></div>
                            <div class="small"><%= origin.origin %></div>
                            <% if (origin.menuName) { %>
                                <div class="small"><%= origin.menuName %></div>
                            <% } %>
                        </td>
                        <td>
                            <% if (rule.occurrences > 1) { %>
                                <div>Seen: <strong><%= rule.occurrences %>x</strong></div>
                            <% } %>
                            <% if (rule.confidence) { %>
                                <div>Confidence: <strong><%= Number(rule.confidence).toFixed(2) %></strong></div>
                            <% } %>
                        </td>
                        <td>
                            <div class="btn-group">
                                <button class="btn success" onclick="reviewRule('<%= rule.id %>', 'accepted')">Accept</button>
                                <button class="btn danger" onclick="reviewRule('<%= rule.id %>', 'rejected')">Reject</button>
                                <% if (rule.source === 'system') { %>
                                    <button class="btn secondary" type="button" onclick="toggleRuleExamples('<%= rule.id %>', this)">Examples</button>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% if (rule.source === 'system') { %>
                        <tr class="examples-row" id="rule-examples-row-<%= rule.id %>" style="display:none;">
                            <td colspan="9">
                                <div class="examples-panel" id="rule-examples-<%= rule.id %>">
                                    <div class="small">Loading examples...</div>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                <% }) %>
                </tbody>
            </table>
        <% } else { %>
            <h3 class="section-title">Pending Rules (Awaiting Review)</h3>
            <div class="empty">No actionable pending rules. System proposals need current eligible human-review evidence before they appear here.</div>
        <% } %>

        <% if (ignoredSystemPendingRules && ignoredSystemPendingRules.length > 0) { %>
            <details class="compact-details">
                <summary>Ignored stale system proposals (<%= ignoredSystemPendingRules.length %>)</summary>
                <div class="details-body">
                    <div class="small" style="margin-bottom:.6rem;">
                        These are pending system proposals from older detected-pattern data. They are not used by Basic AI Check and are hidden from the review queue because the current learning scan does not have matching eligible human-review evidence.
                    </div>
                    <table class="compact-table">
                        <thead>
                            <tr>
                                <th>Original</th>
                                <th>Corrected</th>
                                <th>Rule</th>
                                <th>Menu Scope</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                        <% ignoredSystemPendingRules.forEach((rule) => { %>
                            <tr>
                                <td><%= rule.original_text || '' %></td>
                                <td><%= rule.corrected_text || '' %></td>
                                <td><%= rule.rule || '' %></td>
                                <td><%= menuScopeLabel(rule.applies_to_menu_type) %></td>
                                <td><%= formatDashboardTime(rule.created_at) %></td>
                            </tr>
                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </details>
        <% } %>

        <!-- Accepted Correction Rules -->
        <details class="compact-details">
            <summary>Accepted Correction Rule Audit Log (<%= acceptedRules.length %>)</summary>
            <div class="details-body">
                <div class="filter-row">
                    <label for="ruleLocationFilter" class="small" style="margin:0;">Property Filter:</label>
                    <select id="ruleLocationFilter" onchange="filterAcceptedRules()">
                        <option value="">All Properties</option>
                        <% (propertyOptions || []).forEach((property) => { %>
                            <option value="<%= property %>"><%= property %></option>
                        <% }) %>
                    </select>
                </div>
                <% if (acceptedRules.length === 0) { %>
                    <div class="empty">No accepted correction rules yet. Annotate corrections from submission reviews to build the rule set.</div>
                <% } else { %>
            <table id="acceptedRulesTable">
                <thead>
                    <tr>
                        <th>Original</th>
                        <th>Corrected</th>
                        <th>Rule</th>
                        <th>Implementation</th>
                        <th>What Code Does</th>
                        <th>Menu Scope</th>
                        <th>Type</th>
                        <th>Project / Menu</th>
                        <th>Location</th>
                        <th>Source</th>
                        <th>Reviewer</th>
                        <th>Created</th>
                    </tr>
                </thead>
                <tbody>
                <% acceptedRules.forEach((rule) => { %>
                    <tr data-location="<%= (rule.location || '').toLowerCase() %>">
                        <td><%= rule.original_text || '' %></td>
                        <td><%= rule.corrected_text || '' %></td>
                        <td><%= rule.rule || '' %></td>
                        <td><span class="badge <%= rule.pre_ai_active ? 'accepted' : 'system' %>"><%= rule.implementation_status || rule.pre_ai_status || '' %></span></td>
                        <td><%= rule.implementation_detail || '' %></td>
                        <td><%= menuScopeLabel(rule.applies_to_menu_type) %></td>
                        <td><%= rule.change_type || '' %></td>
                        <td><%= rule.restaurant_name || '' %></td>
                        <td>
                            <%= rule.location || '' %><%= rule.is_location_specific ? '' : ' (global)' %>
                            <% if (rule.other_applicable_locations && rule.other_applicable_locations.length > 0) { %>
                                <div class="small">Also: <%= rule.other_applicable_locations.join(', ') %></div>
                            <% } %>
                        </td>
                        <td><span class="badge <%= rule.source %>"><%= rule.source %></span></td>
                        <td><%= rule.reviewer_name || '—' %></td>
                        <td><%= formatDashboardTime(rule.created_at) %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
                <% } %>
            </div>
        </details>

        <!-- Detected Patterns (read-only reference from differ) -->
        <h3 class="section-title">Detected Patterns (Auto-Scanned)</h3>
        <div class="small" style="margin-bottom:.5rem;">
            Patterns detected by the differ service from before/after document comparisons. These are <strong>not</strong> injected into the prompt and are <strong>not</strong> applied by Pre-AI checks unless a reviewer accepts a safe exact rule above. Use them as reference when annotating corrections.
        </div>
        <% if (!detectedPatterns || detectedPatterns.length === 0) { %>
            <div class="empty">No patterns detected yet. Once corrected documents are processed, patterns will appear here.</div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Pattern</th>
                        <th>Type</th>
                        <th>Evidence Status</th>
                        <th>Implementation</th>
                        <th>What Code Does</th>
                        <th>Signals</th>
                        <th>Last Seen</th>
                    </tr>
                </thead>
                <tbody>
                <% detectedPatterns.forEach((pattern) => { %>
                    <tr>
                        <td>
                            <strong><%= pattern.source %></strong> -> <strong><%= pattern.target %></strong>
                        </td>
                        <td><%= pattern.kind %></td>
                        <td><span class="badge <%= pattern.category === 'active' ? 'candidate' : pattern.category %>"><%= pattern.status_label || (pattern.category === 'active' ? 'Candidate' : pattern.category === 'weak' ? 'Below threshold' : pattern.category === 'conflicted' ? 'Conflicted' : pattern.category) %></span></td>
                        <td><span class="badge <%= pattern.implementation_status === 'Active exact replacement' || pattern.implementation_status === 'Active code guard' || pattern.implementation_status === 'Covered by built-in Pre-AI' ? 'accepted' : 'system' %>"><%= pattern.implementation_status || 'No implementation yet' %></span></td>
                        <td><%= pattern.implementation_detail || '' %></td>
                        <td>
                            <div>Occurrences: <strong><%= pattern.occurrences %></strong></div>
                            <div>Submissions: <strong><%= pattern.submission_count %></strong></div>
                            <div>Confidence: <strong><%= Number(pattern.confidence || 0).toFixed(2) %></strong></div>
                        </td>
                        <td><%= formatDashboardTime(pattern.last_seen_at) %></td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        <% } %>

        <!-- Recent Learned Submissions -->
        <h3 class="section-title">Recent Learned Submissions</h3>
        <% const displayedLearnedSubmissions = (learningSubmissions && learningSubmissions.length ? learningSubmissions : recentSubmissions) || []; %>
        <% if (displayedLearnedSubmissions.length === 0) { %>
            <div class="empty">No training submissions recorded yet.</div>
        <% } else { %>
            <table>
                <thead>
                    <tr>
                        <th>Submission</th>
                        <th>Timestamp</th>
                        <th>Changes</th>
                        <th>Change %</th>
                        <th>Signals</th>
                        <th>AI Draft</th>
                        <th>Final</th>
                        <th>Review</th>
                    </tr>
                </thead>
                <tbody>
                <% displayedLearnedSubmissions.forEach((item) => { %>
                    <tr id="learning-submission-<%= item.submission_id %>">
                        <td class="submission-cell">
                            <div class="submission-name"><%= item.submission_display_name || item.submission_id || 'Unknown menu' %></div>
                            <% if (item.submission_display_detail) { %>
                                <div class="small submission-detail"><%= item.submission_display_detail %></div>
                            <% } %>
                        </td>
                        <td><%= formatDashboardTime(item.timestamp) %></td>
                        <td><%= item.changes_detected ? 'YES' : 'NO' %></td>
                        <td><%= Number(item.change_percentage || 0).toFixed(2) %></td>
                        <td><%= item.replacement_count || item.learning_signals?.replacement_count || 0 %></td>
                        <td><code><%= (item.ai_draft_path || '').split('/').pop() || 'N/A' %></code></td>
                        <td><code><%= (item.final_path || '').split('/').pop() || 'N/A' %></code></td>
                        <td>
                            <div class="btn-group">
                                <a href="/learning/submission/<%= item.submission_id %>">Open</a>
                                <button class="btn danger" type="button" onclick="deleteLearningSubmission('<%= item.submission_id %>', this)">Delete</button>
                            </div>
                        </td>
                    </tr>
                <% }) %>
                </tbody>
            </table>
        <% } %>
    </div>

    <script>
        const ruleExamplesPayload = <%- jsonForScript(pendingRuleExamplePayload) %>;
        const ruleExamplesById = new Map(ruleExamplesPayload.map((rule) => [String(rule.id), rule]));
        const loadedRuleExamples = new Set();

        function escapeHtml(value) {
            return String(value || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function basename(value) {
            return String(value || '').split(/[\\/]/).pop() || 'N/A';
        }

        async function toggleRuleExamples(ruleId, button) {
            const row = document.getElementById(`rule-examples-row-${ruleId}`);
            const container = document.getElementById(`rule-examples-${ruleId}`);
            const rule = ruleExamplesById.get(String(ruleId));
            if (!row || !container || !rule) return;

            const opening = row.style.display === 'none';
            row.style.display = opening ? '' : 'none';
            if (!opening || loadedRuleExamples.has(String(ruleId))) return;

            const originalText = button ? button.textContent : '';
            if (button) {
                button.disabled = true;
                button.textContent = 'Loading';
            }

            try {
                const params = new URLSearchParams({
                    original_text: rule.original_text || '',
                    corrected_text: rule.corrected_text || '',
                    submission_ids: (rule.submission_ids || []).join(','),
                    limit: '8',
                });
                const response = await fetch(`/api/learning/rule-examples?${params.toString()}`);
                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    throw new Error(payload.error || 'Failed to load examples');
                }
                renderRuleExamples(container, rule, payload);
                loadedRuleExamples.add(String(ruleId));
            } catch (error) {
                container.innerHTML = `<div class="examples-note">${escapeHtml(error.message || 'Failed to load examples')}</div>`;
            } finally {
                if (button) {
                    button.disabled = false;
                    button.textContent = originalText || 'Examples';
                }
            }
        }

        function renderRuleExamples(container, rule, payload) {
            const examples = Array.isArray(payload.examples) ? payload.examples : [];
            const errors = Array.isArray(payload.errors) ? payload.errors : [];
            const intro = [
                'Evidence source: differ compared the stored AI draft DOCX with an eligible human-reviewed final approval DOCX.',
                'Use these snippets to confirm the proposal came from the post-AI human approval path before accepting it globally.',
            ].join(' ');

            if (examples.length === 0) {
                const errorText = errors.length ? ` ${errors.length} submission(s) could not be read.` : '';
                container.innerHTML = `<div class="examples-note">${escapeHtml(intro)}</div><div class="empty">No matching examples were reconstructed.${escapeHtml(errorText)}</div>`;
                return;
            }

            const exampleHtml = examples.map((example) => {
                const submissionName = example.submission_display_name || example.submission_id || 'Unknown submission';
                const submissionDetail = example.submission_display_detail ? `<div>${escapeHtml(example.submission_display_detail)}</div>` : '';
                const tokenChanges = (example.token_changes || [])
                    .map((change) => `${change.from || ''} -> ${change.to || ''}`)
                    .join(', ');
                const changesFlag = example.submission_changes_made === true
                    ? 'changes_made: true'
                    : example.submission_changes_made === false
                        ? 'changes_made: false'
                        : 'changes_made: unknown';
                return `
                    <div class="example-item">
                        <div class="example-meta">
                            <div>
                                <a href="/learning/submission/${encodeURIComponent(example.submission_id || '')}">${escapeHtml(submissionName)}</a>
                                ${submissionDetail}
                            </div>
                            <div>
                                <div>${example.timestamp ? escapeHtml(new Date(example.timestamp).toLocaleString()) : 'N/A'}</div>
                                <div>Status: <code>${escapeHtml(example.submission_status || 'unknown')}</code>; <code>${escapeHtml(changesFlag)}</code></div>
                                <div>AI draft: <code>${escapeHtml(basename(example.ai_draft_path))}</code></div>
                                <div>Final approved: <code>${escapeHtml(basename(example.final_path))}</code></div>
                            </div>
                        </div>
                        ${tokenChanges ? `<div class="small" style="margin-bottom:.45rem;">Token change: ${escapeHtml(tokenChanges)}</div>` : ''}
                        <div class="example-lines">
                            <div>
                                <div class="example-label">AI Draft Line</div>
                                <div class="example-line">${escapeHtml(example.before_line)}</div>
                            </div>
                            <div>
                                <div class="example-label">Final Approved Line</div>
                                <div class="example-line">${escapeHtml(example.after_line)}</div>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');

            const errorNote = errors.length
                ? `<div class="examples-note">${escapeHtml(errors.length)} referenced submission(s) could not be read.</div>`
                : '';
            container.innerHTML = `<div class="examples-note">${escapeHtml(intro)}</div>${errorNote}${exampleHtml}`;
        }

        function setManualRuleStatus(message, kind) {
            const statusEl = document.getElementById('manual-rule-status');
            if (!statusEl) return;
            statusEl.textContent = message || '';
            statusEl.className = `save-status ${kind || ''}`.trim();
        }

        function updateManualLocationFields() {
            const isLocationSpecific = document.getElementById('manual-rule-location-specific')?.checked;
            document.getElementById('manual-rule-location-fields')?.classList.toggle('open', !!isLocationSpecific);
        }

        function updateManualSharedLocationOptions() {
            const primary = document.getElementById('manual-rule-location')?.value || '';
            const shared = document.getElementById('manual-rule-shared-locations');
            if (!shared) return;
            Array.from(shared.options).forEach((option) => {
                option.disabled = !!primary && option.value === primary;
                if (option.disabled) {
                    option.selected = false;
                }
            });
        }

        async function saveManualRule(event) {
            event.preventDefault();

            const form = document.getElementById('manualRuleForm');
            const submitButton = form?.querySelector('button[type="submit"]');
            const rule = (document.getElementById('manual-rule-text')?.value || '').trim();
            const originalText = (document.getElementById('manual-rule-original')?.value || '').trim();
            const correctedText = (document.getElementById('manual-rule-corrected')?.value || '').trim();
            const isLocationSpecific = !!document.getElementById('manual-rule-location-specific')?.checked;
            const location = (document.getElementById('manual-rule-location')?.value || '').trim();
            const sharedSelect = document.getElementById('manual-rule-shared-locations');
            const otherLocations = sharedSelect
                ? Array.from(sharedSelect.selectedOptions).map((option) => option.value)
                : [];
            const reviewerName = (document.getElementById('manual-rule-reviewer')?.value || '').trim();
            const exampleOriginal = (document.getElementById('manual-rule-example-original')?.value || '').trim();
            const exampleCorrected = (document.getElementById('manual-rule-example-corrected')?.value || '').trim();

            if (!rule) {
                setManualRuleStatus('Rule is required.', 'err');
                return;
            }
            if (!reviewerName) {
                setManualRuleStatus('Reviewer name is required.', 'err');
                return;
            }
            if ((originalText && !correctedText) || (!originalText && correctedText)) {
                setManualRuleStatus('Original and corrected phrases must be provided together.', 'err');
                return;
            }
            if ((exampleOriginal && !exampleCorrected) || (!exampleOriginal && exampleCorrected)) {
                setManualRuleStatus('Example fields must be provided together.', 'err');
                return;
            }
            if (isLocationSpecific && !location) {
                setManualRuleStatus('Primary property is required for location-specific rules.', 'err');
                return;
            }

            if (submitButton) submitButton.disabled = true;
            setManualRuleStatus('Saving...', '');

            try {
                const response = await fetch('/api/learning/correction-rules', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        rule,
                        original_text: originalText || null,
                        corrected_text: correctedText || null,
                        change_type: document.getElementById('manual-rule-change-type')?.value || 'content',
                        applies_to_menu_type: document.getElementById('manual-rule-menu-type')?.value || 'all',
                        is_location_specific: isLocationSpecific,
                        location,
                        other_applicable_locations: otherLocations,
                        reviewer_name: reviewerName,
                        source: 'human',
                        example_original: exampleOriginal || null,
                        example_corrected: exampleCorrected || null,
                    }),
                });
                const result = await response.json().catch(() => ({}));
                if (!response.ok) {
                    throw new Error(result.error || 'Failed to save rule');
                }
                setManualRuleStatus('Saved.', 'ok');
                setTimeout(() => window.location.reload(), 600);
            } catch (error) {
                setManualRuleStatus(error.message || 'Save failed.', 'err');
                if (submitButton) submitButton.disabled = false;
            }
        }

        async function reviewRule(ruleId, newStatus) {
            try {
                const response = await fetch(`/api/learning/correction-rules/${ruleId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus }),
                });
                const result = await response.json();
                if (!response.ok) {
                    alert(result.error || 'Failed to update rule');
                    return;
                }
                window.location.reload();
            } catch (error) {
                alert('Failed to update rule');
            }
        }

        async function deleteLearningSubmission(submissionId, button) {
            if (!window.confirm(`Delete learned submission ${submissionId}? This removes its training row and comparison detail from the learning dashboard.`)) {
                return;
            }

            const originalText = button.textContent;
            button.disabled = true;
            button.textContent = 'Deleting';

            try {
                const response = await fetch(`/api/learning/submissions/${encodeURIComponent(submissionId)}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' },
                });
                const payload = await response.json().catch(() => ({}));
                if (!response.ok) {
                    throw new Error(payload.error || 'Failed to delete learned submission');
                }

                const row = document.getElementById(`learning-submission-${submissionId}`);
                const tbody = row?.closest('tbody');
                if (row) row.remove();
                if (tbody && tbody.children.length === 0) {
                    window.location.reload();
                }
            } catch (error) {
                alert(error.message || 'Failed to delete learned submission');
                button.disabled = false;
                button.textContent = originalText;
            }
        }

        function filterAcceptedRules() {
            const select = document.getElementById('ruleLocationFilter');
            const selected = (select?.value || '').trim().toLowerCase();
            const rows = document.querySelectorAll('#acceptedRulesTable tbody tr');
            rows.forEach((row) => {
                const rowLocation = (row.getAttribute('data-location') || '').trim().toLowerCase();
                row.style.display = !selected || rowLocation === selected ? '' : 'none';
            });
        }

        document.getElementById('manualRuleForm')?.addEventListener('submit', saveManualRule);
        document.getElementById('manual-rule-location-specific')?.addEventListener('change', updateManualLocationFields);
        document.getElementById('manual-rule-location')?.addEventListener('change', updateManualSharedLocationOptions);
        updateManualLocationFields();
        updateManualSharedLocationOptions();
    </script>
</body>
</html>
