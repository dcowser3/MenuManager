            if (printRegion === 'NON_US') {
                printSizeGroup.classList.remove('hidden');
                printWidthGroup.classList.add('hidden');
                printHeightGroup.classList.add('hidden');
                widthInput.value = '';
                heightInput.value = '';
                widthInput.disabled = true;
                heightInput.disabled = true;
            } else {
                printSizeGroup.classList.add('hidden');
                printWidthGroup.classList.remove('hidden');
                printHeightGroup.classList.remove('hidden');
                widthInput.disabled = false;
                heightInput.disabled = false;
                if (printRegion === 'US') {
                    sizeSelect.value = '';
