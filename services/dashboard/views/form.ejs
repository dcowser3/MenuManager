        async function logFormAttempt(eventType, extra) {
            const payload = getAttemptMetadata({ eventType, ...(extra || {}) });
            const body = JSON.stringify(payload);
            try {
                if (navigator.sendBeacon) {
                    const blob = new Blob([body], { type: 'application/json' });
                    if (navigator.sendBeacon('/api/form/attempt-log', blob)) return;
                }
                await fetch('/api/form/attempt-log', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', ...getAttemptHeaders() },
                    body,
                    keepalive: true
                });
            } catch (error) {
                console.warn('Failed to log form attempt event:', error);
            }
        }

	        function isLikelyAllergenLegendLine(line) {
	            const normalized = (line || '').trim();
	            if (!normalized || !normalized.includes('|')) return false;
	            const parts = normalized.split('|').map((p) => p.trim()).filter(Boolean);
	            if (parts.length < 3) return false;
	            const codeParts = parts.filter((p) => /^[*]?[A-Z]{1,3}\s+.+/.test(p));
	            return codeParts.length >= Math.max(2, Math.floor(parts.length * 0.6));
	        }

	        function normalizeInlineText(value) {
	            return (value || '').replace(/\s+/g, ' ').trim();
	        }

	        function parseParenthesizedAllergenLegend(line) {
	            const normalized = normalizeInlineText(line);
	            if (!normalized || !normalized.includes('(') || !normalized.includes(')')) return '';
	            const footerBody = normalized.split(/\b(?:ALL\s+PRICES|WE\s+WELCOME|CONSUMPTION\s+OF\s+RAW|CONSUMING\s+RAW|FOODBORNE\s+ILLNESS)\b/i)[0];
	            const pattern = /\(\s*([A-Za-z]{1,3})\s*\)\s*([A-Za-z][A-Za-z\s/&-]*?)(?=\s*\(\s*[A-Za-z]{1,3}\s*\)|$)/g;
	            const pairs = [];
	            let match;
	            while ((match = pattern.exec(footerBody)) !== null) {
	                const code = match[1].toUpperCase();
	                const label = normalizeInlineText(match[2]).toLowerCase();
	                if (label) pairs.push({ code, label });
	            }
	            if (pairs.length < 4) return '';
	            const keywordHits = pairs.filter(({ label }) => /(allergen|gluten|dairy|fish|nuts?|egg|vegan|vegetarian|crustacean|soy|sesame|celery|mustard|shellfish|sulphites?|lupin)/i.test(label)).length;
	            if (keywordHits < 2) return '';
	            return pairs.map(({ code, label }) => `${code} ${label}`).join(' | ');
	        }

	        function isLikelyRawNoticeLine(line) {
	            const normalized = normalizeInlineText(line).toLowerCase();
	            return normalized.includes('raw or undercooked') && normalized.includes('foodborne illness');
	        }

	        function isLikelyAllergenLegendHeader(line) {
	            return /^allergen\s+key(?:\s+\(optional\))?$/i.test(normalizeInlineText(line));
	        }

	        function extractAllergenLegendLine(line) {
	            if (isLikelyAllergenLegendLine(line)) return normalizeInlineText(line);
	            return parseParenthesizedAllergenLegend(line);
	        }

            function isManagedFooterText(line) {
                const normalized = normalizeInlineText(line);
                const allergenLine = extractAllergenLegendLine(normalized);
                return !!(
                    allergenLine ||
                    isLikelyAllergenLegendHeader(normalized) ||
                    /^all\s+prices\b/i.test(normalized) ||
                    /^we\s+welcome\s+enquiries\b/i.test(normalized) ||
                    isLikelyRawNoticeLine(normalized)
                );
            }

            function stripManagedFooterHtml(htmlContent) {
                if (!htmlContent) return htmlContent;
                const container = document.createElement('div');
                container.innerHTML = htmlContent;
                container.querySelectorAll('p').forEach((paragraph) => {
                    if (isManagedFooterText(paragraph.textContent || '')) {
                        paragraph.remove();
                    }
                });
                return container.innerHTML;
            }

	        function stripBaselineFooter(menuText, fallbackAllergens = '') {
	            const lines = (menuText || '').split('\n').map((l) => l.trim());
	            const menuLines = [];
	            let allergenLines = [];
	            let hadRawNotice = false;
	            const preservedFooterLines = [];
	            let inFooter = false;

	            for (const line of lines) {
	                const allergenLine = extractAllergenLegendLine(line);
	                const isHeader = isLikelyAllergenLegendHeader(line);
	                const isRawNotice = isLikelyRawNoticeLine(line);
	                const isPriceFooter = /^all\s+prices\b/i.test(normalizeInlineText(line));
	                const isWelcomeFooter = /^we\s+welcome\s+enquiries\b/i.test(normalizeInlineText(line));

	                if (allergenLine || isHeader) {
	                    inFooter = true;
	                    if (allergenLine) allergenLines.push(allergenLine);
	                    continue;
	                }

	                if (isRawNotice) hadRawNotice = true;

	                if (inFooter || isPriceFooter || isWelcomeFooter || isRawNotice) {
	                    if (line) preservedFooterLines.push(line);
	                    continue;
	                }

	                menuLines.push(line);
	            }

            while (menuLines.length && menuLines[0] === '') menuLines.shift();
            while (menuLines.length && menuLines[menuLines.length - 1] === '') menuLines.pop();
            const normalized = [];
            let prevEmpty = false;
            for (const cl of menuLines) {
                if (cl === '') {
                    if (!prevEmpty) normalized.push('');
                    prevEmpty = true;
                } else {
                    normalized.push(cl);
                    prevEmpty = false;
                }
            }

	            return {
	                menu: normalized.join('\n'),
	                allergens: allergenLines.join(' | ') || (fallbackAllergens || ''),
	                hadRawNotice,
	                footerText: preservedFooterLines.join('\n'),
	            };
        }

        /**
         * Normalize text for diff comparison: trim each line, collapse consecutive
         * blank lines, trim leading/trailing blanks. Same logic as normalizeExtractedLines
         * but accepts a raw string instead of an array.
         */
        function normalizeMenuText(text) {
            const lines = (text || '').split('\n').map(l => l.trim());
            while (lines.length && lines[0] === '') lines.shift();
            while (lines.length && lines[lines.length - 1] === '') lines.pop();
            const normalized = [];
            let prevEmpty = false;
            for (const line of lines) {
                if (line === '') {
                    if (!prevEmpty) normalized.push('');
                    prevEmpty = true;
                } else {
                    normalized.push(line);
                    prevEmpty = false;
                }
            }
            return normalized.join('\n');
        }

