        function setContainsRawSelection(checked) {
            const step1 = document.getElementById('containsRawUndercooked');
            const step2 = document.getElementById('containsRawUndercookedStep2');
            if (step1) step1.checked = !!checked;
            if (step2) step2.checked = !!checked;
            renderAllergenLegend();
        }

        function detectRawUndercookedFromMenuText(menuText) {
            const content = (menuText || '').toLowerCase();
            if (!content.trim()) return false;
            if (content.includes('*')) return true;
            return [
                'raw',
                'undercooked',
                'carpaccio',
                'tartare',
                'ceviche',
                'tiradito',
                'crudo',
                'sashimi',
                'oyster',
                'oysters',
                'rare'
            ].some((term) => content.includes(term));
        }

        function getReviewedMenuTextForDetection() {
            const reviewedArea = document.getElementById('reviewedContentArea');
            if (reviewedArea && !document.getElementById('step2').classList.contains('hidden')) {
                return extractCleanTextFromReviewedArea(reviewedArea);
            }
            return (quill && quill.getText) ? quill.getText().trim() : '';
        }

        function getEffectiveRawNoticeDecision() {
            const selected = getContainsRawSelection();
            const detected = detectRawUndercookedFromMenuText(getReviewedMenuTextForDetection());
            return {
                selected,
                detected,
                shouldAdd: !suppressRawNotice && (selected || detected)
            };
        }

        function toggleRawNoticeSuppression() {
            suppressRawNotice = !suppressRawNotice;
            renderAllergenLegend();
        }

        function renderAllergenLegend() {
            // Preview box removed by design; keep function for existing call sites.
        }

        function setAllergenAutoDetectedBadge(visible) {
            const badge = document.getElementById('step2AllergenDetectedBadge');
            if (!badge) return;
            if (visible) {
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        }

        function markAiCheckStale() {
            if (!aiCheckHasRun || requiresAiRerun) return;
            requiresAiRerun = true;
            const rerunBtn = document.getElementById('rerunCheckBtn');
            if (rerunBtn) rerunBtn.classList.add('show');
            updateSubmitButtonState();
        }

        function onSubmissionModeChange() {
            submissionMode = document.getElementById('submissionModeModification').checked ? 'modification' : 'new';
            const modSection = document.getElementById('modificationSearchSection');
            const recentLoader = document.getElementById('recentProjectLoader');
            const previewSection = document.getElementById('persistentPreviewSection');

            if (submissionMode === 'modification') {
                modSection.classList.add('show');
                recentLoader.style.display = 'none';
                previewSection.classList.add('show');
                onModificationSourceChange();
                applyTurnaroundDefaults(true, true);
            } else {
                document.getElementById('step2').classList.add('hidden');
                document.getElementById('step1').classList.remove('hidden');
                document.getElementById('step2FormFields').classList.remove('hidden');
                setAiSuggestionsVisibility(false);

                if (isEditMode) {
                    toggleEditMode();
                }

                modSection.classList.remove('show');
                if (recentProjectsData.length > 0) {
                    recentLoader.style.display = 'flex';
                }
                previewSection.classList.remove('show');
                revisionBaseSubmissionId = null;
                selectedRevisionBaseline = null;
                revisionSource = 'database';
                revisionBaselineDocPath = '';
                revisionBaselineFileName = '';
                baseApprovedMenuContent = '';
                baseApprovedMenuContentHtml = '';
                preservedManagedFooterText = '';
                persistentDiffSummary = { insertions: 0, deletions: 0 };
                unapprovedMode = false;
                unapprovedAnnotations = [];
                unapprovedBaseHtml = '';
                unapprovedDiffBaseline = '';
                unapprovedAnnotationMap = {};
                aiCheckHasRun = false;
                aiCheckResults = null;
                criticalErrorOverrides = {};
                const selectedNote = document.getElementById('revisionSelectedNote');
                selectedNote.classList.remove('show');
                selectedNote.textContent = '';
                document.getElementById('submissionSearchResults').innerHTML = '';
                renderPersistentPreview('', '');
                displayReviewedContent('');
                quill.setText('');
                setAllergenInputValue('');
                setContainsRawSelection(false);
                suppressRawNotice = false;
                setAllergenAutoDetectedBadge(false);
                applyTurnaroundDefaults(true, false);
                baselineFreshnessOverrideKey = '';
            }
            updateRevisionPreCheckLayout();
        }

        function onModificationWorkflowChange(workflow) {
            onModificationSourceChange();
        }

        function onModificationSourceChange() {
            const useEditHere = document.getElementById('modWorkflowEditHere').checked;
            const useUnapproved = document.getElementById('modSourceUnapproved').checked;
            const useDatabase = useEditHere && document.getElementById('modSourceDatabase').checked;
            const useUpload = useEditHere && document.getElementById('modSourceUpload').checked;
            const editHerePanel = document.getElementById('modSourceEditHerePanel');
            const dbPanel = document.getElementById('modSourceDatabasePanel');
            const uploadPanel = document.getElementById('modSourceUploadPanel');
            const unapprovedPanel = document.getElementById('modSourceUnapprovedPanel');
            const selectedNote = document.getElementById('revisionSelectedNote');

            if (useUnapproved) {
                revisionSource = 'uploaded_unapproved';
            } else if (useUpload) {
                revisionSource = 'uploaded_baseline';
            } else if (useDatabase) {
                revisionSource = 'database';
            } else {
                revisionSource = '';
            }

            // Hide all panels first
            editHerePanel.classList.remove('show');
            dbPanel.classList.remove('show');
            uploadPanel.classList.remove('show');
            unapprovedPanel.classList.remove('show');

            // Reset common state
            revisionBaseSubmissionId = null;
            selectedRevisionBaseline = null;
            selectedNote.classList.remove('show');
            selectedNote.textContent = '';
            setContainsRawSelection(false);
            suppressRawNotice = false;
            setAllergenAutoDetectedBadge(false);
            preservedManagedFooterText = '';

            if (useUnapproved) {
                unapprovedPanel.classList.add('show');
                revisionBaseSubmissionId = null;
                revisionSearchResults = [];
                baseApprovedMenuContentHtml = '';
                document.getElementById('submissionSearchResults').innerHTML = '';
            } else if (useEditHere) {
                editHerePanel.classList.add('show');
                if (useUpload) {
                    uploadPanel.classList.add('show');
                    revisionBaseSubmissionId = null;
                    revisionSearchResults = [];
                    baseApprovedMenuContentHtml = '';
                    document.getElementById('submissionSearchResults').innerHTML = '';
                } else if (useDatabase) {
                    dbPanel.classList.add('show');
                    revisionBaselineDocPath = '';
                    revisionBaselineFileName = '';
                    baseApprovedMenuContentHtml = '';
                }
                // Reset unapproved state when switching away
                unapprovedMode = false;
                unapprovedAnnotations = [];
                unapprovedBaseHtml = '';
                unapprovedDiffBaseline = '';
                unapprovedAnnotationMap = {};
                preservedManagedFooterText = '';
            } else {
                revisionBaselineDocPath = '';
                revisionBaselineFileName = '';
                baseApprovedMenuContentHtml = '';
                // Reset unapproved state when switching away
                unapprovedMode = false;
                unapprovedAnnotations = [];
                unapprovedBaseHtml = '';
                unapprovedDiffBaseline = '';
                unapprovedAnnotationMap = {};
                preservedManagedFooterText = '';
            }
            updateRevisionPreCheckLayout();
        }

        function onSubmissionSearchInput(value) {
            clearTimeout(revisionSearchDebounce);
            const query = value.trim();
            if (query.length < 2) {
                document.getElementById('submissionSearchResults').innerHTML = '';
                revisionSearchResults = [];
                return;
            }
            revisionSearchDebounce = setTimeout(() => searchApprovedSubmissions(query), 250);
        }

        function normalizeBaselineMatchValue(value) {
            return `${value || ''}`.trim().toLowerCase().replace(/[_-]+/g, ' ').replace(/\s+/g, ' ');
        }

        function publicSubmissionId(record) {
            return `${record?.id || record?.legacyId || ''}`.trim();
        }

        function getCurrentPropertyService() {
            return {
                property: document.getElementById('property')?.value.trim() || '',
                servicePeriod: document.getElementById('servicePeriod')?.value || ''
            };
        }

        function baselineFreshnessKey(issue) {
            const latestId = publicSubmissionId(issue?.latest || {});
            const selectedId = publicSubmissionId(issue?.selected || {}) || revisionBaseSubmissionId || '';
            return [
                issue?.type || '',
                normalizeBaselineMatchValue(issue?.property || ''),
                normalizeBaselineMatchValue(issue?.servicePeriod || ''),
                selectedId,
                latestId
            ].join('|');
        }

        function formatApprovedDate(value) {
            if (!value) return 'unknown date';
            const date = new Date(value);
            return Number.isNaN(date.getTime()) ? 'unknown date' : date.toLocaleDateString();
        }

        function formatBaselineLabel(record) {
            if (!record) return 'approved menu';
            const name = record.projectName || record.approvedFileName || record.filename || 'approved menu';
            const approvedAt = record.reviewedAt || record.updatedAt || '';
            return `${name}${approvedAt ? ` (${formatApprovedDate(approvedAt)})` : ''}`;
        }

        async function fetchLatestApprovedForCurrentService(property, servicePeriod) {
            if (!property || !servicePeriod) return null;
            const params = new URLSearchParams({ property, servicePeriod });
            const response = await fetch(`/api/submissions/latest-approved?${params.toString()}`);
            if (response.status === 404) return null;
            const data = await response.json();
            if (!response.ok) {
                throw new Error(data.error || 'Latest approved lookup failed');
            }
            return data;
        }

        function applyApprovedBaseline(selected, options = {}) {
            if (!selected) return;

            document.getElementById('submissionModeModification').checked = true;
            document.getElementById('submissionModeNew').checked = false;
            if (submissionMode !== 'modification') {
                onSubmissionModeChange();
            }
            document.getElementById('modSourceDatabase').checked = true;
            document.getElementById('modWorkflowEditHere').checked = true;
            onModificationSourceChange();

            revisionBaseSubmissionId = selected.id;
            selectedRevisionBaseline = selected;
            revisionSource = 'database';
            revisionBaselineDocPath = '';
            revisionBaselineFileName = '';
            const normalizedBaseline = stripBaselineFooter(selected.approvedMenuContent || '', selected.allergens || '');
            baseApprovedMenuContent = normalizedBaseline.menu || '';
            baseApprovedMenuContentHtml = '';
            preservedManagedFooterText = normalizedBaseline.footerText || '';
            persistentDiffSummary = { insertions: 0, deletions: 0 };
            baselineFreshnessOverrideKey = '';
            setAllergenInputValue(normalizedBaseline.allergens || '');
            setContainsRawSelection(!!normalizedBaseline.hadRawNotice);
            suppressRawNotice = false;
            setAllergenAutoDetectedBadge(!!normalizedBaseline.allergens);

            applyProjectPrefill(selected);

            quill.setText(baseApprovedMenuContent || '');
            renderPersistentPreview(baseApprovedMenuContent, baseApprovedMenuContent);

            const selectedNote = document.getElementById('revisionSelectedNote');
            const latestNote = selected.isLatestForPropertyService === false ? ' (older than latest for this service)' : '';
            selectedNote.textContent = `Loaded approved baseline: ${selected.projectName || 'Untitled'} (${selected.id})${latestNote}`;
            selectedNote.classList.add('show');
            document.getElementById('submissionSearchResults').innerHTML = '';
            enterRevisionTrackingMode();
            if (!options.silent) {
                showAlert('Approved baseline loaded. Revision tracking mode is active.', 'success');
            }
            scheduleBaselineFreshnessCheck();
        }

        async function loadLatestApprovedBaseline(latest) {
            const latestId = publicSubmissionId(latest);
            if (!latestId) return;
            applyApprovedBaseline(latest);
        }

        async function getBaselineFreshnessIssue() {
            const { property, servicePeriod } = getCurrentPropertyService();
            if (!property || !servicePeriod) return null;

            const latest = await fetchLatestApprovedForCurrentService(property, servicePeriod);
            if (!latest) return null;

            const selectedId = `${revisionBaseSubmissionId || ''}`.trim();
            const selected = selectedRevisionBaseline;
            const currentPropertyKey = normalizeBaselineMatchValue(property);
            const currentServiceKey = normalizeBaselineMatchValue(servicePeriod);

            if (submissionMode === 'modification' && selectedId && selected) {
                const selectedPropertyKey = normalizeBaselineMatchValue(selected.property);
                const selectedServiceKey = normalizeBaselineMatchValue(selected.servicePeriod);
                if (selectedPropertyKey !== currentPropertyKey || selectedServiceKey !== currentServiceKey) {
                    return { type: 'mismatch', property, servicePeriod, selected, latest };
                }
                if (publicSubmissionId(latest) && publicSubmissionId(latest) !== selectedId) {
                    return { type: 'stale', property, servicePeriod, selected, latest };
                }
                return null;
            }

            return { type: 'existing', property, servicePeriod, selected: null, latest };
        }

        function getBaselineFreshnessCopy(issue) {
            const fallback = {
                title: 'Use the existing approved menu?',
                message: 'There is an approved menu for this property and service period. Loading it as the baseline keeps this submission connected to the current approved version.',
                detail: '',
                loadLabel: 'Use Existing Menu',
                continueLabel: 'Continue Anyway'
            };
            if (!issue) return fallback;

            const latestLabel = formatBaselineLabel(issue.latest);
            if (issue.type === 'mismatch') {
                return {
                    title: 'This baseline does not match the form',
                    message: `The loaded baseline is for ${issue.selected.property || 'another property'} / ${issue.selected.servicePeriod || 'another service'}, but the form is set to ${issue.property} / ${issue.servicePeriod}.`,
                    detail: `Latest approved menu for this form: ${latestLabel}`,
                    loadLabel: 'Load Matching Menu',
                    continueLabel: 'Keep Current Baseline'
                };
            }
            if (issue.type === 'stale') {
                return {
                    title: 'A newer approved menu exists',
                    message: `A newer approved ${issue.servicePeriod} menu exists for ${issue.property}. Loading it prevents design from reviewing changes against an older baseline.`,
                    detail: `Newest approved menu: ${latestLabel}`,
                    loadLabel: 'Load Newer Menu',
                    continueLabel: 'Keep Older Baseline'
                };
            }
            return {
                title: 'An approved menu already exists',
                message: `An approved ${issue.servicePeriod} menu already exists for ${issue.property}. If this is a revision, load the existing menu and make changes from that baseline.`,
                detail: `Existing approved menu: ${latestLabel}`,
                loadLabel: 'Use Existing Menu',
                continueLabel: 'Continue as Brand New'
            };
        }

        function closeBaselineFreshnessDialog(result) {
            const modal = document.getElementById('baselineFreshnessModal');
            if (modal) {
                modal.classList.remove('show');
            }
            if (!baselineFreshnessDialogState || typeof baselineFreshnessDialogState.resolve !== 'function') {
                baselineFreshnessDialogState = null;
                return;
            }
            const resolve = baselineFreshnessDialogState.resolve;
            baselineFreshnessDialogState = null;
            resolve(result);
        }

        function showBaselineFreshnessWarning(issue, options = {}) {
            if (!issue) return true;
            const key = baselineFreshnessKey(issue);
            if (baselineFreshnessOverrideKey === key && !options.force) {
                return true;
            }

            if (baselineFreshnessDialogState && baselineFreshnessDialogState.key === key) {
                return baselineFreshnessDialogState.promise;
            }

            const modal = document.getElementById('baselineFreshnessModal');
            const titleEl = document.getElementById('baselineFreshnessTitle');
            const messageEl = document.getElementById('baselineFreshnessMessage');
            const detailEl = document.getElementById('baselineFreshnessDetail');
            const loadBtn = document.getElementById('baselineFreshnessLoadBtn');
            const continueBtn = document.getElementById('baselineFreshnessContinueBtn');
            const cancelBtn = document.getElementById('baselineFreshnessCancelBtn');
            if (!modal || !titleEl || !messageEl || !detailEl || !loadBtn || !continueBtn || !cancelBtn) {
                return false;
            }

            if (baselineFreshnessDialogState) {
                closeBaselineFreshnessDialog(false);
            }

            const copy = getBaselineFreshnessCopy(issue);
            titleEl.textContent = copy.title;
            messageEl.textContent = copy.message;
            detailEl.textContent = copy.detail;
            loadBtn.textContent = copy.loadLabel;
            continueBtn.textContent = copy.continueLabel;

            let resolveDialog;
            const promise = new Promise((resolve) => {
                resolveDialog = resolve;
            });
            baselineFreshnessDialogState = { key, resolve: resolveDialog, promise };

            loadBtn.onclick = () => {
                closeBaselineFreshnessDialog(false);
                loadLatestApprovedBaseline(issue.latest);
            };
            continueBtn.onclick = () => {
                baselineFreshnessOverrideKey = key;
                closeBaselineFreshnessDialog(true);
                showAlert('Existing-menu warning acknowledged for this property and service.', 'info');
            };
            cancelBtn.onclick = () => closeBaselineFreshnessDialog(false);

            modal.classList.add('show');
            setTimeout(() => loadBtn.focus(), 0);
            return promise;
        }

        async function ensureBaselineFreshnessBeforeContinue() {
            try {
                const issue = await getBaselineFreshnessIssue();
                return await showBaselineFreshnessWarning(issue, { force: true });
            } catch (error) {
                console.error('Baseline freshness check failed:', error);
                showAlert('Could not verify the latest approved menu for this property and service. Please continue carefully.', 'warning');
                return true;
            }
        }

        function scheduleBaselineFreshnessCheck() {
            clearTimeout(baselineFreshnessCheckTimer);
            baselineFreshnessCheckTimer = setTimeout(async () => {
                try {
                    const issue = await getBaselineFreshnessIssue();
                    latestBaselineFreshnessIssue = issue;
                } catch (error) {
                    console.warn('Baseline freshness check skipped:', error.message);
                }
            }, 350);
        }

        async function searchApprovedSubmissions(query) {
            try {
                const { property, servicePeriod } = getCurrentPropertyService();
                const params = new URLSearchParams({ q: query, limit: '20' });
                if (property) params.set('property', property);
                if (servicePeriod) params.set('servicePeriod', servicePeriod);
                const response = await fetch(`/api/submissions/search?${params.toString()}`);
                const results = await response.json();
                if (!response.ok) {
                    throw new Error(results.error || 'Search failed');
                }
                revisionSearchResults = results || [];
                const resultsEl = document.getElementById('submissionSearchResults');

                if (!revisionSearchResults.length) {
                    resultsEl.innerHTML = '<div class="search-result-item">No approved submissions found. New ClickUp tasks appear here only after an approved DOCX has been processed.</div>';
                    return;
                }

                resultsEl.innerHTML = revisionSearchResults.map((r, idx) => `
                    <div class="search-result-item" onclick="selectRevisionResult(${idx})">
                        <strong>${escapeHtml(r.projectName || '(Untitled)')}</strong> - ${escapeHtml(r.property || 'Unknown Property')}<br>
                        <span style="color: var(--color-text-muted);">Service: ${escapeHtml(r.servicePeriod || 'N/A')} | Approved: ${escapeHtml(formatApprovedDate(r.reviewedAt || r.updatedAt))} | ID: ${escapeHtml(r.id)}</span>
                        ${r.isLatestForPropertyService === null ? '' : `<span style="display:inline-block;margin-left:0.4rem;color:${r.isLatestForPropertyService === false ? 'var(--color-warning)' : 'var(--color-success)'};font-weight:600;">${r.isLatestForPropertyService === false ? 'Older version' : 'Latest for service'}</span>`}
                    </div>
                `).join('');
            } catch (error) {
                console.error('Failed to search approved submissions:', error);
                document.getElementById('submissionSearchResults').innerHTML = '<div class="search-result-item">Search failed.</div>';
            }
        }

        function selectRevisionResult(index) {
            const selected = revisionSearchResults[index];
            if (!selected) return;
            applyApprovedBaseline(selected);
        }

        async function uploadBaselineDoc() {
            const input = document.getElementById('baselineDocUpload');
            const btn = document.getElementById('baselineUploadBtn');
            const file = input.files && input.files[0];
            if (!file) {
                showAlert('Choose a .docx baseline file first.', 'error');
                return;
            }

            const form = new FormData();
            form.append('baselineDoc', file);

            btn.disabled = true;
            btn.textContent = 'Extracting...';

            try {
                await logFormAttempt('baseline_upload_started', {
                    route: '/api/modification/baseline-upload',
                    revisionSource: 'uploaded_baseline',
                    revisionBaselineFileName: file.name,
                    details: { fileName: file.name, fileSize: file.size }
                });
                const response = await fetch('/api/modification/baseline-upload', {
                    method: 'POST',
                    headers: getAttemptHeaders({ 'x-menumanager-revision-source': 'uploaded_baseline' }),
                    body: form,
                });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to extract baseline document');
                }

                revisionSource = 'uploaded_baseline';
                revisionBaseSubmissionId = null;
                revisionBaselineDocPath = data.baselineDocPath || '';
                revisionBaselineFileName = data.baselineFileName || file.name;
                const normalizedBaseline = stripBaselineFooter(data.approvedMenuContent || '', data.extractedAllergenKey || '');
                baseApprovedMenuContent = normalizedBaseline.menu || '';
                baseApprovedMenuContentHtml = stripManagedFooterHtml(data.approvedMenuContentHtml || '');
                preservedManagedFooterText = normalizedBaseline.footerText || '';
                persistentDiffSummary = { insertions: 0, deletions: 0 };

                if (data.extractedProject) {
                    applyExtractedProjectToForm(data.extractedProject);
                }
                const detectedAllergens = normalizedBaseline.allergens || data.extractedAllergenKey || '';
                const detectedRawNotice = !!(data.containsRawNotice || normalizedBaseline.hadRawNotice);
                setAllergenInputValue(detectedAllergens || DEFAULT_ALLERGEN_KEY);
                setContainsRawSelection(detectedRawNotice);
                suppressRawNotice = false;
                setAllergenAutoDetectedBadge(!!detectedAllergens);

                quill.setText(baseApprovedMenuContent || '');
                renderPersistentPreview(baseApprovedMenuContent, baseApprovedMenuContent);

                const selectedNote = document.getElementById('revisionSelectedNote');
                selectedNote.textContent = `Loaded uploaded baseline: ${revisionBaselineFileName}`;
                selectedNote.classList.add('show');

                enterRevisionTrackingMode();
                await logFormAttempt('baseline_upload_completed', {
                    route: '/api/modification/baseline-upload',
                    statusCode: response.status,
                    revisionSource: 'uploaded_baseline',
                    revisionBaselineFileName,
                    menuTextLength: baseApprovedMenuContent.length,
                    menuHtmlLength: baseApprovedMenuContentHtml.length,
                    details: { fileName: file.name, fileSize: file.size }
                });
                showAlert('Baseline extracted. Revision tracking mode is active.', 'success');
            } catch (error) {
                console.error(error);
                await logFormAttempt('baseline_upload_failed', {
                    route: '/api/modification/baseline-upload',
                    revisionSource: 'uploaded_baseline',
                    revisionBaselineFileName: file.name,
                    errorMessage: error.message,
                    details: { fileName: file.name, fileSize: file.size }
                });
                showAlert('Failed to process baseline DOCX: ' + error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Extract Baseline';
            }
        }

        async function uploadUnapprovedDoc() {
            const input = document.getElementById('unapprovedDocUpload');
            const btn = document.getElementById('unapprovedUploadBtn');
            const file = input.files && input.files[0];
            if (!file) {
                showAlert('Choose a .docx file first.', 'error');
                return;
            }

            const form = new FormData();
            form.append('baselineDoc', file);

            btn.disabled = true;
            btn.textContent = 'Extracting...';

            try {
                await logFormAttempt('unapproved_upload_started', {
                    route: '/api/modification/unapproved-upload',
                    revisionSource: 'uploaded_unapproved',
                    revisionBaselineFileName: file.name,
                    details: { fileName: file.name, fileSize: file.size }
                });
                const response = await fetch('/api/modification/unapproved-upload', {
                    method: 'POST',
                    headers: getAttemptHeaders({ 'x-menumanager-revision-source': 'uploaded_unapproved' }),
                    body: form,
                });
                const data = await response.json();
                if (!response.ok) {
                    throw new Error(data.error || 'Failed to extract unapproved document');
                }

                unapprovedMode = true;
                unapprovedAnnotations = data.annotations || [];
                unapprovedBaseHtml = stripManagedFooterHtml(data.unapprovedHtml || '');
                revisionSource = 'uploaded_unapproved';
                revisionBaseSubmissionId = null;
                revisionBaselineDocPath = data.baselineDocPath || '';
                revisionBaselineFileName = data.baselineFileName || file.name;
                baseApprovedMenuContent = data.visibleText || '';
                baseApprovedMenuContentHtml = '';
                persistentDiffSummary = { insertions: 0, deletions: 0 };

                if (data.extractedProject) {
                    applyExtractedProjectToForm(data.extractedProject);
                }
                const normalizedBaseline = stripBaselineFooter(data.visibleText || '', data.extractedAllergenKey || '');
                preservedManagedFooterText = normalizedBaseline.footerText || '';
                setAllergenInputValue(normalizedBaseline.allergens || '');
                setContainsRawSelection(!!normalizedBaseline.hadRawNotice);
                suppressRawNotice = false;
                setAllergenAutoDetectedBadge(!!normalizedBaseline.allergens);

                // Baseline and annotation map are extracted from the editor DOM
                // in enterRevisionTrackingMode() after the HTML is loaded.
                // This guarantees structural identity with subsequent extractions.

                // Use stripped text for Quill / submission
                baseApprovedMenuContent = normalizedBaseline.menu || '';
                quill.setText(baseApprovedMenuContent || '');

                const selectedNote = document.getElementById('revisionSelectedNote');
                selectedNote.textContent = `Loaded unapproved DOCX (redlines preserved): ${revisionBaselineFileName}`;
                selectedNote.classList.add('show');

                enterRevisionTrackingMode();
                await logFormAttempt('unapproved_upload_completed', {
                    route: '/api/modification/unapproved-upload',
                    statusCode: response.status,
                    revisionSource: 'uploaded_unapproved',
                    revisionBaselineFileName,
                    menuTextLength: baseApprovedMenuContent.length,
                    menuHtmlLength: unapprovedBaseHtml.length,
                    persistentDiffHtmlLength: document.getElementById('persistentPreviewBody')?.innerHTML?.length || 0,
                    details: {
                        fileName: file.name,
                        fileSize: file.size,
                        annotationCount: unapprovedAnnotations.length
                    }
                });
                showAlert('Unapproved DOCX loaded. Existing redlines are preserved. Revision tracking mode is active.', 'success');
            } catch (error) {
                console.error(error);
                await logFormAttempt('unapproved_upload_failed', {
                    route: '/api/modification/unapproved-upload',
                    revisionSource: 'uploaded_unapproved',
                    revisionBaselineFileName: file.name,
                    errorMessage: error.message,
                    details: { fileName: file.name, fileSize: file.size }
                });
                showAlert('Failed to process unapproved DOCX: ' + error.message, 'error');
            } finally {
                btn.disabled = false;
                btn.textContent = 'Extract with Redlines';
            }
        }

        function enterRevisionTrackingMode() {
            if (submissionMode !== 'modification') return;

            const baselineText = baseApprovedMenuContent || quill.getText().trim();
            const synthetic = {
                success: true,
                originalMenu: baselineText,
                correctedMenu: baselineText,
                suggestions: [],
                hasChanges: false,
                hasCriticalErrors: false
            };

            aiCheckHasRun = false;
            aiCheckResults = synthetic;
