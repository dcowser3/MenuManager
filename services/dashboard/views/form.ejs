        }

        function setSelectValue(id, value) {
            const select = document.getElementById(id);
            if (!select || !value) return;

            // Try exact match first
            for (let i = 0; i < select.options.length; i++) {
                if (select.options[i].value === value) {
                    select.selectedIndex = i;
                    return;
                }
            }
            // Case-insensitive fallback
            const valueLower = value.toLowerCase();
            for (let i = 0; i < select.options.length; i++) {
                if (select.options[i].value.toLowerCase() === valueLower) {
                    select.selectedIndex = i;
                    return;
                }
            }
        }

        function markFieldAsExtracted(fieldId) {
            const el = document.getElementById(fieldId);
            if (!el || el.classList.contains('field-extracted')) return;
            el.classList.add('field-extracted');
            const clear = () => {
                el.classList.remove('field-extracted');
                el.removeEventListener('input', clear);
                el.removeEventListener('change', clear);
            };
            el.addEventListener('input', clear);
            el.addEventListener('change', clear);
        }

        function setFieldValueAndMark(fieldId, value) {
            const el = document.getElementById(fieldId);
            if (!el) return;
            el.value = value;
            markFieldAsExtracted(fieldId);
        }

        function setSelectValueAndMark(fieldId, value) {
            const before = document.getElementById(fieldId)?.value;
            setSelectValue(fieldId, value);
            const after = document.getElementById(fieldId)?.value;
            if (after && after !== before) markFieldAsExtracted(fieldId);
        }

        function applyExtractedProperty(extracted) {
            // 1. Exact catalog match on legacy `property` field.
            if (extracted.property && isPropertyFromCatalog(extracted.property)) {
                setFieldValueAndMark('property', extracted.property);
                updateServicePeriodOptions(extracted.property);
                return;
            }

            // 2. Structured match using outlet/hotel/city hints from newer templates.
            const matches = window.formHelpers.findCatalogMatchesFromHints(propertyCatalogMeta, {
                outlet: extracted.outlet,
                hotel: extracted.hotel,
                city: extracted.city,
            });
            if (matches.length === 1) {
                setFieldValueAndMark('property', matches[0]);
                updateServicePeriodOptions(matches[0]);
                return;
            }

            // Could not resolve confidently; leave the field for the chef to select.
        }

        function applyExtractedProjectToForm(extracted) {
            if (!extracted) return;
            if (extracted.projectName) setFieldValueAndMark('projectName', extracted.projectName);
            applyExtractedProperty(extracted);
            if (extracted.orientation) {
                setSelectValueAndMark('orientation', extracted.orientation);
            }
            if (extracted.dateNeeded) applyExtractedDateNeeded(extracted.dateNeeded);
            if (extracted.size) {
                const parsed = window.formHelpers.parseExtractedSize(extracted.size);
                if (parsed) {
                    applyExtractedSize(extracted.size);
                }
            }
        }

        function applyExtractedDateNeeded(dateStr) {
            const dateInput = document.getElementById('dateNeeded');
