        function showAlert(message, type = 'info', options = {}) {
            const container = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} show`;
            alert.style.position = 'relative';

            const msgSpan = document.createElement('span');
            msgSpan.textContent = message;
            alert.appendChild(msgSpan);

            // Dismiss button for persistent alerts
            if (((type === 'warning' || type === 'error') && !options.temporary) || options.persistent) {
                const dismiss = document.createElement('span');
                dismiss.textContent = ' ✕';
                dismiss.style.cssText = 'cursor:pointer;margin-left:12px;font-weight:bold;opacity:.7';
                dismiss.onclick = () => alert.remove();
                alert.appendChild(dismiss);
            }

            // Retry button
            if (options.onRetry) {
                const retryBtn = document.createElement('button');
                retryBtn.textContent = 'Retry';
                retryBtn.style.cssText = 'margin-left:12px;padding:2px 10px;border:1px solid currentColor;background:transparent;color:inherit;cursor:pointer;font-size:.8em;border-radius:3px';
                retryBtn.onclick = () => { alert.remove(); options.onRetry(); };
                alert.appendChild(retryBtn);
            }

            if (Array.isArray(options.actions)) {
                options.actions.forEach((action) => {
                    if (!action || !action.label) return;
                    if (typeof action.onClick === 'function') {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.textContent = action.label;
                        button.style.cssText = 'margin-left:12px;padding:2px 10px;border:1px solid currentColor;background:transparent;color:inherit;cursor:pointer;font-size:.8em;border-radius:3px;font-weight:600';
                        button.onclick = () => {
                            alert.remove();
                            action.onClick();
                        };
                        alert.appendChild(button);
                        return;
                    }
                    if (!action.href) return;
                    const link = document.createElement('a');
                    link.href = action.href;
                    link.textContent = action.label;
                    link.target = action.target || '_self';
                    link.rel = 'noopener';
                    link.style.cssText = 'margin-left:12px;color:inherit;font-weight:600;text-decoration:underline';
                    alert.appendChild(link);
                });
            }

            const autoDismissMs = Number(options.autoDismissMs || 0) ||
                (((type === 'success' || type === 'info') && !options.persistent) ? 5000 : 0);

            container.appendChild(alert);

            if (autoDismissMs > 0 && !options.persistent) {
                setTimeout(() => alert.remove(), autoDismissMs);
            }
        }

