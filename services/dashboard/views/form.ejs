        async function searchSubmitters(query) {
            try {
                const response = await fetch(`/api/submitter-profiles/search?q=${encodeURIComponent(query)}`);
                const profiles = await response.json();
                submitterResults = profiles;
                submitterHighlightIndex = -1;
                showSubmitterDropdown(profiles, query);
            } catch (err) {
                console.error('Submitter search error:', err);
            }
        }

        function showSubmitterDropdown(profiles, query) {
            const dropdown = document.getElementById('submitterDropdown');
            if (!profiles || profiles.length === 0) {
                dropdown.classList.remove('show');
                return;
            }

            const queryLower = query.toLowerCase();
            dropdown.innerHTML = profiles.map((p, i) => {
                const nameHtml = highlightMatch(p.name, queryLower);
                const detail = [p.email, p.jobTitle].filter(Boolean).join(' · ');
                return `<div class="autocomplete-item" data-index="${i}" onmousedown="selectSubmitter(${i})">
                    <div class="ac-name">${nameHtml}</div>
                    ${detail ? `<div class="ac-detail">${escapeHtml(detail)}</div>` : ''}
                </div>`;
            }).join('');

            dropdown.classList.add('show');
        }

        function highlightMatch(text, query) {
            const escaped = escapeHtml(text);
            const queryEscaped = escapeHtml(query);
            const regex = new RegExp(`(${queryEscaped.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
            return escaped.replace(regex, '<span class="ac-match">$1</span>');
        }

        function selectSubmitter(index) {
            const profile = submitterResults[index];
            if (!profile) return;

            document.getElementById('submitterName').value = profile.name;
            document.getElementById('submitterEmail').value = profile.email || '';
            document.getElementById('submitterJobTitle').value = profile.jobTitle || '';
            document.getElementById('submitterDropdown').classList.remove('show');
            submitterResults = [];
            submitterHighlightIndex = -1;
        }

        function handleSubmitterKeydown(e) {
            const dropdown = document.getElementById('submitterDropdown');
            if (!dropdown.classList.contains('show') || submitterResults.length === 0) return;

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                submitterHighlightIndex = Math.min(submitterHighlightIndex + 1, submitterResults.length - 1);
                updateSubmitterHighlight();
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                submitterHighlightIndex = Math.max(submitterHighlightIndex - 1, 0);
                updateSubmitterHighlight();
            } else if (e.key === 'Enter' && submitterHighlightIndex >= 0) {
                e.preventDefault();
                selectSubmitter(submitterHighlightIndex);
            } else if (e.key === 'Escape') {
                dropdown.classList.remove('show');
                submitterHighlightIndex = -1;
            }
        }

        function updateSubmitterHighlight() {
            const items = document.querySelectorAll('#submitterDropdown .autocomplete-item');
            items.forEach((item, i) => {
                item.classList.toggle('highlighted', i === submitterHighlightIndex);
            });
            // Scroll highlighted item into view
            if (items[submitterHighlightIndex]) {
                items[submitterHighlightIndex].scrollIntoView({ block: 'nearest' });
            }
        }

        // === Recent Project Loader ===
        <% const safePropertyOptions = typeof propertyOptions === 'undefined' ? [] : propertyOptions; %>
        <% const safePropertyCatalog = typeof propertyCatalog === 'undefined' ? [] : propertyCatalog; %>
        const initialPropertyOptions = <%- JSON.stringify(safePropertyOptions) %>;
        const initialPropertyCatalog = <%- JSON.stringify(safePropertyCatalog) %>;
        const DEFAULT_SERVICE_PERIOD_OPTIONS = [
            { value: 'breakfast', label: 'Breakfast' },
            { value: 'brunch', label: 'Brunch' },
            { value: 'lunch', label: 'Lunch' },
            { value: 'dinner', label: 'Dinner' },
            { value: 'happy_hour', label: 'Happy Hour' },
            { value: 'holiday', label: 'Holiday' },
            { value: 'other', label: 'Other' }
        ];
        let recentProjectsData = [];
        let propertyCatalogData = Array.isArray(initialPropertyOptions) ? initialPropertyOptions.slice() : [];
        let propertyCatalogMeta = [];
        let propertyCatalogLookup = {};
        let projectSuggestResults = [];
        let projectSuggestHighlightIndex = -1;
        let propertySuggestResults = [];
        let propertySuggestHighlightIndex = -1;

        function normalizeServiceFolderKey(value) {
            return String(value || '')
                .trim()
                .toLowerCase()
                .replace(/[_-]+/g, ' ')
                .replace(/\s*&\s*/g, ' and ')
                .replace(/\s+/g, ' ');
        }

        function rebuildPropertyCatalogState(catalog) {
            propertyCatalogMeta = Array.isArray(catalog)
                ? catalog
                    .map((item) => ({
                        name: `${item?.name || ''}`.trim(),
                        hotel: `${item?.hotel || ''}`.trim(),
                        cityCountry: `${item?.city_country || ''}`.trim(),
                        sharepointServiceFolders: Array.isArray(item?.sharepoint_service_folders)
                            ? item.sharepoint_service_folders.map((folder) => `${folder || ''}`.trim()).filter(Boolean)
                            : []
                    }))
                    .filter((item) => item.name)
                : [];

            propertyCatalogData = propertyCatalogMeta.map((item) => item.name);
            propertyCatalogLookup = propertyCatalogMeta.reduce((acc, item) => {
                acc[item.name.toLowerCase()] = item;
                return acc;
            }, {});
        }

        function getPropertyCatalogEntry(propertyName) {
            const key = `${propertyName || ''}`.trim().toLowerCase();
            return key ? propertyCatalogLookup[key] || null : null;
        }

        function getServicePeriodOptionsForProperty(propertyName) {
            const config = getPropertyCatalogEntry(propertyName);
            if (config && Array.isArray(config.sharepointServiceFolders) && config.sharepointServiceFolders.length > 0) {
                const propertySpecific = config.sharepointServiceFolders.map((folder) => ({
                    value: folder,
                    label: folder
                }));
                propertySpecific.push({ value: 'other', label: 'Other' });
                return propertySpecific;
            }
            return DEFAULT_SERVICE_PERIOD_OPTIONS.slice();
        }

        function updateServicePeriodOptions(propertyName, preferredValue) {
            const servicePeriodSelect = document.getElementById('servicePeriod');
            if (!servicePeriodSelect) return;

            const options = getServicePeriodOptionsForProperty(propertyName);
            const currentValue = preferredValue !== undefined ? preferredValue : servicePeriodSelect.value;

            servicePeriodSelect.innerHTML = `
                <option value="">Select service period</option>
                ${options.map((option) => `<option value="${escapeHtml(option.value)}">${escapeHtml(option.label)}</option>`).join('')}
            `;

            if (!currentValue) {
                servicePeriodSelect.value = '';
                return;
            }

            const exactMatch = options.find((option) => option.value === currentValue);
            if (exactMatch) {
                servicePeriodSelect.value = exactMatch.value;
                return;
            }

            const caseInsensitiveMatch = options.find((option) => option.value.toLowerCase() === currentValue.toLowerCase());
            if (caseInsensitiveMatch) {
                servicePeriodSelect.value = caseInsensitiveMatch.value;
                return;
            }

            const normalizedValue = normalizeServiceFolderKey(currentValue);
            const normalizedMatch = options.find((option) => normalizeServiceFolderKey(option.value) === normalizedValue);
            servicePeriodSelect.value = normalizedMatch ? normalizedMatch.value : '';
        }

        async function loadPropertyCatalog() {
            if (!propertyCatalogMeta.length && Array.isArray(initialPropertyCatalog) && initialPropertyCatalog.length) {
                rebuildPropertyCatalogState(initialPropertyCatalog);
            } else if (!propertyCatalogData.length && Array.isArray(initialPropertyOptions)) {
                propertyCatalogData = initialPropertyOptions.slice();
            }
            try {
                const response = await fetch('/api/properties');
                const data = await response.json();
                const catalog = Array.isArray(data?.catalog) ? data.catalog : [];
                if (catalog.length) {
                    rebuildPropertyCatalogState(catalog);
                }
            } catch (err) {
                console.error('Failed to load property catalog:', err);
                if (!propertyCatalogMeta.length && !propertyCatalogData.length) {
                    propertyCatalogData = [];
                }
            }

            updateServicePeriodOptions(document.getElementById('property')?.value || '', document.getElementById('servicePeriod')?.value || '');
        }

        async function loadRecentProjects() {
            try {
                const response = await fetch('/api/recent-projects?limit=20');
                const projects = await response.json();
                recentProjectsData = projects;

                if (projects.length === 0) return;

                const select = document.getElementById('recentProjectSelect');
                projects.forEach((p, i) => {
                    const opt = document.createElement('option');
                    opt.value = i;
                    opt.textContent = `${p.projectName} — ${p.property}`;
                    select.appendChild(opt);
                });

                if (submissionMode !== 'modification') {
                    document.getElementById('recentProjectLoader').style.display = 'flex';
                }
            } catch (err) {
                console.error('Failed to load recent projects:', err);
            }
        }

        function loadRecentProject(index) {
            if (index < 0 || !recentProjectsData[index]) return;
            const p = recentProjectsData[index];
            applyProjectPrefill(p);
        }

        function applyProjectPrefill(p) {
            if (!p) return;
            const toYesNo = (value, fallback = 'no') => {
                if (value === true || value === 'true' || value === 1 || value === '1' || value === 'yes') return 'yes';
                if (value === false || value === 'false' || value === 0 || value === '0' || value === 'no') return 'no';
                return fallback;
            };

            document.getElementById('projectName').value = p.projectName || '';
            document.getElementById('property').value = p.property || '';

            setSelectValue('orientation', p.orientation);
            setSelectValue('menuType', p.menuType);
            updateServicePeriodOptions(p.property || '', p.servicePeriod || '');
            baselineFreshnessOverrideKey = '';
            scheduleBaselineFreshnessCheck();
            setSelectValue('templateType', p.templateType);
            setSelectValue('assetType', p.assetType);
            if (p.turnaroundDays) {
                document.getElementById('turnaroundDays').value = p.turnaroundDays;
                setDateNeededMinimumFromTurnaround(true);
            }

            // Show the right conditional fields
            toggleAssetFields();

            // Populate dimension fields based on asset type
            if (p.assetType === 'PRINT') {
                document.getElementById('widthPrint').value = p.width || '';
                document.getElementById('heightPrint').value = p.height || '';
                setSelectValue('cropMarks', toYesNo(p.cropMarks));
                setSelectValue('bleedMarks', toYesNo(p.bleedMarks));
                setSelectValue('fileSizeLimit', toYesNo(p.fileSizeLimit));
                toggleFileSizeLimit();
                document.getElementById('fileSizeLimitMb').value = p.fileSizeLimitMb || '';
                document.getElementById('fileDeliveryNotes').value = p.fileDeliveryNotes || '';
                setSelectValue('folded', toYesNo(p.folded));
                setSelectValue('printRegion', p.printRegion || 'US');
                setSelectValue('printSize', p.printSize || '');
                togglePrintRegionFields();
            } else if (p.assetType === 'DIGITAL') {
                document.getElementById('widthDigital').value = p.width || '';
                document.getElementById('heightDigital').value = p.height || '';
            } else if (p.assetType === 'BOTH') {
                document.getElementById('widthDigital').value = p.digitalWidth || '';
                document.getElementById('heightDigital').value = p.digitalHeight || '';
                document.getElementById('widthPrint').value = '';
                document.getElementById('heightPrint').value = '';
                document.getElementById('cropMarks').value = '';
                document.getElementById('bleedMarks').value = '';
                document.getElementById('fileSizeLimit').value = '';
                document.getElementById('fileSizeLimitMb').value = '';
                document.getElementById('fileDeliveryNotes').value = '';
                document.getElementById('folded').value = '';
                document.getElementById('printRegion').value = '';
                document.getElementById('printSize').value = '';
                togglePrintRegionFields();
                toggleFileSizeLimit();
            }

            // Dispatch change event on templateType to update approval hints
            document.getElementById('templateType').dispatchEvent(new Event('change'));
        }

        function onProjectNameInput(value) {
