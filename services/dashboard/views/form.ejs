    <script>
        let aiCheckResults = null;
        let quill = null;
        let isEditMode = false;
        let aiChanges = [];
        let originalAiCorrectedText = '';
        let criticalErrorOverrides = {};
        let submissionMode = 'modification';
        const turnaroundUserState = {
            new: { isUserSet: false, value: '' },
            modification: { isUserSet: false, value: '' }
        };
        let revisionSearchDebounce = null;
        let revisionSearchResults = [];
        let revisionBaseSubmissionId = null;
        let selectedRevisionBaseline = null;
        let revisionSource = 'database';
        let revisionBaselineDocPath = '';
        let revisionBaselineFileName = '';
        let baseApprovedMenuContent = '';
        let baseApprovedMenuContentHtml = '';
        let persistentDiffSummary = { insertions: 0, deletions: 0 };
        let unapprovedMode = false;
        let unapprovedAnnotations = [];
        let unapprovedBaseHtml = '';
        let unapprovedDiffBaseline = '';
        let unapprovedAnnotationMap = {};
        let persistentPreviewUpdateTimer = null;
        let aiCheckHasRun = false;
        let lastAiCheckedMenuText = '';
        let requiresAiRerun = false;
        let suppressRawNotice = false;
        let uploadedMenuImagePath = '';
        let uploadedMenuImageFileName = '';
        let preservedManagedFooterText = '';
        let baselineFreshnessOverrideKey = '';
        let baselineFreshnessCheckTimer = null;
        let baselineFreshnessDialogState = null;
        let latestBaselineFreshnessIssue = null;
        let formAttemptId = getOrCreateFormAttemptId();
        const DEFAULT_ALLERGEN_KEY = <%- JSON.stringify(defaultAllergenKey || '') %>;
        const RAW_NOTICE_TEXT = '*consuming raw or undercooked meats, poultry, seafood, shellfish, or eggs may increase your risk of foodborne illness.';
        const RAW_NOTICE_REGEX = /\*?\s*consuming raw or undercooked meats,\s*poultry,\s*seafood(?:,\s*shellfish)?,\s*or eggs may increase your risk of foodborne illness\.?/i;
        const redlinePreview = window.MenuRedlinePreview;

        function getOrCreateFormAttemptId() {
            const storageKey = 'menumanager_form_attempt_id';
            try {
                const existing = window.sessionStorage && window.sessionStorage.getItem(storageKey);
                if (existing) return existing;
                const generated = generateFormAttemptId();
                if (window.sessionStorage) window.sessionStorage.setItem(storageKey, generated);
                return generated;
            } catch (error) {
                return generateFormAttemptId();
            }
        }

        function generateFormAttemptId() {
            return (window.crypto && window.crypto.randomUUID)
                ? window.crypto.randomUUID()
                : `attempt-${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        }

