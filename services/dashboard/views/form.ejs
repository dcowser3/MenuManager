        function isHeadingLike(line) {
            const text = (line || '').trim();
            if (!text) return false;
            if (text.length > 48) return false;
            if (/[,:;]/.test(text)) return false;
            if (/\d/.test(text)) return false;
            return text.split(/\s+/).length <= 6;
        }

        function preserveMenuStructure(originalText, correctedText) {
            const originalLines = (originalText || '').split('\n');
            const correctedLines = (correctedText || '').split('\n');

            // If AI already kept blank lines, trust AI output as-is.
            if (correctedLines.some((l) => !l.trim())) {
                return correctedText;
            }

            const originalNonEmpty = originalLines.filter((l) => l.trim());
            const correctedNonEmpty = correctedLines.filter((l) => l.trim());

            // Preserve original spacing pattern only when line counts match.
            if (originalNonEmpty.length !== correctedNonEmpty.length) {
                return correctedText;
            }

            const rebuilt = [];
            let correctedIdx = 0;
            for (const originalLine of originalLines) {
                if (!originalLine.trim()) {
                    rebuilt.push('');
                } else {
                    rebuilt.push(correctedNonEmpty[correctedIdx] || '');
                    correctedIdx++;
                }
            }

            return rebuilt.join('\n');
        }

        function applyHeadingFormatting(originalText, displayText) {
            if (!quill) return;
            const originalLines = (originalText || '').split('\n');
            const displayLines = (displayText || '').split('\n');
            const headingLineIndexes = [];

            if (originalLines.length === displayLines.length) {
                for (let i = 0; i < originalLines.length; i++) {
                    if (isHeadingLike(originalLines[i]) && (displayLines[i] || '').trim()) {
                        headingLineIndexes.push(i);
                    }
                }
            } else {
                for (let i = 0; i < displayLines.length; i++) {
                    if (isHeadingLike(displayLines[i])) {
                        headingLineIndexes.push(i);
                    }
                }
            }

            const headingSet = new Set(headingLineIndexes);
            let charOffset = 0;
            for (let i = 0; i < displayLines.length; i++) {
                const line = displayLines[i] || '';
                if (headingSet.has(i) && line.trim()) {
                    quill.formatText(charOffset, line.length, { bold: true });
                }
                charOffset += line.length + 1;
            }
        }

        function tokenizeDiffText(text) {
            return redlinePreview.tokenizeDiffText(text);
        }

        function diffTokensEqual(left, right) {
            return redlinePreview.diffTokensEqual(left, right);
        }

        function buildTokenLcs(baseTokens, revisedTokens) {
            return redlinePreview.buildTokenLcs(baseTokens, revisedTokens);
        }

        function normalizeTextForStyleMatch(text) {
            return (text || '').replace(/\u00A0/g, ' ').replace(/\r\n?/g, '\n').trim();
        }

        function stripAiReviewTransientFormatting(html) {
            if (!html || !document || !document.createElement) return html || '';
            const wrap = document.createElement('div');
            wrap.innerHTML = html;
            wrap.querySelectorAll('span[style]').forEach((span) => {
                const style = (span.getAttribute('style') || '').toLowerCase();
                if (!style.includes('background')) return;
                const fragment = document.createDocumentFragment();
                while (span.firstChild) {
                    fragment.appendChild(span.firstChild);
                }
                span.replaceWith(fragment);
            });
            return wrap.innerHTML;
        }

        function getCurrentRichMenuHtmlForText(text) {
            const target = normalizeTextForStyleMatch(text);
            const reviewedArea = document.getElementById('reviewedContentArea');
            if (reviewedArea && reviewedArea.innerHTML && normalizeTextForStyleMatch(extractCleanTextFromReviewedArea(reviewedArea)) === target) {
                return stripAiReviewTransientFormatting(reviewedArea.innerHTML);
            }
            if (quill && quill.root && normalizeTextForStyleMatch(quill.getText()) === target) {
                return stripAiReviewTransientFormatting(quill.root.innerHTML);
            }
            return '';
        }

        function htmlLinesToParagraphs(html) {
            return (html || '')
                .split(/<br\s*\/?>/i)
                .map((lineHtml) => `<p>${lineHtml || '<br>'}</p>`)
                .join('');
        }

        function setQuillReviewedHtmlFromText(text, sourceHtml) {
            const projectedHtml = sourceHtml && redlinePreview.projectRichTextHtml
                ? redlinePreview.projectRichTextHtml(sourceHtml, text)
                : '';
            if (projectedHtml && quill && quill.clipboard) {
                quill.clipboard.dangerouslyPasteHTML(htmlLinesToParagraphs(projectedHtml));
            } else {
                quill.setText(text);
            }
        }

        function computeLineDiff(original, corrected) {
            const revisedTokens = tokenizeDiffText(corrected);
            const baseTokens = tokenizeDiffText(original);
            const lcs = buildTokenLcs(baseTokens, revisedTokens);
            const changes = [];

            let idx = 0;
            while (idx < revisedTokens.length) {
                if (lcs.commonRev.has(idx)) {
                    idx++;
                    continue;
                }

                const start = revisedTokens[idx].start;
                let end = revisedTokens[idx].end;
                let hasVisibleToken = revisedTokens[idx].type !== 'whitespace';

                idx++;
                while (idx < revisedTokens.length && !lcs.commonRev.has(idx)) {
                    end = revisedTokens[idx].end;
                    if (revisedTokens[idx].type !== 'whitespace') {
                        hasVisibleToken = true;
                    }
                    idx++;
                }

                if (!hasVisibleToken) {
                    continue;
                }

                changes.push({
                    start,
                    length: end - start,
                    word: corrected.slice(start, end)
                });
            }

            return changes;
        }

        function renderSuggestionCard(suggestion, idx) {
            const isCritical = suggestion.severity === 'critical';
            const confidenceClass = `confidence-${suggestion.confidence}`;
            const criticalClass = isCritical ? 'critical-error' : '';
            const overriddenClass = criticalErrorOverrides[idx] ? 'overridden' : '';

            let badgeHtml = '';
            if (isCritical) {
                badgeHtml = `<span class="severity-badge-critical">CRITICAL</span>`;
            } else {
                badgeHtml = `<span class="confidence-badge ${confidenceClass}">${(suggestion.confidence || 'medium').toUpperCase()}</span>`;
            }

            let overrideBtnHtml = '';
            if (isCritical) {
                const btnText = criticalErrorOverrides[idx] ? 'Undo Override' : 'Override — AI May Be Wrong';
                const btnClass = criticalErrorOverrides[idx] ? 'critical-override-btn overridden' : 'critical-override-btn';
                overrideBtnHtml = `<button class="${btnClass}" onclick="overrideCriticalError(${idx})">${btnText}</button>`;
            }

            return `
                <div class="suggestion-item ${criticalClass} ${overriddenClass}" data-suggestion-index="${idx}">
                    <div class="suggestion-type">
                        ${escapeHtml(suggestion.type)}
                        ${badgeHtml}
                    </div>
                    ${suggestion.menuItem ? `<div style="font-weight: 600; color: var(--color-text); font-size: 0.75rem; margin: 0.25rem 0;">Item: ${escapeHtml(suggestion.menuItem)}</div>` : ''}
                    <div class="suggestion-detail">${escapeHtml(suggestion.description)}</div>
                    <div style="color: var(--color-success); font-size: 0.75rem; margin-top: 0.25rem;"><strong>Recommendation:</strong> ${escapeHtml(suggestion.recommendation)}</div>
                    ${overrideBtnHtml}
                </div>
            `;
        }

        function updateSubmitButtonState() {
            const submitBtn = document.getElementById('submitBtn');
            const banner = document.getElementById('criticalErrorBanner');
            const staleBanner = document.getElementById('aiStaleBanner');
            if (!aiCheckHasRun) {
                submitBtn.disabled = true;
                submitBtn.classList.add('blocked');
                banner.classList.remove('show');
                staleBanner.classList.remove('show');
                return;
            }

            if (requiresAiRerun) {
                submitBtn.disabled = true;
                submitBtn.classList.add('blocked');
                banner.classList.remove('show');
                staleBanner.classList.add('show');
                return;
            }

            if (!aiCheckResults || !aiCheckResults.suggestions) {
                submitBtn.disabled = false;
                submitBtn.classList.remove('blocked');
                banner.classList.remove('show');
                staleBanner.classList.remove('show');
                return;
            }

            const unresolvedCritical = aiCheckResults.suggestions.some((s, idx) =>
                s.severity === 'critical' && !criticalErrorOverrides[idx]
            );

            if (unresolvedCritical) {
                submitBtn.disabled = true;
                submitBtn.classList.add('blocked');
                banner.classList.add('show');
                staleBanner.classList.remove('show');
            } else {
                submitBtn.disabled = false;
                submitBtn.classList.remove('blocked');
                banner.classList.remove('show');
                staleBanner.classList.remove('show');
            }
        }

        function overrideCriticalError(idx) {
            criticalErrorOverrides[idx] = !criticalErrorOverrides[idx];

            // Re-render just the affected card
            const card = document.querySelector(`.suggestion-item[data-suggestion-index="${idx}"]`);
            if (card && aiCheckResults && aiCheckResults.suggestions[idx]) {
                const newCard = document.createElement('div');
                newCard.innerHTML = renderSuggestionCard(aiCheckResults.suggestions[idx], idx);
                card.replaceWith(newCard.firstElementChild);
            }

            updateSubmitButtonState();
        }

        async function rerunAICheck() {
            const rerunBtn = document.getElementById('rerunCheckBtn');
            rerunBtn.disabled = true;
            rerunBtn.textContent = 'Re-running...';

            // Get current edited text using the same normalized extractor as the initial AI check.
            // Raw innerText adds browser-generated newlines around block elements on each render.
            const reviewedArea = document.getElementById('reviewedContentArea');
            const menuContent = extractCleanTextFromReviewedArea(reviewedArea);
            const allergens = getAllergenInputValue();
            const menuType = document.getElementById('menuType').value;
            const reviewMode = submissionMode === 'modification' && !unapprovedMode ? 'changed_only' : 'full';
            const baselineForAiReview = submissionMode === 'modification' && !unapprovedMode ? baseApprovedMenuContent : '';
            const richHtmlForMetrics = reviewedArea?.innerHTML || '';
            const persistentDiffHtmlForMetrics = document.getElementById('persistentPreviewBody')?.innerHTML || '';
            const basicCheckPayload = {
                menuContent,
                allergens,
                menuType,
                baselineMenuContent: baselineForAiReview,
                reviewMode,
                ...getAttemptMetadata({
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length
                })
            };

            try {
                await logFormAttempt('basic_check_started', {
                    route: '/api/form/basic-check',
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length,
                    requestBodyLength: byteLength(JSON.stringify(basicCheckPayload)),
                    details: { reviewMode, rerun: true }
                });
                const response = await fetch('/api/form/basic-check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', ...getAttemptHeaders() },
                    body: JSON.stringify(basicCheckPayload)
                });

                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Failed to run AI check');
                }

                aiCheckHasRun = true;
                requiresAiRerun = false;
                setAiSuggestionsVisibility(true);
                aiCheckResults = data;
                criticalErrorOverrides = {};
                await logFormAttempt('basic_check_client_received', {
                    route: '/api/form/basic-check',
                    statusCode: response.status,
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length,
                    correctedMenuTextLength: (data.correctedMenu || '').length,
                    requestBodyLength: byteLength(JSON.stringify(basicCheckPayload)),
                    suggestionsCount: (data.suggestions || []).length,
                    criticalSuggestionsCount: (data.suggestions || []).filter((s) => s.severity === 'critical').length,
                    criticalSuggestions: (data.suggestions || []).filter((s) => s.severity === 'critical'),
                    details: {
                        reviewMode: data.reviewMode || reviewMode,
                        changedLineCount: data.changedLineCount || 0,
                        hasChanges: !!data.hasChanges,
                        rerun: true
                    }
                });

                // Re-render step 2 with new results
                showStep2(data);
                showAlert('AI check re-run complete! Review updated suggestions.', 'success');

            } catch (error) {
                console.error('Error re-running check:', error);
                await logFormAttempt('basic_check_client_failed', {
                    route: '/api/form/basic-check',
                    menuTextLength: menuContent.length,
                    menuHtmlLength: richHtmlForMetrics.length,
                    persistentDiffHtmlLength: persistentDiffHtmlForMetrics.length,
                    requestBodyLength: byteLength(JSON.stringify(basicCheckPayload)),
                    errorMessage: error.message,
                    details: { rerun: true }
                });
                showAlert('Error re-running AI check: ' + error.message, 'error');
            } finally {
                rerunBtn.disabled = false;
                rerunBtn.textContent = 'Re-run AI Check';
            }
        }

        function showStep2(results) {
            document.getElementById('step2').classList.remove('hidden');
            const step2Container = document.querySelector('.step2-container');
            const isModificationMode = submissionMode === 'modification';
            const preAiRevisionMode = isModificationMode && !aiCheckHasRun;
            const menuPanelSubtitle = document.getElementById('menuPanelSubtitle');

            if (step2Container) {
                if (isModificationMode) {
                    step2Container.classList.add('revision-split');
                } else {
                    step2Container.classList.remove('revision-split');
                }
            }

            if (preAiRevisionMode) {
                document.getElementById('step1').classList.remove('hidden');
                document.getElementById('step2FormFields').classList.add('hidden');
                setAiSuggestionsVisibility(false);
                if (menuPanelSubtitle) {
                    menuPanelSubtitle.textContent = 'Chef revision editor (persistent redlines preview on right)';
                }
            } else {
                document.getElementById('step1').classList.add('hidden');
                document.getElementById('step2FormFields').classList.remove('hidden');
                setAiSuggestionsVisibility(true);
                if (menuPanelSubtitle) {
                    menuPanelSubtitle.textContent = 'AI-reviewed content (green = AI changes)';
                }
            }
            updateRevisionPreCheckLayout();
            renderAllergenLegend();

            // Reset critical error overrides
            criticalErrorOverrides = {};

            // Populate read-only submitter fields
            document.getElementById('step2SubmitterName').value = document.getElementById('submitterName').value;
            document.getElementById('step2SubmitterEmail').value = document.getElementById('submitterEmail').value;
            document.getElementById('step2SubmitterJobTitle').value = document.getElementById('submitterJobTitle').value;

            // Populate read-only project detail fields
            document.getElementById('step2ProjectName').value = document.getElementById('projectName').value;
            document.getElementById('step2Property').value = document.getElementById('property').value;
            const menuTypeSelect = document.getElementById('menuType');
            document.getElementById('step2MenuType').value = menuTypeSelect.options[menuTypeSelect.selectedIndex].text;
            const servicePeriodSelect = document.getElementById('servicePeriod');
            document.getElementById('step2ServicePeriod').value = servicePeriodSelect.options[servicePeriodSelect.selectedIndex].text;
            const templateTypeSelect = document.getElementById('templateType');
            document.getElementById('step2TemplateType').value = templateTypeSelect.options[templateTypeSelect.selectedIndex].text;
            document.getElementById('step2TurnaroundDays').value = `${getTurnaroundDaysValue()} day(s)`;
            document.getElementById('step2DateNeeded').value = document.getElementById('dateNeeded').value;
            const assetTypeSelect = document.getElementById('assetType');
            document.getElementById('step2AssetType').value = assetTypeSelect.options[assetTypeSelect.selectedIndex].text;
            document.getElementById('step2Orientation').value = document.getElementById('orientation').value;

            // Populate dimensions and print-specific fields
            const assetTypeVal = document.getElementById('assetType').value;
            const printRegion = document.getElementById('printRegion').value;
            if (assetTypeVal === 'PRINT' || assetTypeVal === 'BOTH') {
                const w = document.getElementById('widthPrint').value;
                const h = document.getElementById('heightPrint').value;
                const size = document.getElementById('printSize').value;
                const printDim = printRegion === 'NON_US'
                    ? `${size || 'N/A'}`
                    : `${w || 'N/A'} x ${h || 'N/A'} inches`;
                const digitalW = document.getElementById('widthDigital').value;
                const digitalH = document.getElementById('heightDigital').value;
                document.getElementById('step2Dimensions').value = assetTypeVal === 'BOTH'
                    ? `Digital ${digitalW || 'N/A'} x ${digitalH || 'N/A'} px | Print ${printDim}`
                    : printDim;
                // Show print-specific read-only fields
                document.getElementById('step2CropMarksGroup').classList.remove('hidden');
                document.getElementById('step2BleedMarksGroup').classList.remove('hidden');
                document.getElementById('step2FileSizeLimitGroup').classList.remove('hidden');
                document.getElementById('step2FoldedGroup').classList.remove('hidden');
                document.getElementById('step2PrintRegionGroup').classList.remove('hidden');
                document.getElementById('step2CropMarks').value = document.getElementById('cropMarks').value === 'yes' ? 'Yes' : 'No';
                document.getElementById('step2BleedMarks').value = document.getElementById('bleedMarks').value === 'yes' ? 'Yes' : 'No';
                const fsl = document.getElementById('fileSizeLimit').value;
                const fslMb = document.getElementById('fileSizeLimitMb').value;
                document.getElementById('step2FileSizeLimit').value = fsl === 'yes' ? `Yes (${fslMb} MB)` : 'No';
                document.getElementById('step2Folded').value = document.getElementById('folded').value === 'yes' ? 'Folded' : 'Not Folded';
                document.getElementById('step2PrintRegion').value = printRegion === 'NON_US' ? 'Non-US' : 'US';
                if (printRegion === 'NON_US') {
                    document.getElementById('step2PrintSizeGroup').classList.remove('hidden');
                    document.getElementById('step2PrintSize').value = size || 'N/A';
                } else {
                    document.getElementById('step2PrintSizeGroup').classList.add('hidden');
                }
                const deliveryNotes = document.getElementById('fileDeliveryNotes').value.trim();
                if (deliveryNotes) {
                    document.getElementById('step2FileDeliveryNotesGroup').classList.remove('hidden');
                    document.getElementById('step2FileDeliveryNotes').value = deliveryNotes;
                } else {
                    document.getElementById('step2FileDeliveryNotesGroup').classList.add('hidden');
                }
            } else {
                const w = document.getElementById('widthDigital').value;
                const h = document.getElementById('heightDigital').value;
                document.getElementById('step2Dimensions').value = `${w} x ${h} pixels`;
                // Hide print-specific read-only fields
                document.getElementById('step2CropMarksGroup').classList.add('hidden');
                document.getElementById('step2BleedMarksGroup').classList.add('hidden');
                document.getElementById('step2FileSizeLimitGroup').classList.add('hidden');
                document.getElementById('step2FileDeliveryNotesGroup').classList.add('hidden');
                document.getElementById('step2FoldedGroup').classList.add('hidden');
                document.getElementById('step2PrintRegionGroup').classList.add('hidden');
                document.getElementById('step2PrintSizeGroup').classList.add('hidden');
            }

            const originalText = results.originalMenu;
            const correctedText = results.correctedMenu;
            const hasChanges = results.hasChanges;

            const correctedDisplayText = preserveMenuStructure(originalText, correctedText);
            const sourceRichHtml = getCurrentRichMenuHtmlForText(originalText);
            setQuillReviewedHtmlFromText(correctedDisplayText, sourceRichHtml);
            applyHeadingFormatting(originalText, correctedDisplayText);

            if (hasChanges) {
                const changes = computeLineDiff(originalText, correctedDisplayText);

                aiChanges = changes.map(change => ({
                    start: change.start,
                    length: change.length,
                    word: change.word
                }));
                originalAiCorrectedText = correctedDisplayText;

                changes.forEach(change => {
                    quill.formatText(change.start, change.length, {
                        background: 'rgba(74, 124, 89, 0.2)'
                    });
                });
            } else {
                aiChanges = [];
                originalAiCorrectedText = correctedDisplayText;
            }

            // Display the reviewed content with highlights
            displayReviewedContent(quill.root.innerHTML);
            const aiCheckBase = (unapprovedMode && unapprovedDiffBaseline)
                ? unapprovedDiffBaseline
                : (baseApprovedMenuContent || originalText);
            renderPersistentPreview(aiCheckBase, correctedDisplayText);
            lastAiCheckedMenuText = extractCleanTextFromReviewedArea(document.getElementById('reviewedContentArea'));
            requiresAiRerun = false;

            const suggestionsDisplay = document.getElementById('suggestionsDisplay');

            // Sort suggestions: critical first, then normal
            let sortedSuggestions = [];
            if (results.suggestions && results.suggestions.length > 0) {
                sortedSuggestions = [...results.suggestions].sort((a, b) => {
                    if (a.severity === 'critical' && b.severity !== 'critical') return -1;
                    if (a.severity !== 'critical' && b.severity === 'critical') return 1;
                    return 0;
                });
                // Update the results.suggestions to match sorted order for index tracking
                results.suggestions = sortedSuggestions;
            }

            if (hasChanges) {
                let html = `
                    <div class="suggestion-item" style="border-left: 3px solid var(--color-success); background: rgba(74, 124, 89, 0.05);">
                        <div class="suggestion-type" style="color: var(--color-success);">Auto-Corrected</div>
                        <div class="suggestion-detail" style="color: var(--color-success);">
                            High-confidence spelling and grammar corrections have been automatically applied.
                            Green highlights show inserted or modified text, including punctuation and separator changes.
                        </div>
                    </div>
                `;

                if (sortedSuggestions.length > 0) {
                    html += sortedSuggestions.map((suggestion, idx) => renderSuggestionCard(suggestion, idx)).join('');
                }

                suggestionsDisplay.innerHTML = html;
                showAlert('Auto-corrections applied! Green highlights show the changes.', 'success');
            } else if (sortedSuggestions.length > 0) {
                suggestionsDisplay.innerHTML = sortedSuggestions.map((suggestion, idx) => renderSuggestionCard(suggestion, idx)).join('');
            } else {
                suggestionsDisplay.innerHTML = `
                    <div class="suggestion-item" style="border-left: 3px solid var(--color-success);">
                        <div class="suggestion-type" style="color: var(--color-success);">All Clear</div>
                        <div class="suggestion-detail">No issues found. Your menu looks perfect!</div>
                    </div>
                `;
            }

            updateSubmitButtonState();
        }

        async function uploadMenuImageIfNeeded() {
            const input = document.getElementById('menuImageUpload');
            const file = input?.files?.[0];
            if (!file) {
                uploadedMenuImagePath = '';
                uploadedMenuImageFileName = '';
                return;
            }

            const form = new FormData();
            form.append('menuImage', file);
            const response = await fetch('/api/form/menu-image-upload', {
                method: 'POST',
                body: form
            });
            const data = await response.json();
            if (!response.ok) {
                throw new Error(data.error || 'Failed to upload menu image');
            }
            uploadedMenuImagePath = data.menuImagePath || '';
            uploadedMenuImageFileName = data.menuImageFileName || file.name;
        }

        async function submitMenu(skipAiReview = false) {
            if (!skipAiReview && !aiCheckHasRun) {
                showAlert('Run Basic AI Check before submitting.', 'error');
                return;
            }

            if (!skipAiReview && requiresAiRerun) {
                showAlert('You edited the menu after AI check. Please re-run AI Check before submitting.', 'error');
                return;
            }

            if (!skipAiReview && aiCheckResults && aiCheckResults.suggestions) {
                const unresolvedCritical = aiCheckResults.suggestions.some((s, idx) =>
                    s.severity === 'critical' && !criticalErrorOverrides[idx]
                );
                if (unresolvedCritical) {
                    showAlert('Please resolve or override all critical errors before submitting.', 'error');
                    return;
                }
            }

            if (submissionMode === 'modification' && !revisionBaseSubmissionId && !revisionBaselineDocPath) {
                showAlert('Choose a modification source and load a baseline DOCX before submitting.', 'error');
                return;
            }

            if (!(await ensureBaselineFreshnessBeforeContinue())) {
                return;
            }

            if (isEditMode) {
                toggleEditMode();
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span>Submitting...';

            let menuContentHtml = '';
            let menuContentText = '';
            const step2Visible = !document.getElementById('step2').classList.contains('hidden');
            if (step2Visible) {
                const reviewedArea = document.getElementById('reviewedContentArea');
                menuContentHtml = sanitizeMenuHtmlForSubmission(reviewedArea.innerHTML || '');
                menuContentText = extractCleanTextFromReviewedArea(reviewedArea);
            } else {
                menuContentHtml = sanitizeMenuHtmlForSubmission(quill.root.innerHTML || '');
                menuContentText = quill.getText().trim();
            }

            const persistentPreviewBody = document.getElementById('persistentPreviewBody');
            const persistentDiffHtml = submissionMode === 'modification' && persistentPreviewBody
                ? persistentPreviewBody.innerHTML
                : '';

            document.getElementById('originalMenuDisplay').innerHTML = menuContentHtml;

            const approvals = [{
                approved: document.getElementById('approval1').value === 'yes',
                name: document.getElementById('approver1Name').value.trim(),
                position: document.getElementById('approver1Position').value.trim()
            }];

            const approval2 = document.getElementById('approval2').value;
            const approver2Name = document.getElementById('approver2Name').value.trim();
            const approver2Position = document.getElementById('approver2Position').value.trim();
            if (approval2 && approver2Name && approver2Position) {
                approvals.push({
                    approved: approval2 === 'yes',
                    name: approver2Name,
                    position: approver2Position
                });
            }

            const criticalOverrides = [];
            if (aiCheckResults && aiCheckResults.suggestions) {
                aiCheckResults.suggestions.forEach((s, idx) => {
                    if (s.severity === 'critical' && criticalErrorOverrides[idx]) {
                        criticalOverrides.push({
                            type: s.type,
                            menuItem: s.menuItem,
                            description: s.description
                        });
                    }
                });
            }

            const assetTypeValue = document.getElementById('assetType').value;
            const isPrint = assetTypeValue === 'PRINT' || assetTypeValue === 'BOTH';
            const isDigital = assetTypeValue === 'DIGITAL' || assetTypeValue === 'BOTH';
            const printRegion = document.getElementById('printRegion').value || '';
            const printSize = document.getElementById('printSize').value || '';
            const printWidth = document.getElementById('widthPrint').value.trim();
            const printHeight = document.getElementById('heightPrint').value.trim();
            const digitalWidth = document.getElementById('widthDigital').value.trim();
            const digitalHeight = document.getElementById('heightDigital').value.trim();
            const resolvedWidth = assetTypeValue === 'DIGITAL'
                ? digitalWidth
                : (assetTypeValue === 'PRINT' ? (printRegion === 'NON_US' ? printSize : printWidth) : digitalWidth);
            const resolvedHeight = assetTypeValue === 'DIGITAL'
                ? digitalHeight
                : (assetTypeValue === 'PRINT' ? (printRegion === 'NON_US' ? printSize : printHeight) : digitalHeight);

            const formData = {
                submitterName: document.getElementById('submitterName').value.trim(),
                submitterEmail: document.getElementById('submitterEmail').value.trim(),
                submitterJobTitle: document.getElementById('submitterJobTitle').value.trim(),
                projectName: document.getElementById('projectName').value.trim(),
                property: document.getElementById('property').value.trim(),
                width: resolvedWidth,
                height: resolvedHeight,
                printWidth: isPrint ? printWidth : '',
                printHeight: isPrint ? printHeight : '',
                printRegion: isPrint ? printRegion : '',
                printSize: isPrint ? printSize : '',
                folded: isPrint ? document.getElementById('folded').value : '',
                digitalWidth: isDigital ? digitalWidth : '',
                digitalHeight: isDigital ? digitalHeight : '',
                cropMarks: isPrint ? document.getElementById('cropMarks').value : '',
                bleedMarks: isPrint ? document.getElementById('bleedMarks').value : '',
                fileSizeLimit: isPrint ? document.getElementById('fileSizeLimit').value : '',
                fileSizeLimitMb: isPrint ? document.getElementById('fileSizeLimitMb').value.trim() : '',
                fileDeliveryNotes: isPrint ? document.getElementById('fileDeliveryNotes').value.trim() : '',
                orientation: document.getElementById('orientation').value,
                menuType: document.getElementById('menuType').value,
                servicePeriod: document.getElementById('servicePeriod').value,
                templateType: document.getElementById('templateType').value,
                turnaroundDays: getTurnaroundDaysValue(),
                dateNeeded: document.getElementById('dateNeeded').value,
                assetType: assetTypeValue,
                allergens: getAllergenInputValue(),
                containsRawUndercooked: getContainsRawSelection(),
                suppressRawNotice: suppressRawNotice,
                menuContent: menuContentText,
                menuContentHtml: menuContentHtml,
                persistentDiffHtml: persistentDiffHtml,
                preservedFooterText: preservedManagedFooterText,
                approvals: approvals,
                criticalOverrides: criticalOverrides,
                submissionMode: submissionMode,
                unapprovedMode: submissionMode === 'modification' ? unapprovedMode : false,
                revisionSource: submissionMode === 'modification' ? revisionSource : null,
                revisionBaseSubmissionId: revisionBaseSubmissionId,
                revisionBaselineDocPath: submissionMode === 'modification' ? revisionBaselineDocPath : '',
                revisionBaselineFileName: submissionMode === 'modification' ? revisionBaselineFileName : '',
                baseApprovedMenuContent: submissionMode === 'modification' ? baseApprovedMenuContent : '',
                chefPersistentDiff: submissionMode === 'modification' ? persistentDiffSummary : null,
                skipAiReview: !!skipAiReview,
                menuImagePath: '',
                menuImageFileName: ''
            };

            try {
                await uploadMenuImageIfNeeded();
                formData.menuImagePath = uploadedMenuImagePath || '';
                formData.menuImageFileName = uploadedMenuImageFileName || '';
                const submitBody = JSON.stringify(formData);
                const submitBodyLength = byteLength(submitBody);
                await logFormAttempt('submit_started', {
                    route: '/api/form/submit',
                    menuTextLength: menuContentText.length,
                    menuHtmlLength: menuContentHtml.length,
                    persistentDiffHtmlLength: persistentDiffHtml.length,
                    requestBodyLength: submitBodyLength,
                    suggestionsCount: (aiCheckResults?.suggestions || []).length,
                    criticalSuggestionsCount: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical').length,
                    criticalSuggestions: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical'),
                    details: {
                        skipAiReview: !!skipAiReview,
                        unapprovedMode: !!formData.unapprovedMode,
                        hasMenuImage: !!formData.menuImagePath,
                        overriddenCriticalCount: criticalOverrides.length
                    }
                });

                const response = await fetch('/api/form/submit', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', ...getAttemptHeaders() },
                    body: submitBody
                });

                const responseText = await response.text();
                let data = {};
                if (responseText) {
                    try {
                        data = JSON.parse(responseText);
                    } catch (parseError) {
                        data = {
                            error: response.status === 504
                                ? 'The server timed out while submitting the menu. The team has been notified; please wait a moment before retrying.'
                                : `The server returned an unexpected ${response.status || 'error'} response while submitting the menu.`
                        };
                    }
                }

                if (!response.ok) {
                    await logFormAttempt('submit_failed', {
                        route: '/api/form/submit',
                        statusCode: response.status,
                        menuTextLength: menuContentText.length,
                        menuHtmlLength: menuContentHtml.length,
                        persistentDiffHtmlLength: persistentDiffHtml.length,
                        requestBodyLength: submitBodyLength,
                        suggestionsCount: (aiCheckResults?.suggestions || []).length,
                        criticalSuggestionsCount: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical').length,
                        criticalSuggestions: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical'),
                        errorMessage: data.error || 'Failed to submit menu',
                        details: {
                            responseText: responseText.slice(0, 1000),
                            skipAiReview: !!skipAiReview,
                            unapprovedMode: !!formData.unapprovedMode,
                            overriddenCriticalCount: criticalOverrides.length
                        }
                    });
                    throw new Error(data.error || 'Failed to submit menu');
                }
                await logFormAttempt('submit_completed', {
                    route: '/api/form/submit',
                    statusCode: response.status,
                    menuTextLength: menuContentText.length,
                    menuHtmlLength: menuContentHtml.length,
                    persistentDiffHtmlLength: persistentDiffHtml.length,
                    requestBodyLength: submitBodyLength,
                    suggestionsCount: (aiCheckResults?.suggestions || []).length,
                    criticalSuggestionsCount: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical').length,
                    criticalSuggestions: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical'),
                    details: {
                        submissionId: data.submissionId || null,
                        clickupTaskId: data.clickup?.taskId || null,
                        localTesting: !!data.localTesting,
                        skipAiReview: !!skipAiReview,
                        unapprovedMode: !!formData.unapprovedMode,
                        overriddenCriticalCount: criticalOverrides.length
                    }
                });

                const localTesting = data.localTesting || null;
                if (localTesting && localTesting.downloadUrl) {
                    triggerLocalSubmissionDownload(localTesting.downloadUrl);
                    showAlert('Menu submitted locally. The submitted Word document is downloading now.', 'success', {
                        persistent: true,
                        actions: localTesting.approvalUrl ? [{
                            href: localTesting.approvalUrl,
                            label: 'Open approval editor',
                        }] : []
                    });
                } else {
                    showAlert('Menu submitted successfully. Sent to ClickUp for team review. You can submit another menu now.', 'success');
                }
                if (data.clickup && data.clickup.warning) {
                    showAlert(data.clickup.warning, 'warning');
                }
                prepareForNextSubmission();

            } catch (error) {
                console.error('Error:', error);
                await logFormAttempt('submit_client_exception', {
                    route: '/api/form/submit',
                    menuTextLength: menuContentText.length,
                    menuHtmlLength: menuContentHtml.length,
                    persistentDiffHtmlLength: persistentDiffHtml.length,
                    requestBodyLength: typeof formData !== 'undefined' ? byteLength(JSON.stringify(formData)) : null,
                    suggestionsCount: (aiCheckResults?.suggestions || []).length,
                    criticalSuggestionsCount: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical').length,
                    criticalSuggestions: (aiCheckResults?.suggestions || []).filter((s) => s.severity === 'critical'),
                    errorMessage: error.message,
                    details: {
                        skipAiReview: !!skipAiReview,
                        unapprovedMode: !!formData.unapprovedMode,
                        overriddenCriticalCount: criticalOverrides.length
                    }
                });
                showAlert('Error submitting menu: ' + error.message, 'error', {
                    onRetry: () => submitForm()
                });
                btn.disabled = false;
                btn.textContent = 'Submit Menu for Review';
            }
        }

        function prepareForNextSubmission() {
            const retainedAllergens = getAllergenInputValue();
            resetFormAttemptId();

            aiCheckHasRun = false;
            aiCheckResults = null;
            criticalErrorOverrides = {};
            aiChanges = [];
            originalAiCorrectedText = '';
            persistentDiffSummary = { insertions: 0, deletions: 0 };
            unapprovedMode = false;
            unapprovedAnnotations = [];
            unapprovedBaseHtml = '';
            unapprovedDiffBaseline = '';
            unapprovedAnnotationMap = {};
            preservedManagedFooterText = '';

            if (isEditMode) {
                toggleEditMode();
            }

            // Return to new submission mode and clear revision-only state.
            document.getElementById('submissionModeModification').checked = true;
            document.getElementById('submissionModeNew').checked = false;
            onSubmissionModeChange();

            // Keep form metadata populated but clear menu content for next submission.
            quill.setText('');
            displayReviewedContent('');
            document.getElementById('originalMenuDisplay').innerHTML = '';
            document.getElementById('step2').classList.add('hidden');
            document.getElementById('step1').classList.remove('hidden');
            setAiSuggestionsVisibility(false);
            renderPersistentPreview('', '');
            setAllergenInputValue(retainedAllergens);

            const suggestionsDisplay = document.getElementById('suggestionsDisplay');
            if (suggestionsDisplay) suggestionsDisplay.innerHTML = '';

            const runCheckBtn = document.getElementById('runCheckBtn');
            if (runCheckBtn) {
                runCheckBtn.disabled = false;
                runCheckBtn.textContent = requiresAiReview() ? 'Run Basic AI Check' : 'Submit Menu for Review';
            }
            const runCheckBtnBottom = document.getElementById('runCheckBtnBottom');
            if (runCheckBtnBottom) {
                runCheckBtnBottom.disabled = false;
                runCheckBtnBottom.textContent = requiresAiReview() ? 'Run Basic AI Check' : 'Submit Menu for Review';
            }

            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Submit Menu for Review';
            submitBtn.classList.remove('blocked');
            document.getElementById('criticalErrorBanner').classList.remove('show');
            const imageUpload = document.getElementById('menuImageUpload');
            if (imageUpload) imageUpload.value = '';
            uploadedMenuImagePath = '';
            uploadedMenuImageFileName = '';
            applyTurnaroundDefaults(true, true);

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function displayReviewedContent(htmlContent) {
            const reviewedArea = document.getElementById('reviewedContentArea');

            // Clean up excessive empty paragraphs that can accumulate
            let cleanedHtml = htmlContent
                // Remove multiple consecutive empty paragraphs
                .replace(/(<p><br><\/p>\s*){2,}/gi, '<p><br></p>')
                // Remove multiple consecutive &nbsp; paragraphs
                .replace(/(<p>&nbsp;<\/p>\s*){2,}/gi, '<p><br></p>')
                // Remove empty paragraphs with just whitespace
                .replace(/<p>\s*<\/p>/gi, '<p><br></p>');

            reviewedArea.innerHTML = cleanedHtml;
            document.getElementById('originalMenuDisplay').innerHTML = cleanedHtml;
        }

        function sanitizeMenuHtmlForSubmission(htmlContent) {
            let html = htmlContent || '';

            // Remove purely-empty paragraphs; these often become visual double-spacing in DOCX.
            html = html.replace(/<p>(?:\s|&nbsp;|<br\s*\/?>)*<\/p>/gi, '');

            // Collapse excessive whitespace between paragraph tags.
            html = html.replace(/>\s+</g, '><').trim();
            return html;
        }

        function toggleEditMode() {
            const editBtn = document.getElementById('editToggleBtn');
            const editNotice = document.getElementById('editModeNotice');
            const reviewedArea = document.getElementById('reviewedContentArea');

            isEditMode = !isEditMode;

            if (isEditMode) {
                editBtn.classList.add('active');
                editBtn.innerHTML = '<span class="edit-toggle-icon">Done Editing</span>';
                editNotice.classList.add('show');
                reviewedArea.classList.add('editable');
                reviewedArea.contentEditable = 'true';

                reviewedArea.focus();
                reviewedArea.addEventListener('input', handleReviewedAreaInput);
                // Hide re-run button while editing
                document.getElementById('rerunCheckBtn').classList.remove('show');
            } else {
                editBtn.classList.remove('active');
                editBtn.innerHTML = '<span class="edit-toggle-icon">Edit</span>';
                editNotice.classList.remove('show');
                reviewedArea.classList.remove('editable');
                reviewedArea.contentEditable = 'false';
                reviewedArea.removeEventListener('input', handleReviewedAreaInput);

                recalculateHighlights();
                // Show re-run button after editing
                document.getElementById('rerunCheckBtn').classList.add('show');
            }
        }

        function extractCleanTextFromReviewedArea(element) {
            return redlinePreview.extractCleanTextFromElement(element);
        }

        function normalizeExtractedLines(rawLines) {
            return redlinePreview.normalizeExtractedLines(rawLines);
        }

        function handleReviewedAreaInput() {
            const reviewedArea = document.getElementById('reviewedContentArea');
            const currentText = extractCleanTextFromReviewedArea(reviewedArea);
            if (lastAiCheckedMenuText && currentText !== lastAiCheckedMenuText) {
                markAiCheckStale();
            }
            renderAllergenLegend();
            clearTimeout(persistentPreviewUpdateTimer);
            persistentPreviewUpdateTimer = setTimeout(() => {
                const diffBase = (unapprovedMode && unapprovedDiffBaseline)
                    ? unapprovedDiffBaseline
                    : (baseApprovedMenuContent || (aiCheckResults?.originalMenu || ''));
                renderPersistentPreview(diffBase, currentText);
            }, 120);
        }

        /**
         * Build a flat annotation lookup from unapprovedAnnotations (per-paragraph).
         * Returns a map keyed by character offset into the full baseText, with value 'del' or 'ins'.
         */
        function buildAnnotationMap(baseText) {
            return redlinePreview.buildAnnotationMapFromParagraphAnnotations(baseText, unapprovedAnnotations);
        }

        /**
         * Build annotation map from the editor DOM at load time.
         * Finds .existing-del / .existing-ins spans, extracts their text
         * using innerText (matching extractCleanTextFromReviewedArea),
         * and locates them in the baseline string via indexOf.
         * Returns a map keyed by character offset into the baseline text.
         */
        function buildAnnotationMapFromDOM(element) {
            return redlinePreview.buildAnnotationMapFromDOM(element);
        }

        /**
         * Wrap a token with existing-annotation styling if its character range
         * overlaps any annotation in the map. Returns the HTML string.
         */
        function wrapWithExistingAnnotation(token, charOffset, annotationMap) {
            return redlinePreview.wrapWithExistingAnnotation(token, charOffset, annotationMap);
        }

        function renderPersistentPreview(baseText, revisedText) {
            const previewSection = document.getElementById('persistentPreviewSection');
            const previewBody = document.getElementById('persistentPreviewBody');

            if (submissionMode !== 'modification') {
                previewSection.classList.remove('show');
                previewBody.innerHTML = '';
                return;
            }

            previewSection.classList.add('show');
            const baselineHtml = unapprovedMode
                ? (unapprovedBaseHtml || '')
                : (baseApprovedMenuContentHtml || '');
            const rendered = redlinePreview.renderPersistentPreview(baseText, revisedText, {
                annotationMap: unapprovedMode ? unapprovedAnnotationMap : {},
                includeExistingAnnotations: unapprovedMode,
                baselineHtml,
            });

            persistentDiffSummary = {
                insertions: rendered.insertions,
                deletions: rendered.deletions,
            };
            previewBody.innerHTML = rendered.html;
        }

        function recalculateHighlights() {
            const reviewedArea = document.getElementById('reviewedContentArea');

            // Extract clean text from the edited content
            const currentText = extractCleanTextFromReviewedArea(reviewedArea);

            quill.setText(currentText);

            const currentChanges = computeLineDiff(aiCheckResults.originalMenu, currentText);
            const preservedChanges = [];

            aiChanges.forEach(aiChange => {
                const changeStillPresent = currentChanges.some(currentChange => {
                    return currentChange.word === aiChange.word &&
                           Math.abs(currentChange.start - aiChange.start) < 5;
                });

                const textAtPosition = currentText.substring(
                    Math.max(0, aiChange.start - 10),
                    aiChange.start + aiChange.length + 10
                );

                if (changeStillPresent || textAtPosition.includes(aiChange.word)) {
                    const newPosition = findWordPosition(currentText, aiChange.word, aiChange.start);
                    if (newPosition !== -1) {
                        preservedChanges.push({
                            start: newPosition,
                            length: aiChange.length,
                            word: aiChange.word
                        });
                    }
                }
            });

            preservedChanges.forEach(change => {
                quill.formatText(change.start, change.length, {
                    background: 'rgba(74, 124, 89, 0.2)'
                });
            });

            displayReviewedContent(quill.root.innerHTML);
            const recalcBase = (unapprovedMode && unapprovedDiffBaseline)
                ? unapprovedDiffBaseline
                : (baseApprovedMenuContent || aiCheckResults.originalMenu);
            renderPersistentPreview(recalcBase, currentText);
        }

        function findWordPosition(text, word, expectedPosition) {
            const searchStart = Math.max(0, expectedPosition - 50);
            const searchEnd = Math.min(text.length, expectedPosition + 50);
            const searchArea = text.substring(searchStart, searchEnd);
            const localIndex = searchArea.indexOf(word);

            if (localIndex !== -1) {
                return searchStart + localIndex;
            }

            return text.indexOf(word);
        }

    </script>
</body>
</html>
