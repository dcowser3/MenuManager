        function togglePrintRegionFields() {
            const printRegion = document.getElementById('printRegion').value;
            const printSizeGroup = document.getElementById('printSizeGroup');
            const printWidthGroup = document.getElementById('printWidthGroup');
            const printHeightGroup = document.getElementById('printHeightGroup');
            const widthInput = document.getElementById('widthPrint');
            const heightInput = document.getElementById('heightPrint');
            const sizeSelect = document.getElementById('printSize');
            const needsPrint = ['PRINT', 'BOTH'].includes(document.getElementById('assetType').value);

            if (!needsPrint) {
                printSizeGroup.classList.add('hidden');
                printWidthGroup.classList.remove('hidden');
                printHeightGroup.classList.remove('hidden');
                widthInput.disabled = false;
                heightInput.disabled = false;
