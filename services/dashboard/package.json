{
  "name": "@menumanager/dashboard",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp -r views dist/ && cp -r public dist/",
    "start": "npm run build && node dist/index.js",
    "dev": "ts-node index.ts",
    "watch": "ts-node-dev --respawn --transpile-only --clear index.ts",
    "clickup:completed-dry-run": "node scripts/clickup-completed-import.js",
    "clickup:audit-approved-dishes": "node scripts/audit-approved-dishes.js"
  },
  "dependencies": {
    "@menumanager/diff-core": "*",
    "@menumanager/internal-auth": "*",
    "@menumanager/supabase-client": "*",
    "axios": "^1.6.2",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "ejs": "^3.1.9",
    "mammoth": "^1.6.0",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
